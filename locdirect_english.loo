		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.line.poor3";
			Text ="Como posso alimentar minha família com meus ganhos?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.line.com1";
			Text ="Tenho a sensação de que trabalho mais, mas ganho menos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.line.com2";
			Text ="Por que eu deveria trabalhar mais se o salário é sempre muito escasso?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.line.rich1";
			Text ="Definitivamente eu deveria ganhar mais!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.answer.poor1";
			Text ="Todos nós temos o mesmo problema. Pobreza.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.answer.poor2";
			Text ="Estou com o mesmo problema. Talvez devêssemos procurar outro mestre?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.answer.com1";
			Text ="Você não encontrará ninguém satisfeito com seu salário.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.answer.com2";
			Text ="Essas pessoas ricas são tão mesquinhas. Eles deveriam nos pagar mais!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.answer.rich1";
			Text ="Eu gostaria de falar sobre outra coisa além de dinheiro... É chato.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.answer.rich2";
			Text ="Todos nós merecemos ganhar mais.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.line.poor1";
			Text ="Tudo é tão caro...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.line.poor2";
			Text ="Todos os produtos são muito caros.";
