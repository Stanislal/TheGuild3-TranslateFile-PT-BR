		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v4.int_intim";
			Text ="É difícil não concordar com palavras tão sábias.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v4.int_intim";
			Text ="Isso não está certo. A política deveria influenciar a religião; caso contrário, por que alguém iria querer candidatar-se a um cargo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v4.char_intim";
			Text ="O mundo secular é pacífico...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v4.char_intim";
			Text ="Imagine um mundo onde católicos e protestantes vivam juntos em ritmo acelerado. É assim que se parece um mundo secular.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v4.char_intim";
			Text ="Sim, todo mundo está cansado dessas disputas constantes.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v4.char_intim";
			Text ="Devido a todos os nossos pecados, a vida na terra nunca será pacífica.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v4.bb_intim";
			Text ="Devemos manter a política e a fé separadas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v4.bb_intim";
			Text ="Manter a política e a fé separadas é a única maneira de construir uma sociedade pacífica.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v4.bb_intim";
			Text ="Isso parece maravilhoso! Este é o mundo em que todos gostariam de viver!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v4.bb_intim";
			Text ="Sonhe, algumas coisas são simplesmente impossíveis.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v5.int_intim";
			Text ="A política não deve corromper a religião...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v5.int_intim";
			Text ="A política não deveria ser capaz de corromper a religião, é por isso que essas duas coisas deveriam ser separadas. O que você acha?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v5.int_intim";
			Text ="Isso mesmo, é assim que deveria ser.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v5.int_intim";
			Text ="Você tem certeza de que a política corrompe a religião e não vice-versa? Seu argumento não se sustenta.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v5.char_intim";
			Text ="Muitas religiões coexistem num país secular.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v5.char_intim";
			Text ="Católicos, protestantes e outras religiões poderiam coexistir pacificamente num país secular.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v5.char_intim";
			Text ="Correto! É cansativo pensar constantemente na fé dos outros. Afinal, somos todos humanos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v5.char_intim";
			Text ="Que imagem linda... mas irreal.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v5.bb_intim";
			Text ="Os políticos não devem ser influenciados pelos padres...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v5.bb_intim";
			Text ="Não seria ótimo ser político e não estar sob a influência de padres? Que liberdade!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v5.bb_intim";
			Text ="Esses padres gostariam de ter controle e poder sobre cada parte trivial de nossas vidas! Deveríamos parar com isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v5.bb_intim";
			Text ="Esses políticos são tão confiáveis? É altamente improvável.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v1.int_intim";
			Text ="Os protestantes preferem Deus, não ouro...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v1.int_intim";
			Text ="Os interessados em Deus deveriam ser protestantes. Os interessados ​​em ouro deveriam ser católicos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v1.int_intim";
			Text ="Deus é mais importante sem dúvida.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v1.int_intim";
			Text ="Ouro é poder. É nisso que os verdadeiros empresários devem se concentrar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v1.char_intim";
			Text ="Vejo uma alma pura diante de mim...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v1.char_intim";
			Text ="Vejo uma alma pura que deveria se juntar à nossa Igreja Protestante. Nós nos preocupamos com a fé, não com o ouro.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v1.char_intim";
			Text ="Obrigado pela sua oferta. Sim, a fé é a coisa mais importante na vida do homem.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v1.char_intim";
			Text ="A fé não é interessante, mas o ouro certamente é.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v1.bb_intim";
			Text ="Tradição humana ou palavra de Deus?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v1.bb_intim";
			Text ="O que é mais importante? Tradição ou palavra de Deus? Nossa Igreja Protestante acredita na Bíblia, não em tradições.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v1.bb_intim";
			Text ="Na verdade, as tradições são fraquezas humanas, mas a Palavra de Deus é eterna.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v1.bb_intim";
			Text ="A tradição vem da Bíblia. Deveríamos respeitar isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v2.int_intim";
			Text ="Apenas uma fé profunda é necessária para a salvação...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v2.int_intim";
			Text ="Apenas uma fé profunda é necessária para a salvação. Alguém confessa seus pecados somente a Deus! É nisso que nós, os protestantes, acreditamos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v2.int_intim";
			Text ="Isso parece interessante e faz sentido.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v2.int_intim";
			Text ="Se alguém precisa apenas de fé para obter a salvação, isso significa que podemos pecar tanto quanto quisermos. Isso parece tolice.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v2.char_intim";
			Text ="Ser protestante significa buscar a verdade...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v2.char_intim";
			Text ="Ser protestante significa acreditar e buscar a verdadeira vontade de Deus.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v2.char_intim";
			Text ="A verdade é a única coisa valiosa no mundo. Concordo com você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v2.char_intim";
			Text ="O que isso significa? Todos os crentes pregam as mesmas banalidades, independentemente da sua religião.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v2.bb_intim";
			Text ="A Igreja Católica tem ouro suficiente...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v2.bb_intim";
			Text ="Você quer doar o seu suado ouro para a corrupta Igreja Católica? Já tem riqueza suficiente!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v2.bb_intim";
			Text ="Isso mesmo, minha família e eu também precisamos desse ouro!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v2.bb_intim";
			Text ="Só uma pessoa mesquinha pensaria assim.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v3.int_intim";
			Text ="O culto aos santos não vem da Bíblia.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v3.int_intim";
			Text ="O Culto aos Santos, imagens, relíquias, tudo isso é invenção, e não vem da Bíblia. Nós não acreditamos nisso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v3.int_intim";
			Text ="Imagens de santos e relíquias só são criadas para ganhar mais ouro! É assim que as coisas são!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v3.int_intim";
			Text ="Santos ajudam pessoas como eu. Por que os protestantes estão dizendo coisas tão horríveis?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v3.char_intim";
			Text ="Os protestantes querem estar mais perto de Deus.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v3.char_intim";
			Text ="Os católicos esqueceram o que significa ser um verdadeiro cristão. Nós, protestantes, queremos estar mais perto de Deus.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v3.char_intim";
			Text ="Ser protestante parece razoável.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v3.char_intim.female";
			Text ="Ser protestante parece razoável.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v3.char_intim";
			Text ="Todo cristão quer estar mais perto de Deus, não apenas os protestantes.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v3.bb_intim";
			Text ="A Igreja Católica não é confiável.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v3.bb_intim";
			Text ="Você pode confiar em uma pessoa que prega água, mas bebe vinho? É precisamente isso que a Igreja Católica faz.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v3.bb_intim";
			Text ="Um pensamento interessante. Talvez os protestantes levem a verdade mais a sério.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v3.bb_intim";
			Text ="Todas as igrejas são iguais...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v4.int_intim";
			Text ="A Igreja Católica é uma organização política...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v4.int_intim";
			Text ="Você acha que a Igreja Católica é uma instituição de fé? É uma organização política.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v4.int_intim";
			Text ="Sim, é verdade! Fazer parte da Igreja Protestante parece melhor.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v4.int_intim";
			Text ="Não devemos ser ingênuos. Não há nada neste mundo que não seja político até certo ponto.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v4.char_intim";
			Text ="Os católicos perdoam pecados por ouro...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v4.char_intim";
			Text ="Na Igreja Católica, o perdão de todos os pecados é possível desde que você tenha ouro no bolso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v4.char_intim.male";
			Text ="Quando você coloca dessa forma, parece ruim. Talvez seja melhor ser protestante.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v4.char_intim.female";
			Text ="Quando você coloca dessa forma, parece ruim. Talvez seja melhor ser protestante.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v4.char_intim";
			Text ="Pelo menos essa regra é simples e transparente.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v4.bb_intim";
			Text ="Os católicos interpretam os textos sagrados incorretamente...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v4.bb_intim";
			Text ="A Igreja Católica interpreta as escrituras sagradas para atender aos seus próprios fins. Como você pode acreditar no que os católicos dizem?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v4.bb_intim";
			Text ="Ultrajante, como pode ser isso! A Igreja Protestante parece ser a escolha certa!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v4.bb_intim";
			Text ="Isso é o que significa interpretação. Essa discussão é uma perda de tempo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v5.int_intim";
			Text ="Os católicos só querem que as pessoas obedeçam.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v5.int_intim";
			Text ="Um bom cristão da Igreja Católica paga e obedece. Nós, protestantes, somos diferentes.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v5.int_intim";
			Text ="Se os protestantes são diferentes, pode ser uma boa ideia filiar-se a esta igreja.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v5.int_intim";
			Text ="Os protestantes estão apenas fingindo que são diferentes. Eles são todos iguais.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v5.char_intim";
			Text ="Ficamos maravilhados com a criação de Deus...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v5.char_intim";
			Text ="Ficamos maravilhados com o mundo como criação de Deus, e não com os santos como criação do homem.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v5.char_intim";
			Text ="Isso parece interessante. Eu gostaria de aprender mais sobre isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v5.char_intim";
			Text ="Mas imagens de santos são tão lindas...";
