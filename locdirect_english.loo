		LocDirectEntry
		{
			Key ="$ui.storageRules.headers.keepStorage.tooltip";
			Text ="Mín. Armazenamento\nVenda: transportadores automatizados venderão itens acima desta configuração quando não estiverem em uso para produção\nAquisição: transportadores automatizados comprarão quantos itens forem necessários para atingir a quantidade definida nesta configuração quando necessário para produção.";
		},
		LocDirectEntry
		{
			Key ="$ui.storageRules.headers.ProcureItem";
			Text ="Aquisição$(Dica)";
		},
		LocDirectEntry
		{
			Key ="$ui.storageRules.headers.ProcureItem.tooltip";
			Text ="Aquisição\nTransportadores Automatizados tentarão adquirir itens para este negócio quando necessário para a produção e tentarão manter o nível de estoque desses itens pelo menos \"Min. Storage\" amount. Furthermore, automated workers will not produce this item, as they expect the transporters to procure it.";
		},
		LocDirectEntry
