		LocDirectEntry
		{
			Key ="$gui.production.mode.manualLooped.tooltip";
			Text ="Produção em loop: os trabalhadores continuarão percorrendo a mesma lista de pedidos e apenas omitirão os pedidos que não puderem ser atendidos no momento determinado. Os trabalhadores que trabalham em uma lista de ordens de produção em loop receberão um bônus na produtividade.";
		},
		LocDirectEntry
		{
			Key ="$gui.production.mode.manual.tooltip";
			Text ="Produção manual: os trabalhadores produzirão apenas o que foi encomendado. As encomendas que não possam ser cumpridas serão omitidas até que os requisitos essenciais sejam cumpridos. Os trabalhadores que trabalham com uma lista de pedidos manual receberão um bônus na produtividade.";
