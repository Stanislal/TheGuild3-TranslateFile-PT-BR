			Text ="Um poeta escreveu uma música sobre roupas íntimas de %CharacterContext%. Como ele sabia como era?";
		},
		LocDirectEntry
		{
			Key ="$d.act.Denounce.fullLine11";
			Text ="%CharacterContext% sempre trapaceia na pesagem de mercadorias!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Denounce.fullLine12";
			Text ="%CharacterContext% nunca dá esmola aos pobres!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Denounce.fullLine13";
			Text ="Adivinha quem tem pernas tortas? %CharacterContext% claro!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine6";
			Text ="Todo mundo sabe que %CharacterContext% é muito piedoso. Não conheço nenhuma outra pessoa que reze com tanta frequência!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine7";
			Text ="%CharacterContext% está sempre dando esmolas aos pobres.";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine8";
			Text ="Ninguém tem tolerância ao álcool como %CharacterContext%, essa pessoa consegue beber tanto quanto quatro homens!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine9";
			Text ="Todos nós poderíamos aprender com %CharacterContext% como administrar um negócio!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine10";
			Text ="Nunca vi %CharacterContext% tratar mal os funcionários.";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine11";
			Text ="A dança de %CharacterContext% é sempre cheia de alegria e graça!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine12";
			Text ="Quem não desejaria uma família como %CharacterContext% tem?";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine13";
			Text ="%CharacterContext% sempre fala sobre nosso soberano com respeito.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.v2.per";
			Text ="Uma moeda falsa para um mendigo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.v2.per";
			Text ="Eu vi você dar uma moeda falsa para um mendigo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.v2.per";
			Text ="Eu só queria que as pessoas pensassem que sou uma pessoa generosa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.v2.per";
			Text ="Não fazia ideia que era uma moeda falsa...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.v2.per";
			Text ="Você tem alguma prova?";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.v2.per";
			Text ="Recebi esta moeda DE VOCÊ!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.v2.prod";
			Text ="Ser ganancioso e mesquinho...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.v2.prod";
			Text ="Todo mundo sabe que você é ganancioso e mesquinho. Você nem jogaria um osso para um cachorro.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.v2.prod";
			Text ="Eu adoraria dizer que não é verdade, mas você está certo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.v2.prod";
			Text ="Eu sei que a ganância é um dos sete pecados capitais, mas eu adoro ossos!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.v2.prod";
			Text ="Como você pode saber tanto sobre minha personalidade? Você mal me conhece!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.v2.prod";
			Text ="Isso é calúnia! A igreja recebe doações regulares da minha família.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.v2.int";
			Text ="Como comer com um porco...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.v2.int";
			Text ="Ter você como convidado em uma festa é como comer com um porco que não é alimentado há muito tempo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.v2.int";
			Text ="Me sinto tão humilhado, e tudo por causa do meu grande apetite.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.v2.int";
			Text ="Simplesmente não sei como lidar com meu grande apetite.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.v2.int";
			Text ="Se você pudesse se ver enquanto está comendo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.v2.int";
			Text ="Como você pode saber disso, se ninguém nunca te convidou para um grande banquete?!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.v3.per";
			Text ="Você falou mal do soberano...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.v3.per";
			Text ="Uma vez ouvi você falar mal do nosso soberano!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.v3.per";
			Text ="Foi só uma vez! Eu estava tendo um dia realmente horrível!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.v3.per";
			Text ="Eu não quis dizer isso! Foi só uma brincadeira!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.v3.per";
			Text ="Significa que eu estava fazendo exatamente o que metade da cidade faz. Você vai acusar todos esses cidadãos também?";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.v3.per";
			Text ="Talvez você tenha uma memória ruim, então deixe-me lembrá-lo que esta foi a SUA opinião no início.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.v3.prod";
			Text ="Você tem ronco na igreja...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.v3.prod";
			Text ="A congregação inteira ouviu você roncando na igreja no domingo passado! Como você pode ser tão desrespeitoso?";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.v3.prod";
			Text ="Por favor, me perdoe! É que estou trabalhando tanto...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.v3.prod";
			Text ="Estou tão envergonhado, mas o sermão foi simplesmente tão chato...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.v3.prod";
			Text ="Não me lembro nada disso; talvez você apenas tenha sonhado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.v3.prod";
			Text ="Você está distorcendo os fatos. Foi VOCÊ quem adormeceu durante a última Santa Missa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.v3.int";
			Text ="Você é uma dançarina horrível...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.v3.int";
			Text ="Ouvi dizer que uma senhora perdeu a visão depois de ver você dançando.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.v3.int";
			Text ="Isso foi um acidente!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.v3.int";
			Text ="Essa não é toda a verdade. eu posso explicar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.v3.int";
			Text ="Ah, é mesmo? Eu, pela minha parte, ouvi você falar mal de outras pessoas em vez de trabalhar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.v3.int";
			Text ="Tentei imitar a maneira como você caminha para casa depois de tomar algumas canecas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.v2.cha";
			Text ="Você é bom e gentil...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.v2.cha";
			Text ="Tudo o que sei sobre você é bondade e graciosidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.v2.cha";
			Text ="Eu diria o mesmo de você, mas é bom receber um elogio de vez em quando.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.v2.cha";
			Text ="Suas palavras são muito lisonjeiras.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.v2.cha";
			Text ="Podemos concordar que você não sabe nada sobre mim.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.v2.cha";
			Text ="Não tenho interesse na sua bajulação.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.v2.prod";
			Text ="Seus talentos não têm preço...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.v2.prod";
			Text ="Você tem talentos que o tornam inestimável para nossa cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.v2.prod";
			Text ="Obrigado! Só espero que você esteja sendo honesto ao dizer isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.v2.prod";
			Text ="Por favor, pare, ou você vai me fazer corar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.v2.prod";
			Text ="Não tenho certeza se é um elogio ou apenas uma piada boba.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.v2.bb";
			Text ="Seu negócio é tão bem sucedido...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.v2.bb";
			Text ="Todos gostariam de administrar um negócio com tanto sucesso quanto você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.v2.bb";
			Text ="Muitas pessoas dizem que sou muito hábil em negociação.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.v2.bb";
			Text ="Obrigado. Nossa cidade está cheia de comerciantes inteligentes.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.v2.bb";
			Text ="Nesse caso, não devem perder tempo fazendo complementos falsos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.v2.bb";
			Text ="Um elogio como você não é agradável aos meus ouvidos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.v3.cha";
			Text ="Ninguém consegue dançar tão bem quanto você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.v3.cha";
			Text ="Ninguém consegue dançar tão bem quanto você! Você vai me contar seu segredo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.v3.cha";
			Text ="Será um prazer revelar esse segredo para uma pessoa tão simpática. Minha querida mãe me ensinou a dançar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.v3.cha";
			Text ="Estou muito feliz que você esteja me perguntando. Dançar é mesmo minha paixão!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.v3.cha";
			Text ="Por que eu deveria? Você não entenderia meus movimentos artísticos de dança!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.v3.cha";
			Text ="Não desejo discutir minha arte de dançar com você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.v3.prod";
			Text ="Seus funcionários trabalham tanto...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.v3.prod";
			Text ="Sempre vejo seus funcionários trabalhando de coração e alma! Como você os motiva?";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.v3.prod";
			Text ="Tenho meus métodos, mas o pagamento parece ser a estratégia mais eficiente.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.v3.prod";
			Text ="Ainda acho que eles poderiam trabalhar mais, mas obrigado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.v3.prod";
			Text ="Se você tratasse seus funcionários com respeito, eles também trabalhariam duro para você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.v3.prod";
			Text ="Não tenho tempo para conversas tão triviais.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.v3.bb";
			Text ="Você sabe negociar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.v3.bb";
			Text ="Uma vez ouvi você negociando em um mercado. Sua arte de falar é simplesmente admirável!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.v3.bb";
			Text ="Ouvi dizer que você domina a arte da retórica com a mesma eficácia.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.v3.bb";
			Text ="Tenho paixão por retórica.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.v3.bb";
			Text ="Não tenho ideia do que você está falando. Foram apenas negociações normais.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.v3.bb";
			Text ="Para ser honesto, não estou tão preocupado com suas palavras.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.v2.cha";
			Text ="Minha família é a alma desta cidade...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.v2.cha";
			Text ="Minha família fornece trabalho para pessoas pobres e produz os bens que você precisa. Somos a alma desta cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.v2.cha";
			Text ="Sim, sua dinastia é uma parte importante desta cidade. Eu aprecio isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.v2.cha";
			Text ="Bla, bla, bla... Odeio quando pessoas ricas se vangloriam, muitas palavras, mas vazias de sentido.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.v2.intim";
			Text ="Mais cedo ou mais tarde você precisará de algo nosso...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.v2.intim";
			Text ="Temos vários negócios. Mais cedo ou mais tarde você precisará de algo nosso. Você tem certeza de quem apoiará?";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.v2.intim";
			Text ="Bom ponto. Vou me lembrar disso e, claro, vou apoiá-lo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.v2.intim";
			Text ="Você superestima sua influência na cidade. Não vou perder meu tempo com algo assim...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.v2.str";
			Text ="Nossos funcionários são fracos...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.v2.str";
			Text ="Funcionários fracos têm assento em nosso conselho municipal. Considerando que minha família tem coração de leão. Devíamos governar a cidade!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.v2.str";
			Text ="Sim, é exatamente isso que penso da sua família! Eu vou apoiar você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.v2.str";
			Text ="Acho que temos dinastias melhores que poderiam liderar nossa cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.v3.cha";
			Text ="Nós dois nos divertimos muito na taverna...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.v3.cha";
			Text ="Não nos divertimos muito na taverna? Em nome dos interesses comuns, devemos apoiar-nos uns aos outros!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.v3.cha";
			Text ="Hum... bem... claro, eu me lembro da taverna! Eu vou apoiar você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.v3.cha";
			Text ="Raramente vou à taberna. Você deve estar me confundindo com outra pessoa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.v3.intim";
			Text ="Somente minha família pode liderar a cidade...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.v3.intim";
			Text ="Somente uma família competente e honrada como a minha pode liderar a cidade. Você precisa de nós. Isso parece razoável para você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.v3.intim";
			Text ="Eu respeito pessoas confiantes como você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.v3.intim";
			Text ="Com licença, mas sou eu quem decide o que preciso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.v3.str";
			Text ="Precisamos de funcionários sábios...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.v3.str";
			Text ="Os funcionários pensam que são mais espertos que você! Você não tem a propriedade necessária! Minha família nunca toleraria isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.v3.str";
			Text ="É realmente uma escandalosa falta de decoro! Por favor, mostre a eles o que é a verdadeira liderança!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.v3.str";
			Text ="A única coisa que podemos ter certeza é que eles são mais espertos que você.";
		},
		LocDirectEntry
		{
			Key ="$d.q.instructionToActiveDialogue";
			Text ="Por favor, escolha suas palavras:";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.All";
			Text ="Todos";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.Known";
			Text ="Empresas desbloqueadas";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.FoodPreparation";
			Text ="Empresas de preparação de alimentos";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.HuntingFarming";
			Text ="Empresas de preparação de alimentos";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.Handicraft";
			Text ="Negócios de artesanato";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.Herbalism";
			Text ="Empresas de bolsas de estudo";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.Rogue";
			Text ="Negócios desonestos";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.Other";
			Text ="Outros";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.City";
			Text ="Cidade";
		},
		LocDirectEntry
		{
			Key ="$gui.Erect.GroupName.Village";
			Text ="Aldeia";
		},
		LocDirectEntry
		{
			Key ="$WoodenShield";
			Text ="Escudo de madeira";
		},
		LocDirectEntry
		{
			Key ="$WoodenShieldDesc";
			Text ="Um escudo redondo simples feito de madeira.";
		},
		LocDirectEntry
		{
			Key ="$CopperBracelet";
			Text ="Pulseira de cobre";
		},
		LocDirectEntry
		{
			Key ="$CopperBraceletDesc";
			Text ="Uma simples bugiganga de cobre que pode decorar o braço de pessoas não tão ricas.";
		},
		LocDirectEntry
		{
			Key ="$ThrowingKnife";
			Text ="Faca de arremesso";
		},
		LocDirectEntry
