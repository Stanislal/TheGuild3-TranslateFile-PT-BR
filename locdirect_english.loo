			Text ="Reformista";
		},
		LocDirectEntry
		{
			Key ="$society.hussites.motto";
			Text ="Busque a verdade!";
		},
		LocDirectEntry
		{
			Key ="$society.hussites.name";
			Text ="Guilda dos Reformadores";
		},
		LocDirectEntry
		{
			Key ="$society.inquisition.desc";
			Text ="A Guilda dos Preservadores é uma associação de inquisidores leigos recrutados exclusivamente entre católicos estritamente devotos. Para a sua própria salvação - e por medo dos múltiplos castigos de Deus que podem atingir a sua cidade a qualquer momento - eles lutam contra os hereges e a heresia em todas as suas formas.";
		},
		LocDirectEntry
		{
			Key ="$society.inquisition.leader";
			Text ="Grande Inquisidor";
		},
		LocDirectEntry
		{
			Key ="$society.inquisition.leader.female";
