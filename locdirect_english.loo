		LocDirectEntry
		{
			Key ="$Barber";
			Text ="Barbeiro";
		},
		LocDirectEntry
		{
			Key ="$BarberDesc";
			Text ="O barbeiro proporciona relaxamento e limpeza corporal, como banho de hidromassagem e corte de cabelo. No entanto, os barbeiros são vistos como desonrosos pela alta sociedade porque os estudiosos dizem: tomar banho deixa você doente e infeliz e leva a um comportamento pecaminoso!";
		},
