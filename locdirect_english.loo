			Text ="Você parece ser um homem inteligente. Caminhe comigo um pouco e me conte sobre você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.csAnswer.int.toMale.1";
			Text ="Com prazer. Estou ansioso para aprender mais sobre você também.";
