		LocDirectEntry
		{
			Key ="$Cutscenes.ComplimentSpouse.Commitment";
			Text ="Eu... não estou pronto para um compromisso...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.ComplimentSpouse.Family";
			Text ="Você poderia me ajudar a começar uma família? Meus pais estão realmente me irritando com tudo isso...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.ComplimentSpouse.FreeOfDisease";
			Text ="Você parece estar livre de qualquer doença. Isso é bom.";
