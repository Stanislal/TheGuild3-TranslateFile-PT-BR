		},
		LocDirectEntry
		{
			Key ="$society.inquisition.motto";
			Text ="O mal está em toda parte - até mesmo nos bons!";
		},
		LocDirectEntry
		{
			Key ="$society.inquisition.name";
			Text ="Guilda dos Preservadores";
		},
		LocDirectEntry
		{
			Key ="$society.knightsorder.desc";
			Text ="O esplendor e a glória da era dos cavaleiros desapareceram desde o advento dos canhões e dos lansquenets alugados. As outrora tão poderosas e influentes ordens de cavaleiros foram dissolvidas há muito tempo ou dedicaram-se a outras tarefas. Os Cavaleiros Livres, no entanto, não abandonaram os seus ideais e adaptaram-se em grande parte à nova era.";
		},
		LocDirectEntry
		{
			Key ="$society.knightsorder.leader";
