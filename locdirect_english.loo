		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.answer.rich2";
			Text ="Não percebi que os preços estão muito altos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.line.poor1";
			Text ="A competição fica mais forte a cada dia!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.line.poor2";
			Text ="Meus concorrentes parecem não dormir nada.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.line.com1";
			Text ="A competição nunca para. Sinto que meus concorrentes estão sempre respirando no meu pescoço.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.line.com2";
			Text ="Acho que meus concorrentes têm algum pacto com o diabo! Eles são simplesmente muito bem-sucedidos!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.line.rich1";
			Text ="Meus concorrentes estão roubando a camisa das minhas costas...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.answer.poor1";
			Text ="Você está com inveja de seus concorrentes!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.answer.poor2";
			Text ="Não se preocupe, seu dia chegará.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.answer.com1";
			Text ="Negócios de sucesso sempre foram duvidosos em alguns aspectos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.answer.com2";
			Text ="Não fique desapontado, seus negócios estão indo bem.";
