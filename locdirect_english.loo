			Text ="Estou impressionado que você tenha notado isso. Mas para mim você pertence ao resto do cinza. Apenas afaste-se.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.openLine.int.toFemale";
			Text ="Você não acha que combinamos bem?";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fullLine.int.toFemale";
			Text ="Você não acha que combinamos bem?";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.int.toFemale.1";
			Text ="Você tem razão, nos destacamos entre todos os outros. Estar com você é tão revigorante!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.int.toFemale.2";
			Text ="Você está certo, nos destacamos de todos os outros. Estar com você é tão revigorante!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.int.toFemale.1";
			Text ="Não, não combinamos bem. Respeito as regras que se aplicam.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.int.toFemale.2";
			Text ="Não, não combinamos bem. Respeito as regras que se aplicam.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.openLine.char.toFemale";
			Text ="Não seria emocionante ter um segredinho...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fullLine.char.toFemale";
			Text ="Não seria emocionante termos um segredinho juntos...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.char.toFemale.1";
			Text ="Seria emocionante compartilhar um segredo com você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.char.toFemale.2";
			Text ="Adoro segredos, principalmente quando são sobre nós dois!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.char.toFemale.1";
			Text ="Não há nada no mundo que eu gostaria de ter com você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.char.toFemale.2";
			Text ="Posso imaginar o que se passa na sua cabeça quando você pensa em segredos. Eu não sou esse tipo de mulher!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.openLine.per.toFemale";
			Text ="Eu sei que não deveríamos, mas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fullLine.per.toFemale";
			Text ="Eu sei que não deveríamos, mas não consigo me conter. Você é tão incrivelmente linda!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.per.toFemale.1";
			Text ="Por favor, não pare. Deixe esse sentimento estar vivo!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.per.toFemale.2";
			Text ="Você me faz tão feliz! Sim, também não consigo mais me conter!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.per.toFemale.1";
			Text ="Eu sei que estou de tirar o fôlego, mas por favor tente se controlar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.per.toFemale.2";
			Text ="Percebi que você me quer mais do que eu permiti... Por favor, não ultrapasse essa linha!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.openLine.int.toMale";
			Text ="Eu poderia falar com você o dia todo e a noite toda...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fullLine.int.toMale";
			Text ="Eu poderia falar com você dia e noite. E se eu quisesse ver você mais vezes em segredo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.int.toMale.1";
			Text ="Tenho muito mais a dizer para você. Então vamos continuar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.int.toMale.2";
			Text ="Conversar com você se tornou um dos meus desejos secretos. Definitivamente quero falar com você mais vezes!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.int.toMale.1";
			Text ="Conversar dia e noite? Seriamente? Não, obrigado!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.int.toMale.2";
			Text ="Ufa... Acho que ficaríamos sem palavras mais rápido do que você imagina. É melhor não fazermos isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.openLine.char.toMale";
			Text ="Eu estava pensando em nós dois...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fullLine.char.toMale";
			Text ="Eu estava pensando em nós dois. Sabe, eu gosto muito de você e...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.char.toMale.1";
			Text ="Eu também gosto muito de você, minha senhora. Vamos nos encontrar mais vezes em segredo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.char.toMale.2";
			Text ="Eu sinto o mesmo, minha senhora! Vamos dar um passo adiante...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.char.toMale.1";
			Text ="Acho que não devemos ir mais longe...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.char.toMale.2";
			Text ="Gosto de você, mas não tanto assim. Vamos ficar como estamos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.openLine.per.toMale";
			Text ="Notei como você sorri docemente...";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fullLine.per.toMale";
			Text ="Percebi como você sorri docemente quando estamos juntos. Então vamos passar mais tempo juntos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.per.toMale.1";
			Text ="Acho uma ideia maravilhosa!";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.sAnswer.per.toMale.2";
			Text ="Poder passar ainda mais tempo com você em segredo enche meu coração de muita alegria.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.per.toMale.1";
			Text ="Só estou sorrindo porque estou pensando no tempo depois do nosso encontro... então acho que não.";
		},
		LocDirectEntry
		{
			Key ="$d.act.startLia.fAnswer.per.toMale.2";
			Text ="Você já está se agarrando demais a mim. Em hipótese alguma quero ver você com mais frequência!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.cha";
			Text ="Tenho acompanhado sua conquista...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.cha.toMale";
			Text ="É uma honra ter um cidadão tão exemplar como concorrente. Sua família envergonha a todos nós.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.cha.toFemale";
			Text ="É uma honra ter um cidadão tão exemplar como concorrente. Sua família envergonha a todos nós.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.cha";
			Text ="Você me honra com seus elogios. Muito obrigado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.cha";
			Text ="Agradeço gentilmente senhor, tenho certeza que nossas famílias poderão fazer negócios juntas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.cha.toFemale";
			Text ="Agradeço-lhe, gentil senhora, tenho certeza de que nossas famílias poderão fazer negócios juntas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.cha";
			Text ="Claro! Todo mundo sabe que sou melhor que você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.cha.toMale";
			Text ="O que ele quer? Por que ele está falando comigo? No seu caminho, seu canalha.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.cha.toFemale";
			Text ="O que ela quer? Por que ela está falando comigo? No seu caminho, seu canalha.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.prod";
			Text ="Admiro a eficiência dos seus negócios...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.prod";
			Text ="Admiro a eficiência com que você administra seus negócios. Sua família é um verdadeiro farol de excelência.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.prod";
			Text ="Isso é um grande elogio... Obrigado por suas amáveis ​​palavras.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.prod";
			Text ="Muito obrigado. Fazemos o nosso melhor para otimizar nossos negócios usando os mais recentes padrões tecnológicos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.prod";
			Text ="Bem, você pode ser muito eficiente se realmente se dedicar a isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.prod";
			Text ="Eu sei, nossos negócios funcionam como um relógio. O seu, por outro lado...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.openLine.bb";
			Text ="Admiro suas habilidades de negociação...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fullLine.bb";
			Text ="Admiro suas habilidades de negociação... Podemos nos encontrar algum dia e você pode me ensinar um pouco sobre suas habilidades?";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.csAnswer.bb";
			Text ="Eu sempre digo: a honestidade é a melhor política nos negócios... e o talento para sempre tirar mais uma moeda do negócio.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.sAnswer.bb";
			Text ="Obrigado. Sim, vamos nos encontrar um dia e explicarei como fechar um negócio corretamente.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.fAnswer.bb";
			Text ="Obrigado, mas não, obrigado. Acho que não estou interessado em me encontrar com você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicPraise.cfAnswer.bb";
			Text ="Por favor, saia. Ser visto com você é ruim para os negócios.";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.openLine.str";
			Text ="Que Deus tenha misericórdia de você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.fullLine.str";
			Text ="%CharacterTarget%, pelo poder investido em mim pela cidade, declaro você um fora da lei. Num futuro próximo, os guardas da cidade não irão protegê-lo de crimes cometidos contra você. Que Deus tenha misericórdia de você, porque não teremos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.csAnswer.str";
			Text ="O quê? Não! Por favor, eu imploro! Você não pode fazer isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.sAnswer.str";
			Text ="Eu juro... você vai pagar por isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.fAnswer.str";
			Text ="Nem eu nem os guardas da cidade nos importamos com o que você tem a dizer.";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.cfAnswer.str";
			Text ="Não seja ridículo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.openLine.cha";
			Text ="Após inúmeras reclamações de cidadãos...";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.fullLine.cha";
			Text ="Depois de inúmeras reclamações da boa gente desta cidade sobre o seu comportamento miserável, o honorável conselho municipal decidiu que você, %CharacterTarget%, será marcado como fora da lei. Num futuro próximo, os guardas da cidade não intervirão quando virem crimes cometidos contra si ou contra a sua propriedade. Espero que isso lhe ensine uma lição para o futuro.";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.csAnswer.cha";
			Text ="Oh Deus, ah não... por favor, eu tenho tantos inimigos!";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.sAnswer.cha";
			Text ="O quê?! Mas... mas eu não fiz nada!";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.fAnswer.cha";
			Text ="Acredito que você está ultrapassando sua autoridade...";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.cfAnswer.cha";
			Text ="Hahaha, realmente ninguém agirá com base em suas mentiras insanas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.openLine.dex";
			Text ="Tomarei medidas rápidas e decisivas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.fullLine.dex";
			Text ="Algumas coisas não podem esperar pelos mecanismos lentos e inflexíveis do tribunal. Portanto, tomarei medidas rápidas e decisivas e declaro você, %CharacterTarget%, um fora da lei! Num futuro próximo, os guardas da cidade não intervirão em quaisquer crimes cometidos contra você. Esperemos todos que isto seja uma lição para você e que você conserte seus caminhos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.csAnswer.dex";
			Text ="Você não pode esperar pelo tribunal? Eu nem fui acusado de nada? O que devo fazer agora?";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.sAnswer.dex";
			Text ="Por favor, não faça isso! Eu tenho tantos inimigos!";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.fAnswer.dex";
			Text ="Você não é rápido nem decisivo. E os guardas da cidade certamente não obedecerão a esta ordem.";
		},
		LocDirectEntry
		{
			Key ="$d.act.MarkAsOutlaw.cfAnswer.dex";
			Text ="Nem mesmo sua própria família leva você a sério, então por que alguém deveria?";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.openLine.int";
			Text ="Devido aos seus esforços incansáveis...";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fullLine.int";
			Text ="%CharacterTarget%, os vereadores e eu temos observado seus esforços incansáveis pelo bem de nossa cidade. Como pequena manifestação do nosso agradecimento, apresentamos-lhe hoje esta chave ornamental da cidade, para que todos reconheçam o seu árduo trabalho pelo bem comum.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.sAnswer.int";
			Text ="Obrigado. Aceito humildemente este sinal de agradecimento e sou grato por esta honra.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fAnswer.int";
			Text ="Vindo de você, isso não significa nada para mim. Então, obrigado, mas não, obrigado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.openLine.intim";
			Text ="É mais fácil perder favor do que ganhar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fullLine.intim";
			Text ="Hoje queremos lançar uma luz brilhante sobre %CharacterTarget%. Queremos presenteá-lo com esta chave ornamental da cidade pelo seu esforço pessoal e lealdade à Câmara Municipal, para que todos saibam que ele está a favor das autoridades municipais. Mas cuidado: a fortuna é uma amante inconstante e é mais fácil perder o favor do que ganhar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fullLine.intim.toFemale";
			Text ="Hoje queremos lançar uma luz brilhante sobre %CharacterTarget%. Queremos presenteá-la com esta chave ornamental da cidade pelo seu esforço pessoal e lealdade à Câmara Municipal, para que todos saibam que ela está a favor das autoridades municipais. Mas cuidado: a fortuna é uma amante inconstante e é mais fácil perder o favor do que ganhar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.sAnswer.intim";
			Text ="eu entendo. Obrigado meu Senhor.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.sAnswer.intim.toFemale";
			Text ="eu entendo. Obrigado minha senhora.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fAnswer.intim";
			Text ="Você não pode me pressionar com presentes vãos e ameaças vazias.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.openLine.rb";
			Text ="Amigos verdadeiros são difíceis de encontrar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fullLine.rb";
			Text ="Amigos de verdade são difíceis de encontrar hoje em dia. É por isso que os anciãos da cidade querem que todos saibam que %CharacterTarget% é um verdadeiro amigo desta cidade. Estamos, portanto, concedendo-lhe esta chave ornamental da cidade para simbolizar isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fullLine.rb.toFemale";
			Text ="Amigos de verdade são difíceis de encontrar hoje em dia. É por isso que os anciãos da cidade querem que todos saibam que %CharacterTarget% é um verdadeiro amigo desta cidade. Estamos, portanto, concedendo-lhe esta chave ornamental da cidade para simbolizar isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.sAnswer.rb";
			Text ="Obrigado. Sinto-me profundamente honrado por ser seu amigo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.fAnswer.rb";
			Text ="Acho que não quero ser seu amigo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.cha1";
			Text ="Meu Deus, você é feio...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.cha1";
			Text ="Meu Deus! Você tem a caneca mais feia que já vi em toda a minha vida! Quão feio você pode perguntar? Eu até vi leprosos se virarem enojados! Você é tão feio que sua família te obriga a comer no cocho dos porcos porque não te suportam na mesa com você no jantar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.cha2";
			Text ="Você deveria usar uma máscara de peste...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.cha2";
			Text ="Você realmente deveria estar usando uma daquelas máscaras de peste. Isso poupará às pessoas a dor de ver seu rosto horrível.";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.cha3";
			Text ="Ouvi rumores sobre sua aparência...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.cha3";
			Text ="Ouvi rumores de que você e sua roupa eram tão feios que muitos o confundiram com um porco que acabou de se afundar na sujeira. No começo pensei 'coitado'. Mas agora que te vi de perto, estou pensando 'pobres porcos'!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.cha3.toFemale";
			Text ="Ouvi rumores de que você e sua roupa eram tão feios que muitos o confundiram com um porco que acabou de se afundar na sujeira. No começo pensei 'coitada'. Mas agora que te vi de perto, estou pensando 'pobres porcos'!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.sAnswer.cha";
			Text ="Veremos quem é feio depois que eu terminar com você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fAnswer.cha";
			Text ="Eu? Feio? Ha! Olha quem está falando!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.str1";
			Text ="Força de vontade de uma mosca...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.str1";
			Text ="Quem ouviria o que um fraco como você tem a dizer? Uma mosca doméstica tem força de vontade mais forte que você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.str2";
			Text ="Minha avó poderia vencer você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.str2";
			Text ="Olhe para você! Minha querida e velha avó poderia vencer você na queda de braço. Ela nem suava a camisa!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.str3";
			Text ="Nem braços fortes nem vontade forte...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.str3";
			Text ="Você não tem braços fortes nem vontade forte. Fiquei me perguntando como você sobreviveu até agora...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.sAnswer.str";
			Text ="Vou te mostrar força!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fAnswer.str";
			Text ="Não se preocupe com meus pontos fortes, pois em breve você os conhecerá!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.dex1";
			Text ="Você é tão lento...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.dex1";
			Text ="Deus, você é tão lento! Você ficaria em último lugar em todas as corridas de caracóis! E não só porque você é lento, mas também porque precisaria parar e pedir informações! Caso você ainda não tenha percebido: estou te chamando de lento e estúpido!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.dex2";
			Text ="Você está ficando atrás de seus concorrentes...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.dex2";
			Text ="Diga-me, todos na sua família são tão lentos quanto você? Não admira que você esteja sempre atrás de seus concorrentes!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.openLine.dex3";
			Text ="Muito lento para entender...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fullLine.dex3";
			Text ="Você sabe, eu poderia inventar um insulto elaborado e espirituoso para envergonhar você. Mas por que se preocupar? Você é muito lento e estúpido para entender isso de qualquer maneira.";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.sAnswer.dex";
			Text ="Você pode pensar que sou lento, mas eu garanto: você não verá meu punho chegando!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fAnswer.dex";
			Text ="A lentidão deve ser vista em relação à tarefa e/ou objetivo. Você não entende? Desculpe, eu não queria sobrecarregar você... ah, é melhor você parar de hiperventilar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.sAnswer.all1";
			Text ="Venha aqui, você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.sAnswer.all2";
			Text ="Você retirará isso em breve!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.sAnswer.all3";
			Text ="Engraçado! Vamos ver o quão engraçado você fica depois que eu limpar o chão com você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.sAnswer.all4";
			Text ="Ah... quando isso acabar você vai desejar nunca ter nascido!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fAnswer.all1";
			Text ="Eu sei o que você está tentando fazer, mas não vai funcionar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fAnswer.all2";
			Text ="Ah! Isso é um pouco grosso vindo de alguém como você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fAnswer.all3";
			Text ="Hahaha! Essa foi boa! Agora vá embora e continue vivendo sua vida miserável!";
		},
		LocDirectEntry
		{
			Key ="$d.act.DuelInsult.fAnswer.all4";
			Text ="Você não vale o esforço...";
		},
		LocDirectEntry
		{
			Key ="$d.act.Denounce.fullLine1";
			Text ="Ouvi dizer que %CharacterContext% paga com moedas falsas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.Denounce.fullLine2";
			Text ="%CharacterContext% adormeceu na igreja uma vez! Que blasfêmia!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Denounce.fullLine3";
			Text ="%CharacterContext% não acredita no poder curativo da torrada com queijo!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Denounce.fullLine4";
