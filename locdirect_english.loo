			Text ="Salvando a rota comercial";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail12";
			Text ="Se você estiver satisfeito com sua rota comercial, clique em Salvar. Se você ativou o aviso mostrar rota salva no menu de opções e a quantidade de itens carregados e descarregados não corresponde ou há problemas com os pontos de referência da rota, você receberá um aviso de salvar rota. Você pode então alterar as configurações da rota comercial ou ignorar o aviso e salvar a rota de qualquer maneira.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail4a";
			Text ="A ordem dos waypoints existentes pode ser alterada usando os botões de seta à esquerda.";
