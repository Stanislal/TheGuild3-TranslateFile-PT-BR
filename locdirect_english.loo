		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.openLine.char";
			Text ="Meu coração chama seu nome todas as noites...";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.fullLine.char";
			Text ="Meu coração chama seu nome todas as noites. Permita-me sussurrar em seu ouvido o que meu coração deseja lhe dizer.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.csAnswer.char";
			Text ="Ah! Isso é tão romântico! Por favor, sou todo ouvidos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.sAnswer.char";
			Text ="Fascinante. Por favor, continue - você já chamou minha atenção.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.fAnswer.char";
			Text ="Você tem certeza de que é o seu coração e não algum espírito profano na sua cabeça? É melhor você me deixar em paz.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.cfAnswer.char";
			Text ="Você perdeu completamente os sentidos agora? Infelizmente para você, não falo com o coração de estranhos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.openLine.per";
			Text ="Eu vejo seu rosto em meus sonhos...";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.fullLine.per";
			Text ="Eu vejo seu rosto em meus sonhos todas as noites. Você me permitiria olhar para você à luz do dia?";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.csAnswer.per";
			Text ="Sonhos deveriam se tornar realidade, não acha?";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.sAnswer.per";
			Text ="Isso parece romântico. Sim, vou permitir que você olhe para mim e você pode até falar comigo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.fAnswer.per";
			Text ="Eu deveria pedir seu perdão, mas não tenho tempo para isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v4.cfAnswer.per";
			Text ="Não acredito em sonhos, eles não são reais. Por favor, não perca meu tempo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.openLine.int";
			Text ="Eu adoraria ter uma conversa significativa com você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.fullLine.int";
			Text ="Encontrar alguém capaz de ter uma conversa inteligente é difícil. Então, por favor, salve-me e fale comigo!";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.csAnswer.int.female";
			Text ="Como poderia recusar seu pedido, senhor! Claro que falarei com você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.csAnswer.int.male";
			Text ="Como poderia recusar seu pedido, minha senhora! Claro que falarei com você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.sAnswer.int";
			Text ="Eu daria tudo por uma conversa inteligente. Sobre o que vamos conversar?";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.fAnswer.int";
			Text ="Estou lisonjeado, mas dificilmente consigo imaginar ter uma conversa inteligente com alguém como você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.cfAnswer.int";
			Text ="Perdoe-me, mas não estou convencido de que valha a pena salvar sua mente.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.openLine.char.toFemale";
			Text ="Você é uma mulher tão fascinante...";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.openLine.char.toMale";
			Text ="Você é um homem tão fascinante...";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.fullLine.char";
			Text ="Diga-me, quais são os poderes que tornam impossível eu desviar o olhar de você? Você é fascinante!";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.csAnswer.char";
			Text ="Não vou revelar meus segredos tão cedo. Devíamos passar algum tempo juntos primeiro.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.sAnswer.char";
			Text ="Que coincidência, você parece uma pessoa interessante. Eu gostaria de me encontrar com você mais tarde.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.fAnswer.char.female";
			Text ="Poderes secretos?! Você está me acusando de bruxaria?! Isso não é engraçado!";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.fAnswer.char.male";
			Text ="Poderes secretos?! Você está me acusando de fazer um pacto com espíritos profanos?";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.v5.cfAnswer.char.female";
