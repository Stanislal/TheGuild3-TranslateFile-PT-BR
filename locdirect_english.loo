		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.sAnswer.v3.int";
			Text ="Espero que isso seja uma inspiração para meus oponentes. Permita-me expressar minha gratidão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fAnswer.v3.int";
			Text ="Você realmente quer que eu acredite que VOCÊ, dentre todas as pessoas, quer me presentear com um elogio?";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.openLine.v3.intim";
			Text ="Sua atitude moral merece um elogio.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v3.intim";
			Text ="Em reconhecimento à sua moralidade exemplar e fé inabalável, entrego-lhe esta chave ornamental da cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.sAnswer.v3.intim";
			Text ="Tem certeza de que deveria me presentear com um prêmio? Quer dizer, é claro que aceitarei esse prêmio. Obrigado!";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fAnswer.v3.intim";
			Text ="Não há necessidade de me recompensar. Tudo o que eu faço, faço porque é a coisa certa a fazer.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.openLine.v3.rb";
			Text ="Nossa sociedade é grata a você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v3.rb";
			Text ="Com esta chave, os cidadãos do nosso feudo desejam expressar a sua gratidão pela sua contribuição para a nossa sociedade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.sAnswer.v3.rb";
