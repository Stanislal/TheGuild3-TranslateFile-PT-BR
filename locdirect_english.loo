			Text ="É uma pena que lutar esteja abaixo da minha dignidade.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.fight.rich3";
			Text ="Sim, bata mais forte... ehm, quero dizer... isso é nojento!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.fight.rich4";
			Text ="Guardas! Onde estão os guardas!";
