			Text ="Um casamento está acontecendo";
		},
		LocDirectEntry
		{
			Key ="$notification.ChurchWedding.body";
			Text ="%groom% e %bride% se casam. Apresse-se se quiser comparecer à cerimônia.";
		},
		LocDirectEntry
		{
			Key ="$d.scene.wedding.Priest.Intro";
			Text ="Estamos reunidos hoje para unir %groom% e %bride% nos laços do sagrado matrimônio.";
		},
		LocDirectEntry
		{
			Key ="$d.scene.wedding.Priest.Intro.Narration";
			Text ="Estamos reunidos hoje para unir essas duas pessoas nos laços do sagrado matrimônio.";
		},
		LocDirectEntry
		{
			Key ="$d.scene.wedding.Priest.toHusband";
			Text ="E você, %groom%, deseja levar %bride% para ser sua legítima esposa, para amar e honrar, até que a morte os separe? Se sim, responda com: sim.";
		},
		LocDirectEntry
		{
			Key ="$d.scene.wedding.Priest.toHusband.Narration";
			Text ="E você, deseja levar esta mulher para ser sua legítima esposa, para amar e honrar, até que a morte os separe? Se sim, responda com: sim.";
		},
		LocDirectEntry
		{
			Key ="$d.scene.wedding.Priest.toWife";
