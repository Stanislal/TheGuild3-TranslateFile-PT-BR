			Key ="$gui.Options.VideoVolume";
			Text ="Volume do vídeo";
		},
		LocDirectEntry
		{
			Key ="$gui.politics.LegalityCannotChange";
			Text ="A legalidade desta ação não pode ser alterada";
		},
		LocDirectEntry
		{
			Key ="$gui.politics.OnlySovereignCanChangeLegality";
			Text ="Somente o soberano pode alterar a legalidade desta ação";
		},
		LocDirectEntry
		{
			Key ="$notice.quests.newEntry";
			Text ="Nova missão disponível";
		},
		LocDirectEntry
		{
			Key ="$gui.multiplayer.disconnecting";
			Text ="Desconectando...";
		},
		LocDirectEntry
		{
			Key ="$ui.Politics.FamilyNameAndSize";
			Text ="%name% (adultos: %adults%, crianças: %children%)";
		},
		LocDirectEntry
		{
			Key ="$statusEffect.heart";
			Text ="Este personagem tem uma preferência romântica.";
		},
		LocDirectEntry
		{
			Key ="$status.RomPrefCloseApproach";
			Text ="Gostaria de uma abordagem um pouco mais íntima.";
		},
		LocDirectEntry
		{
			Key ="$status.RomPrefMoreDistance";
			Text ="Gostaria de uma abordagem mais distante.";
		},
		LocDirectEntry
		{
			Key ="$status.RomPrefPresent";
			Text ="Gostaria de um belo presente.";
		},
		LocDirectEntry
		{
			Key ="$status.RomPrefArtist";
			Text ="Gostaria de uma apresentação romântica.";
		},
		LocDirectEntry
		{
			Key ="$status.RomPrefContraryGoodBehavior";
			Text ="Gostaria de uma abordagem cautelosa e contrária ao bom comportamento.";
		},
		LocDirectEntry
		{
			Key ="$NPC.Thinking";
			Text ="Pensando";
		},
		LocDirectEntry
		{
			Key ="$NPC.ThinkingDesc";
			Text ="O personagem está pensando no que fazer a seguir...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.line.poor1";
			Text ="Gostaria de saber ler e escrever...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.line.poor2";
			Text ="Gostaria de saber o que os estudiosos escrevem no pergaminho. Deve-se saber ler.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.line.com1";
			Text ="Leio um livro há anos. Já estou na página 11... Se ao menos eu tivesse aprendido a ler melhor.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.line.com2";
			Text ="Se eu soubesse ler e escrever, manteria um diário. A posteridade saberia então de todas as minhas aventuras.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.line.rich1";
			Text ="Acho que deveria começar a aprender a ler e escrever em latim.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.line.rich2";
			Text ="As pessoas comuns não têm faculdades mentais para aprender a ler e escrever. Você também não acha?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.answer.poor1";
			Text ="Pense nisso. Ler e escrever ajuda você no seu trabalho?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.answer.poor2";
			Text ="Não consigo imaginar que alguém possa ler algo útil em rabiscos.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.answer.com1";
			Text ="Também seria interessante saber o que há em todos esses livros.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.answer.com2";
			Text ="Para que serve ler, hein? Nunca ouvi falar de alguém escrevendo instruções de trabalho.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.answer.rich1";
			Text ="Ler e escrever só deveriam ser permitidos à classe alta, por lei.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.literacy.answer.rich2";
			Text ="Para aprender a ler e escrever é preciso entrar num mosteiro. Ou você paga muito dinheiro por um professor...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.line.poor1";
			Text ="Tenho picadas de vermes por todo o corpo... é tããão desconfortável...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.line.poor2";
			Text ="Fui recentemente mordido por um rato. Provavelmente pensou que eu era bacon ou queijo...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.line.com1";
			Text ="Hoje encontrei um rato morto no meu estoque de grãos. Provavelmente comeu até a morte, enquanto eu tenho que morrer de fome...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.line.com2";
			Text ="Esses vermes! Estou com muita coceira. Talvez eu devesse sacudir minhas roupas...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.line.rich1";
			Text ="Você deve aplicar este pó para a pele. Cobre maravilhosamente pústulas e picadas de vermes.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.line.rich2";
			Text ="Derramo água de rosas nos lençóis todas as noites antes de dormir. É suposto proteger contra vermes.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.answer.poor1";
			Text ="Você deveria trocar seu saco de palha. É onde vivem as criaturas. Melhor queimá-lo imediatamente.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.answer.poor2";
			Text ="Isso é uma pulga no seu braço... Ah não, agora é por minha conta! Fique longe de mim!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.answer.com1";
			Text ="Diz-se que o olíbano ajuda contra vermes. Você já tentou isso antes?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.answer.com2";
			Text ="Eu tinha ratos em casa, mas o vizinho os assustou. E então ele invadiu minha cozinha...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.answer.rich1";
			Text ="Bem, prefiro ir ao barbeiro e me esfregar na banheira.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.hygiene.answer.rich2";
			Text ="Deve-se manter distância dos plebeus. É daí que vêm os vermes.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.line.poor1";
			Text ="Está muito frio... e não temos dinheiro para comprar lenha...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.line.poor2";
			Text ="Fiquei sem lenha... você também está com frio?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.line.com1";
			Text ="Está frio e não tenho lenha. Espero não pegar um resfriado.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.line.com2";
			Text ="Esses comerciantes ricos não vão congelar com seus casacos de pele caros... Ah, está tão frio...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.line.rich1";
			Text ="Meus servos não conseguiram lenha suficiente. Agora eles não conseguem aquecer suficientemente minha sala de jantar.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.line.rich2";
			Text ="Minha empregada deixou a pedra térmica quente demais para dormir. Foi muito desconfortável!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.answer.poor1";
			Text ="Sim, você está certo...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.answer.poor2";
			Text ="Isso... uh... parece terrível...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.answer.com1";
			Text ="Eu simpatizo.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.answer.com2";
			Text ="Vamos lá, você está exagerando.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.answer.rich1";
			Text ="Isso é inacreditável! Você deveria fazer algo a respeito!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.firewood.answer.rich2";
			Text ="Vergonhoso! Eu não aceitaria tal coisa e faria algo a respeito!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.line.poor1";
			Text ="Acho que alguém está escondido aí atrás...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.line.poor2";
			Text ="Você também ouviu isso? Havia algo nas sombras ali?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.line.com1";
			Text ="Ali! Você viu isso? Aqueles bandidos ali trocaram sinais secretos com as mãos novamente!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.line.com2";
			Text ="Tenho certeza que alguém me seguiu.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.line.rich1";
			Text ="Eu ouvi alguém puxar uma adaga da bainha atrás de mim. Mas quando me virei não havia ninguém lá...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.line.rich2";
			Text ="Não deveríamos estar andando por aí a esta hora. Os ladrões podem estar à espreita em qualquer lugar...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.answer.poor1";
			Text ="Não tenho nada para roubar. Eu não tenho medo.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.answer.poor2";
			Text ="Sim, há muitos bandidos no exterior novamente...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.answer.com1";
			Text ="Ah, você está simplesmente vendo fantasmas de novo...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.answer.com2";
			Text ="Tem certeza? Então é melhor escondermos nossas bolsas... Onde ESTÁ minha bolsa?!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.answer.rich1";
			Text ="Se alguém estiver lá, certamente não se atreverá a se envolver com minha família.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.shadows.answer.rich2";
			Text ="Fique aqui e distraia-os – quero dizer – fique de olho. Vou em frente e informarei a guarda da cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.line.poor1";
			Text ="Você também ouviu isso?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.line.poor2";
			Text ="Tenho um mau pressentimento. Você também sente isso?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.line.com1";
			Text ="Meu nariz está coçando... Algo ruim vai acontecer...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.line.com2";
			Text ="Ouça-me: demônios espreitam nas sombras! Eles desejam as almas dos justos!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.line.rich1";
			Text ="Essa conversa sobre demônios assusta apenas os mentalmente fracos. Mas... quero dizer... você acredita em demônios?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.line.rich2";
			Text ="Me sinto um pouco desconfortável aqui. As pessoas aqui são tão pecadoras que o próprio diabo não pode estar longe...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.answer.poor1";
			Text ="Ah, não tem nada aí.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.answer.poor2";
			Text ="Hum... sim! Deveríamos... hum... onde está minha cruz protetora?!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.answer.com1";
			Text ="Não tenha medo. Eu protegerei você!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.answer.com2";
			Text ="Ah, não! Eles estão vindo nos pegar...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.answer.rich1";
			Text ="Não, acho que não. Estamos seguros aqui. Deus está conosco... ou pelo menos comigo.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.ghosts.answer.rich2";
			Text ="Estou com minha adaga comigo. Mandei abençoar ontem...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.poor1.IsMale";
			Text ="O Soberano %CharacterContext% faleceu.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.poor1.IsFemale";
			Text ="O Soberano %CharacterContext% faleceu.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.poor2.IsMale";
			Text ="Soberano %CharacterContext% não existe mais...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.poor2.IsFemale";
			Text ="Soberano %CharacterContext% não existe mais...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.com1.IsMale";
			Text ="Nosso Soberano %CharacterContext% partiu desta vida...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.com1.IsFemale";
			Text ="Nosso Soberano %CharacterContext% partiu desta vida...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.com2.IsMale";
			Text ="Soberano %CharacterContext% deixou seu castelo com os pés primeiro...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.com2.IsFemale";
			Text ="Sovereign %CharacterContext% deixou seu castelo com os pés primeiro...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.rich1.IsMale";
			Text ="A morte arrancou o Soberano %CharacterContext% de nosso meio...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.rich1.IsFemale";
			Text ="A morte arrancou o Soberano %CharacterContext% de nosso meio...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.rich2.IsMale";
			Text ="Deus convocou nosso Soberano %CharacterContext% para o céu.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.line.rich2.IsFemale";
			Text ="Deus convocou nosso Soberano %CharacterContext% para o céu.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.poor1.IsMale";
			Text ="Já era hora de %CharacterContext% deixar o trono!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.poor1.IsFemale";
			Text ="Já era hora de %CharacterContext% deixar o trono!";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.poor2";
			Text ="Sim. Mas eu não me importo.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.poor3";
			Text ="Então as coisas só podem melhorar agora...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.com1";
			Text ="E recentemente sentou-se no alto de um nobre corcel, vestido com roupas entrelaçadas com ouro. E agora tão morto quanto um mendigo comum...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.com2";
			Text ="Que nosso Monarca escolha o sucessor com sabedoria.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.com3.IsMale";
			Text ="%CharacterContext% foi um bom soberano. Sentiremos falta de sua regra...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.com3.IsFemale";
			Text ="%CharacterContext% foi um bom soberano. Sentiremos falta da regra dela...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.rich1";
			Text ="Quem assumirá o governo como Soberano?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.rich2";
			Text ="Quem nosso estimado Monarca nomeará como o novo Soberano?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.SovereignDead.answer.rich3";
			Text ="Eu estaria disposto a assumir este feudo. Talvez eu me candidate...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.poor1.IsMale";
			Text ="A dinastia %FamilyContext% perdeu seu chefe de família %CharacterContext%.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.poor1.IsFemale";
			Text ="A dinastia %FamilyContext% perdeu seu chefe de família %CharacterContext%.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.poor2.IsMale";
			Text ="%CharacterContext% foi ao encontro de seu criador. A dinastia %FamilyContext% terá um novo chefe de família.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.poor2.IsFemale";
			Text ="%CharacterContext% foi conhecer seu criador. A dinastia %FamilyContext% terá um novo chefe de família.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.com1.IsMale";
			Text ="O chefe da família %FamilyContext% faleceu. %CharacterContext% será difícil de substituir...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.com1.IsFemale";
			Text ="O chefe da família %FamilyContext% faleceu. %CharacterContext% será difícil de substituir...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.com2.IsMale";
			Text ="Você já ouviu falar que o chefe da dinastia %FamilyContext%, %CharacterContext%, morreu?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.com2.IsFemale";
			Text ="Você já ouviu falar que o chefe da dinastia %FamilyContext%, %CharacterContext%, morreu?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.rich1.IsMale";
			Text ="Você já ouviu falar que a dinastia %FamilyContext% perdeu seu líder popular %CharacterContext%?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.rich1.IsFemale";
			Text ="Você já ouviu falar que a dinastia %FamilyContext% perdeu seu líder popular %CharacterContext%?";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.rich2.IsMale";
			Text ="Há notícias tristes. O bom %CharacterContext%, chefe da dinastia %FamilyContext%, faleceu...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.line.rich2.IsFemale";
			Text ="Há notícias tristes. O bom %CharacterContext%, chefe da dinastia %FamilyContext%, faleceu...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.answer.poor1";
			Text ="Sim, eu tinha ouvido falar. Muito triste...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.answer.poor2.IsMale";
			Text ="%CharacterContext% era um bom homem. É uma pena...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.answer.poor2.IsFemale";
			Text ="%CharacterContext% era uma boa mulher. É uma pena...";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.answer.poor3.IsMale";
			Text ="Que ele descanse em paz.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.answer.poor3.IsFemale";
			Text ="Que ela descanse em paz.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.answer.com1";
			Text ="A família %FamilyContext% fez muito bem para nós. Eu luto com eles.";
		},
		LocDirectEntry
		{
			Key ="$d.npcChat.LeaderDead.good.answer.com2";
			Text ="Quem da família %FamilyContext% assumirá o negócio?";
		},
		LocDirectEntry
		{
