		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.answer.poor1";
			Text ="Os comerciantes gananciosos superfaturam os produtos que precisamos urgentemente...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.answer.poor2";
			Text ="Quando você é pobre, qualquer preço pode ser muito alto.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.answer.com1";
			Text ="Todos os comerciantes estão superfaturando seus produtos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.answer.com2";
			Text ="Alguns comerciantes são tão gananciosos que oferecem os seus produtos por preços exorbitantes.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.highPrices.answer.rich1";
			Text ="Os comerciantes querem ganhar mais, por isso seus preços são tão altos.";
