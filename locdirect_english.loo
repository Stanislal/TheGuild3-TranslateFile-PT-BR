		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceSong.answer.rich1";
			Text ="Poesia não é para mim, poderíamos conversar sobre outra coisa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceSong.answer.rich2";
			Text ="Com todo o respeito, mas o que você pode saber sobre música e poesia?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.line.poor1";
			Text ="Ei! Você já ouviu essa piada sobre...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.line.poor2";
			Text ="Eu tenho uma piada muito engraçada! Ouça...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.line.poor3";
			Text ="Você gosta de piadas? Esta é uma boa. Então...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.line.com1";
			Text ="Basta ouvir esta história humorística...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.line.com2";
			Text ="Ouça essa piada! Um dos nossos concidadãos, um homem muito espirituoso, era...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.line.com3";
			Text ="Você vai adorar essa brincadeira! Duas vacas estão no prado, quando...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.line.rich1";
			Text ="Acabei de ouvir uma piada divertida. Deixe-me contar para você...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.answer.poor1";
			Text ="Eu conheço um melhor, apenas ouça isso...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.answer.poor2";
			Text ="Uma piada é a última coisa que preciso agora.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.answer.com1";
			Text ="Pare com essa bobagem...";
