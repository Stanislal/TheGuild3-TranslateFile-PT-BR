		LocDirectEntry
		{
			Key ="$PoemDesc";
			Text ="O poema escrito neste pergaminho não poderia ser mais adequado para você recitar. Dedique esta obra-prima poética a um de seus romances ou ligações e você descobrirá que a resistência inicial logo dá lugar à alegria por ser o tema de seu poema.";
