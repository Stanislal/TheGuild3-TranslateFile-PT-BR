		LocDirectEntry
		{
			Key ="$d.act.awardKey.openLine.v3.int";
			Text ="Em reconhecimento às suas conquistas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v3.int";
