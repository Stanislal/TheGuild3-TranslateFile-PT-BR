		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v3.char_intim";
			Text ="Precisamos de separação e equilíbrio...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v3.char_intim";
			Text ="O sagrado e o profano, assim como o homem e a mulher, deveriam estar separados, mas coexistirem num equilíbrio natural entre si.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v3.char_intim";
			Text ="É isso!! Separados, mas juntos, como homem e mulher.";
