		LocDirectEntry
		{
			Key ="$CommonerClothes4Desc";
			Text ="Estas peças de vestuário são pobres, mas robustas e práticas.";
		},
		LocDirectEntry
		{
			Key ="$Cookie";
			Text ="Ataque duro";
		},
		LocDirectEntry
		{
			Key ="$CookieDesc";
			Text ="Feito de pura cevada e bala, o hardtack é uma refeição para o cidadão simples. Hardtack fica mais gostoso quando untado com mel ou compota de frutas - infelizmente, porém, apenas poucos podem pagar por isso...";
		},
		LocDirectEntry
		{
			Key ="$CreamPie";
			Text ="Bolo de creme";
		},
		LocDirectEntry
		{
			Key ="$CreamPieDesc";
			Text ="Um bolo de creme é o auge da arte do padeiro! As camadas maravilhosamente doces e habilmente construídas são uma delícia para os gourmets e serão depositadas como reservas de gordura para o inverno que se aproxima!\nSabore você mesmo com gritos de alegria ou faça outra pessoa muito feliz e presenteie-a com um bolo de creme.";
		},
		LocDirectEntry
		{
			Key ="$Crossbow";
			Text ="Besta";
		},
		LocDirectEntry
		{
			Key ="$CrossbowDesc";
			Text ="Um golpe de besta pode penetrar até mesmo em armaduras pesadas. Por outro lado, a besta é pesada, difícil de manejar e demora um pouco até que você possa dispará-la novamente. Por esta razão, você só pode disparar a besta no início da batalha e então precisará recorrer ao combate corpo a corpo!";
		},
		LocDirectEntry
		{
			Key ="$CrowdManagement";
			Text ="Hospitalidade";
		},
		LocDirectEntry
		{
			Key ="$CrowdManagementDesc";
			Text ="A habilidade de hospitalidade permite que você possua e administre tavernas.";
		},
		LocDirectEntry
		{
			Key ="$Culinary";
			Text ="Comércio de Miller";
		},
		LocDirectEntry
		{
			Key ="$CulinaryDesc";
			Text ="Como moleiro, você poderá possuir e operar um moinho de vento. Com a ajuda poderosa do vento, você será capaz de transformar seus grãos em farinha, que será necessária mais tarde se você planeja se tornar um padeiro.";
		},
		LocDirectEntry
		{
			Key ="$Cupboard";
			Text ="Armário";
		},
		LocDirectEntry
		{
			Key ="$CupboardDesc";
			Text ="Os armários são baús verticais onde se pode guardar confortavelmente roupas ou artigos de uso diário. Cada um deveria ter seu próprio armário...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.BuyOrphan.Children";
			Text ="Bem-vindo à casa de Deus, meu filho. Tenho certeza de que você gostaria de fazer boas obras e cuidar de um pobre órfão? E tenho a mesma certeza de que pretende dar um obelus à Santa Madre Igreja...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.BuyPardon.BuyPardon";
			Text ="Você gostaria de saber como libertar sua alma do fardo de todos os seus pecados?";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.ComplimentSpouse.AllTheGirls";
			Text ="Tenho certeza que você diz isso para todas as garotas...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.ComplimentSpouse.BecomeAPriest";
			Text ="Acho que seria melhor entrar para uma ordem religiosa...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.ComplimentSpouse.CleaningMyHouse";
			Text ="Então, o que eu poderia oferecer em troca de limpar minha casa?";
