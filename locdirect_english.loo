		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.character.returns.body.female";
			Text ="%character% volta para casa depois da grande construção.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.title";
			Text ="Anúncio da Guilda dos Alquimistas!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.title.1";
			Text ="Guilda dos Alquimistas - expedição à floresta primitiva";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.body.1";
			Text ="A Guilda dos Alquimistas organiza uma expedição a uma das últimas florestas primitivas do Ocidente. Porque lá, de acordo com um membro de alto escalão da guilda, a lendária fonte da juventude pode ser encontrada. Se quiser viajar com eles, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.title.2";
			Text ="Guilda dos Alquimistas - transformação de chumbo em ouro";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.body.2";
			Text ="Um alquimista famoso, mas controverso, quer apresentar suas últimas descobertas sobre o processo de transformação de chumbo em ouro em uma cidade próxima. A Guilda dos Alquimistas certamente enviará uma delegação. Se quiser viajar com eles, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.title.3";
			Text ="Guild of Alchemists - praga em uma cidade próxima";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.body.3";
			Text ="Oh senhor, uma terrível praga está assolando uma cidade próxima! Em desespero, a Câmara Municipal oferece uma grande recompensa para quem conseguir deter a praga. A Guilda dos Alquimistas já está montando um grupo de pesquisa. Se quiser viajar com eles, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.title.4";
			Text ="Guilda dos Alquimistas - doença desconhecida";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.body.4";
			Text ="Um grupo de viajantes de terras distantes, que montou acampamento nas proximidades, é acometido de uma doença desconhecida. A Guilda dos Alquimistas está reunindo um grupo de pessoas experientes para viajar para lá o mais rápido possível e investigar o assunto. Se quiser viajar com eles, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Alchimists.Player.option.short";
			Text ="Chamado da Guilda dos Alquimistas";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Alchimists.Player.option";
			Text ="A Guilda dos Alquimistas está se preparando para uma viagem?";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Alchimists.NPC.answer.positive";
			Text ="Você quer viajar com eles? Não posso dizer que viajar com eles será isento de riscos, mas com certeza será interessante para você - especialmente quando você for membro da Guilda dos Alquimistas!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Alchimists.NPC.answer";
			Text ="Sim, a Guilda dos Alquimistas está se preparando para uma viagem.";
		},
		LocDirectEntry
