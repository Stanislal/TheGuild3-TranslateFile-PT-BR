		LocDirectEntry
		{
			Key ="$action.WarEvent.Officer";
			Text ="Na guerra como oficial";
		},
		LocDirectEntry
		{
			Key ="$action.WarEvent.OfficerDesc";
			Text ="está liderando as tropas da cidade em uma campanha de guerra.";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.war.Player.option.cancel";
			Text ="Não, isso é muito arriscado para mim...";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.won.title";
			Text ="A guerra está vencida!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.won.body";
			Text ="Recebemos boas notícias do campo de batalha! Nossa cidade aliada venceu a batalha com a ajuda de nossas gloriosas tropas e cada soldado e oficial sobrevivente receberá sua parte nos despojos!\nNo entanto, os participantes precisam de mais algum tempo para chegar às suas casas.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.defeat.title";
			Text ="A guerra está perdida!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.defeat.body";
			Text ="Este é um dia ruim para todos nós! As tropas que enviamos para apoiar a guerra da nossa cidade aliada não foram capazes de mudar a maré da guerra. Para aqueles que sobreviveram, o resgate da batalha deverá ser pago...\nNo entanto, os participantes precisarão de mais algum tempo para chegar às suas casas.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.truce.title";
			Text ="A guerra termina com uma trégua!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.truce.body";
			Text ="Um mensageiro da nossa cidade aliada trouxe a notícia de que uma trégua foi alcançada entre as partes em conflito. Mas ainda assim, alguns dos nossos bravos soldados não voltarão para casa, para as suas famílias...\nNo entanto, os participantes precisam de mais algum tempo para chegar às suas casas.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.character.survived.title";
