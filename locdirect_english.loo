		},
		LocDirectEntry
		{
			Key ="$FreemasonsGift";
			Text ="Proteger um edifício";
		},
		LocDirectEntry
		{
			Key ="$FreemasonsGiftDesc";
			Text ="Os maçons são provavelmente os melhores mestres construtores do nosso tempo. Como membro da Maçonaria, você tem acesso aos escritos secretos e aprende a fazer corretamente os cálculos mais complicados. Isso permite que você proteja um de seus edifícios de forma que ninguém possa danificá-lo novamente.\nPor um tempo, o edifício fica protegido contra sabotagem, arrombamentos, tentativas de conquistá-lo e até mesmo contra tentativas de extorsão de dinheiro e pulgas. Mas as bombas ainda terão os seus efeitos destrutivos!";
		},
		LocDirectEntry
		{
			Key ="$statusEffect.FreemasonsGift";
			Text ="Garantido por um antigo mestre construtor";
		},
		LocDirectEntry
		{
			Key ="$feedback.EffectAppliedFreemasonsGift";
			Text ="Extra seguro";
		},
		LocDirectEntry
		{
