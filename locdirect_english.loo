		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.allguilds.character.returns.title";
			Text ="%character% volta para casa!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.title";
			Text ="Uma guerra é iminente!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.title.1";
			Text ="Uma cidade aliada está sitiada!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.body.1";
			Text ="Ouça, ouça! Notícias de uma guerra iminente chegaram até nós de uma cidade aliada! A cidade corre o risco de ser sitiada pelas tropas de um Nobre ganancioso. Como seus aliados, ficaremos ao lado deles!\nEste chamado vai para os cidadãos justos de nossa cidade e também para todos os lansquenets! E aos nossos nobres honrados e à prova de combate!\nBravos homens e mulheres, peguem suas armas e apresentem-se ao Mestre do Arsenal o mais rápido possível! Reuniremos nossas tropas lá até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.title.2";
			Text ="Uma cidade aliada está reunindo tropas!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.body.2";
			Text ="Ouça, ouça! Notícias de uma guerra iminente chegaram até nós de uma cidade aliada! A cidade está reunindo suas tropas para atacar um de seus inimigos. Como seus aliados, ficaremos ao lado deles!\nEste chamado vai para os cidadãos justos de nossa cidade e também para todos os lansquenets! E aos nossos nobres honrados e à prova de combate!\nBravos homens e mulheres, peguem suas armas e apresentem-se ao Mestre do Arsenal o mais rápido possível! Reuniremos nossas tropas lá até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.title.3";
			Text ="Uma cidade aliada entrou em uma rivalidade!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.body.3";
			Text ="Ouça, ouça! Notícias de uma guerra iminente chegaram até nós de uma cidade aliada! A cidade foi arrastada para uma rivalidade e agora deve se preparar para um ataque. Como seus aliados, ficaremos ao lado deles!\nEste chamado vai para os cidadãos justos de nossa cidade e também para todos os lansquenets! E aos nossos nobres honrados e à prova de combate!\nBravos homens e mulheres, peguem suas armas e apresentem-se ao Mestre do Arsenal o mais rápido possível! Reuniremos nossas tropas lá até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.title.4";
			Text ="Uma cidade aliada entra em guerra!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.body.4";
			Text ="Ouça, ouça! Notícias de uma guerra iminente chegaram até nós de uma cidade aliada! A cidade está formando um exército para intervir em uma disputa que assola seu feudo! Como seus aliados, ficaremos ao lado deles!\nEste chamado vai para os cidadãos justos de nossa cidade e também para todos os lansquenets! E aos nossos nobres honrados e à prova de combate!\nBravos homens e mulheres, peguem suas armas e apresentem-se ao Mestre do Arsenal o mais rápido possível! Reuniremos nossas tropas lá até %date%!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.war.Player.option";
			Text ="Eu ouvi o chamado às armas...";
		},
		LocDirectEntry
		{
			Key ="$avr.arsenal.event.war.Player.option";
			Text ="Ouvi dizer que uma guerra é iminente...";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.war.NPC.answer.positive";
			Text ="Participar de uma guerra pode ser arriscado e você pode morrer ou sua dinastia terá que pagar um resgate para libertá-lo. Mas se você sobreviver e a batalha for vencida, você receberá uma parte dos despojos! Você está disposto a alcançar a glória e se juntar às nossas tropas?";
		},
		LocDirectEntry
		{
			Key ="$avr.arsenal.event.war.NPC.answer.positive";
			Text ="Você está disposto a alcançar a glória e se juntar às nossas tropas?";
		},
		LocDirectEntry
		{
			Key ="$avr.arsenal.event.guilds.NPC.answer.positive";
			Text ="Você está disposto a alcançar a glória?";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.war.NPC.answer.war";
			Text ="Isso mesmo, entraremos em guerra em breve!";
		},
		LocDirectEntry
		{
			Key ="$avr.arsenal.event.war.NPC.answer.war";
			Text ="Isso mesmo, entraremos em guerra em breve!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.war.Player.option.soldier";
			Text ="Junte-se como soldado de infantaria!";
		},
		LocDirectEntry
		{
			Key ="$action.WarEvent.Soldier";
			Text ="Na guerra como soldado de infantaria";
		},
		LocDirectEntry
		{
			Key ="$action.WarEvent.SoldierDesc";
			Text ="Participa de uma guerra como soldado de infantaria.";
