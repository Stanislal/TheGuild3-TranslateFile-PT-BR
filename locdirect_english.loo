		},
		LocDirectEntry
		{
			Key ="$ChurchServiceCityDesc";
			Text ="Deixe o sino da cabana do seu pregador tocar alto e bom som para chamar o seu rebanho de verdadeiros crentes para um culto sagrado na igreja. Eles ouvirão seu sermão e preencherão generosamente sua coleção.";
		},
		LocDirectEntry
		{
			Key ="$gui.sys.Religion";
			Text ="Religião";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.Catholic";
			Text ="Católico";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.CatholicDesc";
			Text ="Os católicos acreditam nas tradições centenárias da santa Mãe Igreja, tendo o Papa como seu supremo pregador e pastor.\n\nObserve: a chance de sucesso para algumas ações é menor quando você interage com um personagem ou família de outra denominação. Por outro lado, o estado de alerta de uma guarda municipal ou lansquenet é maior quando se trata de detectar crimes cometidos por culpados de uma denominação diferente da sua. Todos os guardas da cidade têm a denominação do soberano e os lansquenetes têm a denominação do seu empregador!";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.CatholicDesc2";
			Text ="Os católicos acreditam nas tradições centenárias da santa Mãe Igreja, tendo o Papa como seu supremo pregador e pastor.";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.Protestant";
			Text ="Protestante";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.ProtestantDesc";
			Text ="Os cristãos protestantes seguem as doutrinas dos reformadores evangélicos, que criticam as riquezas e o perdão dos pecados por dinheiro. Eles negam a lealdade do Papa.\n\nAtenção: a chance de sucesso para algumas ações é menor quando você interage com um personagem ou família de outra denominação. Por outro lado, o estado de alerta de uma guarda municipal ou lansquenet é maior quando se trata de detectar crimes cometidos por culpados de uma denominação diferente da sua. Todos os guardas da cidade têm a denominação do soberano e os lansquenetes têm a denominação do seu empregador!";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.ProtestantDesc2";
			Text ="Os cristãos protestantes seguem as doutrinas dos reformadores evangélicos, que criticam as riquezas e o perdão dos pecados por dinheiro. Eles negam ao Papa a sua lealdade.";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.NoReligion";
			Text ="Secular";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.NoReligionDesc";
			Text ="Os cristãos seculares acreditam em Deus, mas seguem um modo de fé mais secular. Eles tentam não interferir nas lutas entre católicos e protestantes.\n\nAtenção: a chance de sucesso de algumas ações é menor quando você interage com um personagem ou família de outra denominação. Por outro lado, o estado de alerta de uma guarda municipal ou lansquenet é maior quando se trata de detectar crimes cometidos por culpados de uma denominação diferente da sua. Todos os guardas da cidade têm a denominação do soberano e os lansquenetes têm a denominação do seu empregador!";
		},
		LocDirectEntry
		{
			Key ="$gui.Religion.NoReligionDesc2";
			Text ="Os cristãos seculares acreditam em Deus, mas seguem um modo de fé mais secular. Eles tentam não interferir nas lutas entre católicos e protestantes.";
		},
		LocDirectEntry
		{
			Key ="$gui.UICategory.Religion";
			Text ="Religião";
		},
		LocDirectEntry
		{
			Key ="$gui.UICategory.Romance";
			Text ="Romances e ligações";
		},
		LocDirectEntry
		{
			Key ="$action.BuyCatholic";
			Text ="Converta-se à fé católica";
		},
		LocDirectEntry
		{
			Key ="$action.BuyCatholicDesc";
			Text ="Você pode deixar sua vida ímpia para trás e se converter à fé católica.";
		},
		LocDirectEntry
		{
			Key ="$action.BuyProtestant";
			Text ="Converta-se à fé protestante";
		},
		LocDirectEntry
		{
			Key ="$action.BuyProtestantDesc";
			Text ="Você pode aplicar-se às doutrinas dos reformadores evangélicos e viver sua vida seguindo o exemplo de Cristo.";
		},
		LocDirectEntry
		{
			Key ="$action.BuyNoReligion";
			Text ="Deixe sua fé religiosa";
		},
		LocDirectEntry
		{
			Key ="$action.BuyNoReligionDesc";
			Text ="Católicos e Protestantes são responsáveis por este cisma da Igreja de Deus. Se você não deseja mais participar disso, então declare que está deixando sua denominação religiosa e que doravante é um cristão secular.";
		},
		LocDirectEntry
		{
			Key ="$WinBelievers";
			Text ="Ganhe crentes na aldeia";
		},
		LocDirectEntry
		{
			Key ="$WinBelieversDesc";
			Text ="Pregue aos aldeões e convença-os da sua própria fé. Quanto mais irmãos você tiver em sua aldeia, maior será sua coleção.";
		},
		LocDirectEntry
		{
			Key ="$WinBelieversCity";
			Text ="Ganhe crentes na cidade";
		},
		LocDirectEntry
		{
			Key ="$WinBelieversCityDesc";
			Text ="Pregue aos habitantes da cidade e convença-os da sua própria fé. Quanto mais irmãos você tiver em sua cidade, maior será sua coleção.";
		},
		LocDirectEntry
		{
			Key ="$MakeCatholic";
			Text ="Converter alguém à fé católica";
		},
		LocDirectEntry
		{
			Key ="$MakeCatholicDesc";
			Text ="Quando a verdadeira fé desaparece, os costumes inevitavelmente decaem e o Anticristo fica mais forte. Mas você pode parar com isso, pelo menos aqui! Portanto, traga o povo de volta à verdadeira fé católica e, portanto, aos braços da santa Mãe Igreja! Os crentes agradecerão doando moedas aos seus pregadores católicos para que você possa expandir seus abençoados negócios.\nAlém disso, algumas atividades sociais se tornarão mais fáceis para você se você tiver a mesma fé que seu homólogo...";
		},
		LocDirectEntry
		{
			Key ="$MakeProtestant";
			Text ="Converter alguém para a fé protestante";
		},
		LocDirectEntry
		{
			Key ="$MakeProtestantDesc";
			Text ="Os reformadores evangélicos trouxeram para todos nós a verdadeira fé cristã! Vamos todos seguir o exemplo de Cristo e viver uma vida frugal! Quanto mais pessoas migrarem para o protestantismo, mais ricas doações você poderá esperar em sua coleção.\nAlém disso, algumas atividades sociais se tornarão mais fáceis para você se você tiver a mesma fé que seu homólogo...";
		},
		LocDirectEntry
		{
			Key ="$MakeSecular";
			Text ="Converter alguém para a fé secular";
		},
		LocDirectEntry
		{
			Key ="$MakeSecularDesc";
			Text ="Você não acredita nem no catolicismo nem nas doutrinas dos reformadores protestantes. Você é um cristão secular em seu coração e alma. Você deveria trazer mais companheiros para sua fé secular.\nAlém disso, algumas atividades sociais se tornarão mais fáceis para você se você tiver a mesma fé que seu colega...";
		},
		LocDirectEntry
		{
			Key ="$feedback.EffectAppliedcatholic";
			Text ="agora é católico";
		},
		LocDirectEntry
		{
			Key ="$feedback.EffectHealedcatholic";
			Text ="agora é um cristão secular";
		},
		LocDirectEntry
		{
			Key ="$statusEffect.catholic";
