			Key ="$n.arsenal.event.Alchimists.end.body";
			Text ="O grupo de viagem retornará em breve. No entanto, os participantes precisam de mais algum tempo para chegar às suas casas.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Alchimists.character.returns.body";
