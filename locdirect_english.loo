		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.character.ransom.body";
			Text ="%character% sobreviveu ao massacre, mas você teve que pagar resgate para resgatá-lo do inimigo vitorioso...";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.war.character.ransom.body.female";
			Text ="%character% sobreviveu ao massacre, mas você teve que pagar resgate para resgatá-la do inimigo vitorioso...";
		},
		LocDirectEntry
