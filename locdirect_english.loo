		},
		LocDirectEntry
		{
			Key ="$MakeUpDesc";
			Text ="Esta pasta de tinta vermelha é aplicada nos lábios. Algumas mulheres até o usam para enfatizar os olhos. Ah, sim, os homens às vezes também colocam essa tinta...";
		},
		LocDirectEntry
		{
			Key ="$DistractEveryone";
