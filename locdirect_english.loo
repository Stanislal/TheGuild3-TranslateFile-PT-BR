		LocDirectEntry
		{
			Key ="$PlantSiblingDesc";
			Text ="Com este privilégio, você pode nomear membros adultos de sua família para cargos em sua cidade. Se você lidar com isso com habilidade, em breve controlará a cidade inteira...";
