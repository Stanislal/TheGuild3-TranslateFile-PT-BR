		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.line.poor1";
			Text ="Como uma pessoa pode ganhar tão pouco?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.earnLittle.line.poor2";
