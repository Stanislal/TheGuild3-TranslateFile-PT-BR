		},
		LocDirectEntry
		{
			Key ="$int.Praise.Audience.6";
			Text ="Bem dito.";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Audience.7";
			Text ="Você tem uma opinião tão elevada sobre mim?";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Victim.0";
			Text ="Sim... é verdade.";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Victim.1";
			Text ="Isso é o que eu penso!";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Victim.2";
			Text ="Parabéns por perceber isso.";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Victim.3";
			Text ="Fico feliz em agradecer seu elogio.";
