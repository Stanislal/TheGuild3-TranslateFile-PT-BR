		LocDirectEntry
		{
			Key ="$PinewoodDesc";
			Text ="A madeira castanho-avermelhada do pinheiro não é tão estável como a madeira de carvalho, mas é mais fácil de trabalhar.";
		},
		LocDirectEntry
		{
			Key ="$PlagueSuit";
			Text ="Traje da peste";
		},
		LocDirectEntry
		{
			Key ="$PlagueSuitDesc";
			Text ="Se você usar essas roupas reconhecidamente feias, você estará em desvantagem no que diz respeito à sua vida social. Mas pelo menos você não vai pegar nada!";
