		},
		LocDirectEntry
		{
			Key ="$society.thievesguild.desc";
			Text ="Os membros da Guilda dos Ladrões são geralmente cidadãos respeitadores da lei e respeitáveis que, no entanto, usam secretamente todos os tipos de meios sorrateiros e ilegais para garantir uma vantagem financeira para si próprios.";
		},
		LocDirectEntry
		{
			Key ="$society.thievesguild.leader";
