		LocDirectEntry
		{
			Key ="$fb.Insult.Success.Actor.District";
			Text ="Você insultou %TargetCharacter% e, portanto, todos os habitantes do distrito %neighborhood% de %city%.";
		},
		LocDirectEntry
		{
			Key ="$fb.Insult.Success.Actor.Dynasty";
			Text ="Você insultou %TargetCharacter% e os cidadãos de %city% descobriram! Embora a sua reputação esteja manchada aos olhos da dinastia %dynasty%, os habitantes do distrito %neighborhood% agora têm menos respeito por esta família.";
		},
		LocDirectEntry
		{
