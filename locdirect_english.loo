		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes4d";
			Text ="Para nomear sua rota, selecione o ícone de lápis no lado direito da janela. Em seguida, digite o nome da sua rota no campo e não se esqueça de confirmar clicando no botão da marca de seleção ou pressionando a tecla Enter.";
		},
		LocDirectEntry
