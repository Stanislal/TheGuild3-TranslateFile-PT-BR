			Text ="O talismã da inspiração concede ao seu usuário uma mente clara e aberta...";
		},
		LocDirectEntry
		{
			Key ="$DiamondStaff";
			Text ="Equipe incrustada de diamantes";
		},
		LocDirectEntry
		{
			Key ="$DiamondStaffDesc";
			Text ="Andar por aí com esta equipe incrustada de diamantes mostrará aos seus parceiros de negócios que você é um comerciante confiável e justo.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.title";
			Text ="A Guilda dos Comerciantes tem algo a anunciar!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.title.1";
			Text ="Guilda dos Comerciantes - mercado de comércio inter-regional";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.body.1";
			Text ="A honorável Guilda dos Mercadores anuncia que planeja enviar uma caravana comercial para um grande mercado comercial inter-regional em uma cidade distante. Este pode ser um evento lucrativo para uma casa mercantil como a sua, especialmente se você for membro da Guilda dos Comerciantes! Se você estiver disposto a se juntar à caravana comercial, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.title.2";
			Text ="Guilda dos Mercadores - caravana para a rota da seda";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.body.2";
			Text ="A próspera Guilda dos Mercadores está planejando equipar uma caravana comercial para alcançar a Rota da Seda no Oriente. Este pode ser um evento lucrativo para uma casa mercantil como a sua, especialmente se você for membro da Guilda dos Comerciantes! Se você estiver disposto a se juntar à caravana comercial, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.title.3";
			Text ="Guilda dos Mercadores - caravana comercial para Roma";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.body.3";
			Text ="A generosa Guilda dos Mercadores está disposta a permitir que você se junte à sua caravana comercial para Roma. Este pode ser um evento lucrativo para uma casa mercantil como a sua, especialmente se você for membro da Guilda dos Comerciantes! Se você estiver disposto a se juntar à caravana comercial, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.title.4";
			Text ="Guilda dos Mercadores - caravana comercial para a costa";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.body.4";
			Text ="A ousada Guilda dos Mercadores oferece aos cidadãos a oportunidade de se juntarem à sua caravana comercial. A caravana deve encontrar um grupo de capitães de navios não especificados na costa e iniciar um comércio lucrativo com eles. Este pode ser um evento lucrativo para uma casa mercantil como a sua, especialmente se você for membro da Guilda dos Comerciantes! Se você estiver disposto a se juntar à caravana comercial, apresente-se ao Mestre do Arsenal até %date%!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.MerchantsGuild.Player.option.short";
			Text ="Chamada da Guilda dos Comerciantes";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.MerchantsGuild.Player.option";
			Text ="O chamado da Guilda dos Mercadores me leva até você.";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.MerchantsGuild.NPC.answer.positive";
			Text ="Juntar-se a eles não é isento de riscos, mas do outro lado da moeda você pode encontrar o negócio da sua vida! E se você for membro da Guilda dos Comerciantes, poderá se beneficiar ainda mais! Você está disposto a se juntar à caravana comercial?";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.MerchantsGuild.NPC.answer";
			Text ="Sim, a Guilda dos Mercadores enviará uma caravana comercial!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.MerchantsGuild.Player.option.join";
			Text ="Sim, eu me juntei a eles!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.GuildEvent.Player.option.joinMember";
			Text ="Sim, eu entro na minha guilda!";
		},
		LocDirectEntry
		{
			Key ="$action.MerchantsGuildEvent";
			Text ="Viajando com uma caravana comercial";
		},
		LocDirectEntry
		{
			Key ="$action.MerchantsGuildEventDesc";
			Text ="Participa de uma caravana comercial da Guilda dos Mercadores.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.end.body";
			Text ="A caravana comercial retornará em breve. No entanto, os participantes precisam de mais algum tempo para chegar às suas casas.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.character.returns.body";
			Text ="%character%, que você enviou com a caravana comercial da Guilda dos Mercadores, volta para casa.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.MerchantsGuild.character.returns.body.female";
			Text ="%character%, que você enviou com a caravana comercial da Guilda dos Mercadores, volta para casa.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.title";
			Text ="Os maçons anunciam algo!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.title.1";
			Text ="Maçons - canteiro de obras de uma catedral";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.body.1";
			Text ="Ouçam, bons pedreiros de perto e de longe! Uma cidade não muito distante realizará extensas reformas em sua catedral! Você está disposto a participar deste grande empreendimento para honra de nosso Senhor? Este apelo vai especialmente para os membros da Maçonaria! Apresse-se e apresente-se ao Mestre do Arsenal, pois a construção está prevista para terminar em %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.title.2";
			Text ="Maçons - canteiro de obras da fortificação de uma cidade";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.body.2";
			Text ="Ouçam, bons pedreiros de perto e de longe! Uma cidade não muito distante empreende uma expansão da fortificação da sua cidade! Você está disposto a participar do fortalecimento das muralhas de defesa desta cidade? Este apelo vai especialmente para os membros da Maçonaria! Apresse-se e apresente-se ao Mestre do Arsenal, pois a construção está prevista para terminar em %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.title.3";
			Text ="Maçons - reconstrução de um distrito inteiro da cidade";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.body.3";
			Text ="Escutem, seus pedreiros e arquitetos! Houve um grande incêndio no centro histórico de uma cidade próxima que destruiu a maioria das casas. Agora o bairro mais antigo da cidade deve ser reconstruído do zero! Você está disposto a participar? Este apelo vai especialmente para os membros da Maçonaria! Apresse-se e apresente-se ao Mestre do Arsenal, pois a construção está prevista para terminar em %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.title.4";
			Text ="Maçons - modernização de um antigo castelo familiar";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.Freemasons.body.4";
			Text ="Os tempos são difíceis e a paz é sempre instável! Uma antiga família nobre, venerável e rica, quer modernizar o antigo castelo da família, tanto em termos de luxo como de fortificação. Você está disposto a trabalhar na construção de uma família nobre? Este apelo vai especialmente para os membros da Maçonaria! Apresse-se e apresente-se ao Mestre do Arsenal, pois a construção está prevista para terminar em %date%!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Freemasons.Player.option.short";
			Text ="Chamado dos Maçons";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Freemasons.Player.option";
			Text ="Segui o chamado dos maçons.";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Freemasons.NPC.answer.positive";
			Text ="Trabalhar em um canteiro de obras não é isento de riscos, mas se você executar bem suas tarefas, poderá ganhar boas moedas - especialmente quando você for membro da Maçonaria! Você está disposto a se juntar à tropa de construção?";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Freemasons.NPC.answer";
			Text ="Os maçons enviam uma tropa de construção para um grande canteiro de obras em uma cidade não muito distante.";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.Freemasons.Player.option.join";
			Text ="Sim, é para isso que estou aqui!";
		},
		LocDirectEntry
		{
			Key ="$action.FreemasonsEvent";
			Text ="Trabalha em um grande canteiro de obras";
		},
		LocDirectEntry
		{
			Key ="$action.FreemasonsEventDesc";
			Text ="Trabalha em um grande canteiro de obras em uma cidade não muito distante.";
