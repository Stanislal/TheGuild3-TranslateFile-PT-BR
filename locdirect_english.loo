		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine4";
			Text ="Ninguém é tão generoso quanto %CharacterContext%!";
		},
		LocDirectEntry
		{
			Key ="$d.act.Praise.fullLine5";
			Text ="%CharacterContext% se preocupa com os grandes problemas, para que você possa viver uma vida despreocupada!";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.openLine.int";
			Text ="Ouvi alguns rumores ruins sobre você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.fullLine.int";
			Text ="Ouvi alguns rumores ruins sobre você e defendi você imediatamente! Terrível! Então, do que se tratava?";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.csAnswer.int";
			Text ="Obrigada, meu amor! Ah, não... É possível que eles saibam disso...";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.sAnswer.int";
			Text ="Pelo menos você está me defendendo! Não é nada, apenas....";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.fAnswer.int";
			Text ="Rumores? Que rumores? Não entendo o que você está tentando dizer.";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.cfAnswer.int";
			Text ="Você criou essa história para arrancar informações de mim?";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.openLine.char";
			Text ="Você parece perturbado hoje, minha estrela mais brilhante!";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.fullLine.char";
			Text ="Você parece perturbado hoje, minha estrela mais brilhante! Diga-me o que há de errado? É sua família?";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.csAnswer.char";
			Text ="Você notou? Oh, querido, talvez eu esteja mais deprimido do que queria admitir...";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.sAnswer.char";
			Text ="Eu pareço assim? Talvez você esteja certo. Às vezes é demais para mim...";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.fAnswer.char";
			Text ="Isso é adorável, mas me sinto muito bem. Minha família é um modelo para os outros.";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.cfAnswer.char";
			Text ="Esse é um truque cruel. Achei que você poderia fazer melhor que isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.openLine.str";
			Text ="Achei que você tivesse sentimentos por mim, mas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.fullLine.str";
			Text ="Achei que você sentia algo por mim, mas não quer compartilhar seus segredos comigo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.csAnswer.str";
			Text ="Claro que tenho sentimentos por você. O que você quer saber?";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.sAnswer.str";
			Text ="Claro que tenho sentimentos por você. Sou apenas tímido, só isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.fAnswer.str";
			Text ="Agora estou ainda menos inclinado a compartilhar segredos com você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.manipLia.cfAnswer.str";
			Text ="O que isso quer dizer? Eu não sou sua propriedade!";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.openLine.int";
			Text ="Você é minha vela na escuridão...";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.fullLine.int";
			Text ="Você é minha vela na escuridão deste mundo. Ver você sempre traz luz ao meu coração.";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.sAnswer.int";
			Text ="Você me lisonjeia, acho que me fez corar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.fAnswer.int";
			Text ="Não é difícil trazer luz para alguém tão obscuro quanto você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.openLine.char";
			Text ="Os poemas de cem poetas não...";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.fullLine.char";
			Text ="Os poemas de cem poetas não conseguiriam captar a plenitude do seu lindo rosto.";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.sAnswer.char";
			Text ="Ah! Que fofo! Eu adoraria que você escrevesse um poema que me capturasse completamente...";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.fAnswer.char";
			Text ="Não gosto de poesia. Estou um pouco decepcionado com você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.openLine.per";
			Text ="Não sei como isso é possível, mas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.fullLine.per";
			Text ="Não sei como isso é possível, mas sua beleza interior supera a do seu rosto verdadeiramente maravilhoso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.court.sAnswer.per";
