			Key ="$nobility.8.female";
			Text ="Nobre";
		},
		LocDirectEntry
		{
			Key ="$nobility.8desc";
			Text ="Os nobres não estão exatamente no nível da nobreza, mas são superiores aos patrícios. São, portanto, reconhecidos pelas famílias aristocráticas da região e ocasionalmente convidados para as suas festividades.";
		},
