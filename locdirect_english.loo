		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ResidenceInterior.LookOutside";
			Text ="Para sair de casa, clique na ação Olhar para fora na barra de ação.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ResidenceInterior.GoHome";
			Text ="Se você entrar em sua residência, poderá observar seus personagens trabalhando ou acessar alguns dos menus.\n\n1. Envie seu avatar para casa selecionando-o e clicando no ícone Enviar para casa na barra de ação.\n\n2. Use Olhar para fora na barra de ação do edifício para retornar ao mundo exterior selecionando a residência e clicando no botão de ação.\n(Você pode usar Olhar para dentro do edifício para retornar para dentro.)";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.InteriorActionsContent";
			Text ="Dentro de cada interior, há uma série de objetos interativos que podem ser usados para abrir interfaces ou, se usados enquanto um personagem estiver selecionado, iniciar uma ação para aquele personagem.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.InteriorCamera_title";
			Text ="Câmera e interiores";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.InteriorCamera_text";
			Text ="Sempre que um personagem entrar em um prédio com um interior enquanto estiver selecionado, a câmera seguirá esse personagem até o prédio quando ele entrar.\nEnquanto estiver dentro do interior, a câmera pode ser navegada com as mesmas teclas que fora. Enquanto um personagem estiver focado, a câmera irá segui-lo enquanto ele se move.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ResidenceInterior.PlayerParty";
			Text ="Designe seu cônjuge para ser membro do seu grupo de jogadores. Isso permite mais ações e as torna acessíveis diretamente no painel da dinastia.\n\n1. Selecione seu cônjuge.\n\n2. Clique no ícone Tornar a mão direita/esquerda na barra de ação.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD.InteriorButtons_title";
			Text ="Vista interna";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD.InteriorLeave_content";
			Text ="Cada interior possui um botão Sair da vista interior à direita, que permite sair do interior com a câmera.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ResidenceInterior.GoHome.Title";
			Text ="Entre e olhe dentro da residência";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialWiki.ResidenceInterior.Training.Title";
			Text ="Interiores";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialWiki.ResidenceInterior.Training.Content";
			Text ="As residências possuem interiores. Todos os interiores são únicos, dependendo do nível e tipo de construção, do layout, da decoração e das ações disponíveis.\nOs personagens também podem treinar certos atributos aqui para obter um impulso temporário no atributo selecionado. As ações de treinamento podem ser encontradas na barra de ação de cada personagem na seção Dinastia e negócios.\nSe você não atribuir algo aos seus familiares enquanto estiverem no interior da residência, os personagens começarão a se ocupar com algumas ações aleatórias como cozinhar, limpar ou ler.";
		},
		LocDirectEntry
