		{
			Key ="$d.npc.global.plagueMap.line.rich2";
			Text ="Nossas terras estão assoladas pela peste!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.global.plagueMap.line.rich3";
			Text ="Essas pessoas comuns deveriam parar de tagarelar sobre a peste.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.global.plagueMap.answer.poor1";
			Text ="Eu não gosto da minha vida de qualquer maneira.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.global.plagueMap.answer.poor2";
			Text ="Não será a primeira nem a última vez.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.global.plagueMap.answer.com1";
			Text ="Devemos nos desinfetar com álcool!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.global.plagueMap.answer.com2";
			Text ="Ah, não! Estamos condenados!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.global.plagueMap.answer.rich1";
			Text ="A peste é a única coisa que realmente tenho medo!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.global.plagueMap.answer.rich2";
			Text ="Não tenho medo da peste. Eu sou rico o suficiente.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.poor1";
			Text ="Eles sempre fazem o que querem. Não há justiça.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.poor2";
			Text ="Não há justiça para pessoas pobres como nós.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.poor3";
			Text ="Justiça só para ricos, né?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.com1";
			Text ="É inacreditável! Onde está a justiça?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.com2";
			Text ="Injustiça e corrupção!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.com3";
			Text ="Justiça para todos!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.rich1";
			Text ="Não acredito que nossos funcionários estejam se comportando assim. E a justiça?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.rich2";
			Text ="Justiça é apenas uma questão de preço.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.line.rich3";
			Text ="Quem permite que esses idiotas façam justiça?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.answer.poor1";
			Text ="Onde estão meus forcados!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.answer.poor2";
			Text ="Devemos decidir a justiça nós mesmos!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.answer.com1";
			Text ="Inacreditável!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.answer.com2";
			Text ="Precisamos fazer alguma coisa!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.answer.rich1";
			Text ="O que restará se tudo o que tivermos for injustiça?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.belowPublic.answer.rich2";
			Text ="Justiça é apenas uma palavra.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.poor1";
			Text ="Existem criminosos por toda parte!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.poor2";
			Text ="Crime, fome, pobreza. O que vem a seguir? A praga?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.poor3";
			Text ="Não consigo dormir porque estou com muito medo. O crime está ao nosso redor!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.com1";
			Text ="Hoje em dia só ouço falar de crimes.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.com2";
			Text ="Alguém deveria fazer algo a respeito desses criminosos!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.com3";
			Text ="Todos os dias ouço falar de outro crime. Isso é uma loucura!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.rich1";
			Text ="Como eu poderia me sentir seguro em um lugar como esse? Apenas criminosos!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.rich2";
			Text ="Acho que é hora de me mudar. Há muitos crimes aqui para o meu gosto.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.line.rich3";
			Text ="Por que a ralé infringe a lei o tempo todo?!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.answer.poor1";
			Text ="Às vezes, o crime é a única coisa que resta às pessoas pobres.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.answer.poor2";
			Text ="Posso apostar que pessoas ricas estão por trás disso.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.answer.com1";
			Text ="Estou com tanto medo! Não posso pagar uma proteção melhor.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.answer.com2";
			Text ="O que os guardas fazem o dia todo?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.answer.rich1";
			Text ="Devo gastar mais dinheiro com minha segurança.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.crime.around.answer.rich2";
			Text ="Vou simplesmente recrutar os capangas mais próximos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.poor1";
			Text ="Talvez este dia não seja tão ruim.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.poor2";
			Text ="Esse dia começou bem... tem algo que não está certo...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.poor3";
			Text ="Este dia não parece ruim até agora. Provavelmente ainda estou dormindo.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.com1";
			Text ="Que dia lindo!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.com2";
			Text ="Ótimo dia para ganhar dinheiro!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.com3";
			Text ="Me sinto ótimo hoje!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.rich1";
			Text ="Está um lindo dia! Embora, quando você é rico, todos os dias são bons.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.rich2";
			Text ="Um ótimo dia para ser rico!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.line.rich3";
			Text ="Sinto-me particularmente bem hoje!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.answer.poor1";
			Text ="Meu dia também não está ruim.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.answer.poor2";
			Text ="Eu também gostaria de me sentir bem hoje.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.answer.com1";
			Text ="Eu concordo, está um bom dia hoje.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.answer.com2";
			Text ="Um bom dia para beber uma cerveja ou pelo menos comer torradas com queijo.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.answer.rich1";
			Text ="Na verdade, também me sinto extraordinário hoje.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gDay.answer.rich2";
			Text ="Todo dia é assim se você for rico o suficiente.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.poor1";
			Text ="Algo estranho tem acontecido ultimamente. Tenho mais dinheiro do que o normal.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.poor2";
			Text ="Sou mais rico do que era! Mas ainda sou pobre...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.poor3";
			Text ="Meus bolsos não estão vazios! Eu tenho algumas moedas!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.com1";
			Text ="Meus negócios estão melhor agora! Não sei o que fiz, mas funcionou!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.com2";
			Text ="Minha bolsa de dinheiro está mais pesada agora!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.com3";
			Text ="É um bom momento para meus negócios! Agora estou preocupado que as coisas mudem.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.rich1";
			Text ="Meu negócio tem sido mais lucrativo ultimamente. Não é de admirar! Afinal, eu sou o chefe!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.rich2";
			Text ="Minha bolsa de dinheiro é terrivelmente pesada, preciso pagar alguém para carregá-la para mim.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.line.rich3";
			Text ="Não faço parte da ralé pobre! Como isso aconteceu?!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.answer.poor1";
			Text ="Você roubou alguma coisa, seu bandido?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.answer.poor2";
			Text ="Sou o único que está falido?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.answer.com1";
			Text ="Trabalhe duro, sonhe grande!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.answer.com2";
			Text ="Vamos gastar essa sua riqueza em uma taverna.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.answer.rich1";
			Text ="Fale baixo. Os batedores de carteira e outros bandidos têm ouvidos aguçados!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.gBusiness.answer.rich2";
			Text ="Dinheiro não é tudo! No entanto...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.poor1";
			Text ="Alguém está nos observando?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.poor2";
			Text ="Sinto que estou sendo observado.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.poor3";
			Text ="Você também sente que alguém está constantemente te observando?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.com1";
			Text ="Estou ficando louco ou alguém está nos observando?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.com2";
			Text ="Por favor, me diga que você também sente que está sendo observado.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.com3";
			Text ="Olhos, olhos... eles estão por toda parte.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.rich1";
			Text ="Eles estão nos observando...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.rich2";
			Text ="Sinto-me estranhamente... como se estivesse sendo observado hoje.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.line.rich3";
			Text ="Acho que alguém está nos observando.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.answer.poor1";
			Text ="Não há nada de interessante para ver.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.answer.poor2";
			Text ="Do que você está falando?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.answer.com1";
			Text ="Deixe-os assistir, não temos nada a esconder.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.answer.com2";
			Text ="Você realmente acha que alguém está nos observando?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.answer.rich1";
			Text ="Eu entenderia se alguém estivesse me observando, mas por que eles observariam você?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.watchingUs.answer.rich2";
			Text ="... e às vezes sinto que estou sendo clicado...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.line.poor1";
			Text ="Sonhei com uma enchente. O que isso significa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.line.com1";
			Text ="Ontem à noite tive um sonho assustador sobre uma enchente.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.line.rich1";
			Text ="Sonhei com uma enchente ontem à noite.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.answer.poor1";
			Text ="Você bebe demais.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.answer.com1";
			Text ="Não acredito no significado oculto dos sonhos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.answer.rich1";
			Text ="Teremos uma inundação no próximo ano.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.answer.poor2";
			Text ="Você bebe pouco.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.answer.com2";
			Text ="Haverá uma seca este ano.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.floodDream.answer.rich2";
			Text ="Você provavelmente só estava com sede durante a noite.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.line.poor1";
			Text ="E se você sonhar em voar?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.line.com1";
			Text ="Um sonho sobre voar significa alguma coisa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.line.rich1";
			Text ="Ontem à noite sonhei em voar. O que isso significa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.answer.poor1";
			Text ="Você deveria voltar à terra.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.answer.com1";
			Text ="Você parece estar vivendo em um mundo de sonhos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.answer.rich1";
			Text ="Cuidado com sua alma ambiciosa e não voe muito alto.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.answer.poor2";
			Text ="Você não pode escapar deste lugar.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.answer.com2";
			Text ="A sorte está sorrindo para você.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.flyDream.answer.rich2";
			Text ="Pare de fantasiar e volte às suas tarefas.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.line.poor1";
			Text ="O que significa sonhar com ampulheta?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.line.com1";
			Text ="Uma ampulheta em um sonho significa alguma coisa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.line.rich1";
			Text ="Eu estava sonhando com uma ampulheta. O que isso significa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.answer.poor1";
			Text ="Chegou a hora de uma grande conquista.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.answer.com1";
			Text ="Alguém está contando os dias em que poderá ver você novamente.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.answer.rich1";
			Text ="Este é um sinal para dedicar tempo às coisas importantes da vida.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.answer.poor2";
			Text ="No final das contas, é tudo uma questão de tempo.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.answer.com2";
			Text ="Isso significa que é hora de visitar uma taverna!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.clockDream.answer.rich2";
			Text ="Use seu tempo com sabedoria, não o desperdice.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.line.poor1";
			Text ="Sonhei com um banquete. O que isso significa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.line.com1";
			Text ="Ontem à noite tive um sonho estranho sobre um banquete.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.line.rich1";
			Text ="Ontem à noite sonhei com um banquete. O que isso significa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.answer.poor1";
			Text ="Significa apenas que você estava com fome.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.answer.com1";
			Text ="Você tem fome de sucesso.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.answer.rich1";
			Text ="Se você fosse rico, poderia fazer um banquete e não apenas sonhar com isso.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.answer.poor2";
			Text ="sonhei com a mesma coisa!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.answer.com2";
			Text ="Você provavelmente comeu demais ontem à noite.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.feastDream.answer.rich2";
			Text ="Talvez em breve você receba um convite para um banquete?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.line.poor1";
			Text ="Sonhei com um barco. O que isso significa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.line.com1";
			Text ="O que significa sonhar com um barco?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.line.rich1";
			Text ="Ontem à noite sonhei com um barco. O que isso significa?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.answer.poor1";
			Text ="Poderíamos ir pescar juntos se você quiser...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.answer.com1";
			Text ="Você deve considerar embarcar em uma longa jornada em busca de novas oportunidades de negócios.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.answer.rich1";
			Text ="Hora de uma aventura!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.answer.poor2";
			Text ="É hora de derrotar um monstro marinho!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.sailDream.answer.com2";
