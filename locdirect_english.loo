			Text ="Por que você está desperdiçando meu tempo? Você mal teve um arranhão!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.BlessedYou";
			Text ="Você é uma pessoa tão boa e honesta, o próprio Deus deve ter te abençoado.";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.Brothel";
			Text ="Eu vi sua mãe saindo de um bordel ontem - acho que ela foi demitida de novo!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.Clothes";
			Text ="Essas roupas são suas ou você tropeçou na lata de lixo?";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.EveryDay";
			Text ="Todos os dias digo aos meus aprendizes e jornaleiros para olharem para o seu trabalho artesanal como exemplo.";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.Inspiration";
			Text ="Você é uma inspiração diária para mim! Seu exemplo me tornou uma pessoa melhor!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.Nephew";
			Text ="Você quer que eu mande meu sobrinho de seis anos para te ensinar esgrima? Tenho certeza que ele pode te ensinar uma ou duas coisas...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.NoseLikeThat";
			Text ="Se eu tivesse um nariz assim, perguntaria para minha mãe se ela se casou com um troll!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.Orphans";
			Text ="Ouvi dizer que órfãos preferem trabalhar como cobaias para o médico do que serem adotados por você!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.Renovating";
			Text ="Ouvi dizer que eles estão reformando a igreja. Talvez você devesse ir até lá e falar com os pedreiros. Tenho certeza que ainda estão procurando modelos para as gárgulas!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.VillageIdiot";
			Text ="Queria que você soubesse que você me convenceu e que votarei em você nas próximas eleições - para idiota da aldeia!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.Wow";
			Text ="Nossa, essa é a sua cara? Deus deve realmente te odiar...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.YouHouse";
			Text ="Passei pela sua casa e pensei ter sentido cheiro de latrinas, mas descobri que era o seu jantar...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Reputation.YourFamily";
			Text ="Sua família é uma verdadeira bênção para esta cidade!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.Around";
