		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.fullLine.int.toFemale";
			Text ="Pessoas inteligentes deveriam ficar juntas, você gostaria de caminhar um pouco comigo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.csAnswer.int.toFemale.1";
			Text ="Claro. Poderíamos ter muitas conversas interessantes.";
