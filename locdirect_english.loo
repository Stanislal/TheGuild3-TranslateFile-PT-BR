			Text ="Iluminado";
		},
		LocDirectEntry
		{
			Key ="$society.brotherhoodoflight.motto";
			Text ="O fim está próximo!";
		},
		LocDirectEntry
		{
			Key ="$society.brotherhoodoflight.name";
			Text ="Guilda dos Iluminados";
		},
		LocDirectEntry
		{
			Key ="$society.circleofthewarlocks.desc";
			Text ="A Guilda dos Bruxos segue o caminho da magia negra e dos rituais sangrentos. Os bruxos prometem suas almas aos senhores demônios para ganhar poder. Eles odeiam a fraqueza e não param diante de nada. Eles acreditam que existe um céu e um inferno, que são o lar de criaturas sobrenaturais. Mas os anjos do céu só querem servos dispostos: sacerdotes e monges. Em sua busca pelo poder, eles se voltam para o inferno.";
		},
		LocDirectEntry
		{
			Key ="$society.circleofthewarlocks.leader";
			Text ="Arco Bruxo";
		},
		LocDirectEntry
		{
			Key ="$society.circleofthewarlocks.leader.female";
			Text ="Arco Bruxo";
		},
		LocDirectEntry
		{
			Key ="$society.circleofthewarlocks.member";
			Text ="Bruxo";
		},
		LocDirectEntry
		{
			Key ="$society.circleofthewarlocks.member.female";
			Text ="Bruxo";
		},
		LocDirectEntry
		{
			Key ="$society.circleofthewarlocks.motto";
			Text ="Poder é tudo que importa!";
		},
		LocDirectEntry
		{
			Key ="$society.circleofthewarlocks.name";
			Text ="Guilda dos Bruxos";
		},
		LocDirectEntry
		{
			Key ="$society.craftsmensguild.desc";
			Text ="A Guilda dos Artesãos é uma associação de e para cidadãos justos. Eles não têm nenhuma fé ou modo de vida específico, além do objetivo comum de conduzir negócios honestos e criar prosperidade.";
		},
		LocDirectEntry
		{
			Key ="$society.craftsmensguild.leader";
			Text ="Grande Mestre";
		},
		LocDirectEntry
		{
			Key ="$society.craftsmensguild.leader.female";
			Text ="Grande Mestre";
		},
		LocDirectEntry
		{
			Key ="$society.craftsmensguild.member";
			Text ="Mestre";
		},
		LocDirectEntry
		{
			Key ="$society.craftsmensguild.member.female";
			Text ="Mestre";
		},
		LocDirectEntry
		{
			Key ="$society.craftsmensguild.motto";
			Text ="Justiça e comunidade.";
		},
		LocDirectEntry
		{
			Key ="$society.craftsmensguild.name";
			Text ="Guilda dos Artesãos";
		},
		LocDirectEntry
		{
			Key ="$society.freemasons.desc";
			Text ="Os maçons são construtores e engenheiros cujas tradições remontam a tempos antigos. Fundada originalmente como uma comunidade de comerciantes que viajavam frequentemente para grandes canteiros de obras em outras terras, hoje seu objetivo é manter em segredo seus conhecimentos e garantir a ordem na cidade.";
		},
		LocDirectEntry
		{
			Key ="$society.freemasons.leader";
			Text ="Grande construtor";
		},
		LocDirectEntry
		{
			Key ="$society.freemasons.leader.female";
			Text ="Grande construtor";
		},
		LocDirectEntry
		{
			Key ="$society.freemasons.member";
			Text ="Construtor";
		},
		LocDirectEntry
