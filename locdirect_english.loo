			Text ="Armazenamento máximo$(Dica)";
		},
		LocDirectEntry
		{
			Key ="$ui.storageRules.headers.maxStorage.tooltip";
			Text ="Armazenamento Máximo\nVenda: Transportadores automatizados venderão itens acima desta configuração para o mercado, mesmo que sejam usados ​​como intermediários para a produção de outros itens.\nAquisição: Transportadores automatizados não comprarão mais itens do que o definido nesta configuração.";
		},
