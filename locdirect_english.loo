		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.fullLine.int";
			Text ="Deus ajuda quem se ajuda. Você se importaria se eu fortalecesse um pouco sua fé nele?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.openLine.intim";
			Text ="Acidentes acontecem...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.fullLine.intim";
			Text ="Olha, não estou dizendo que você TEM que aceitar esse presente, só estou dizendo que acidentes acontecem com muitos cidadãos aqui...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.openLine.cha";
			Text ="Que saco lindo cheio de moedas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.fullLine.cha";
			Text ="Que lindo saco cheio de moedas! Acho que cabe perfeitamente na sua mão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.csAnswer.int";
			Text ="Quem sou eu para enfrentar o destino? Claro, eu vou te ajudar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.sAnswer.int";
			Text ="eu entendo. Verei o que posso fazer por você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.fAnswer.int";
			Text ="Deixe o destino agir. Você não receberá nenhuma ajuda minha!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.cfAnswer.int";
			Text ="Deus só ajuda os fiéis. Saia da minha frente!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.csAnswer.intim";
			Text ="Ah, sim... eu entendo. Os acidentes são sempre lamentáveis. Você pode contar com meu apoio.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.sAnswer.intim";
			Text ="Não quero problemas! Seus presentes são sempre bem-vindos. Obrigado!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.fAnswer.intim";
			Text ="Obrigado, mas me sinto bastante seguro. Você deve guardar seus presentes para aqueles com mentes mais fracas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.cfAnswer.intim";
			Text ="Como você ousa me ameaçar?! Vá embora, antes que eu perca a paciência!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.csAnswer.cha";
			Text ="Você está certo! É um ajuste perfeito para a minha mão! Obrigado! Claro, eu vou te ajudar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.sAnswer.cha";
			Text ="Minha mão é um pouco maior, mas isso é satisfatório. Verei o que posso fazer por você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.fAnswer.cha";
			Text ="Sinto muito, mas minhas duas mãos estão ocupadas no momento. Tente outra hora.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOH.cfAnswer.cha";
			Text ="Você realmente pensou que poderia me tentar com isso? Se perder!";
		},
		LocDirectEntry
		{
			Key ="$callToAction.CharacterConsciousNoDynasty";
			Text ="Selecione um personagem consciente que não faça parte de nenhuma dinastia. O personagem não deve estar dentro de um prédio e nem em um interior onde você não possa entrar.";
