		LocDirectEntry
		{
			Key ="$d.act.embRom.sAnswer.int.toFemale.1";
			Text ="Por que não? Poderia ser divertido.";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.sAnswer.int.toFemale.2";
			Text ="Não tenho outros planos. Então, por que não?";
