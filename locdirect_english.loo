		LocDirectEntry
		{
			Key ="$action.PoisonNeighborhoodDesc";
			Text ="Ninguém está comprando seu remédio? As pessoas são muito saudáveis? Sem problemas. Como médico experiente, você é capaz de envenenar a água do poço; qualquer um que beber dele contrairá uma doença agradável.";
