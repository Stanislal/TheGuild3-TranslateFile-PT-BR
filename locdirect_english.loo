			Text ="Por favor!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Execution.Start";
			Text ="Neste dia, aos olhos de Deus e dos cidadãos honestos de nossa justa cidade, esta pessoa será executada por seu crime covarde!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Medicus.Cost";
			Text ="Colocar você de pé vai custar %coins%!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Medicus.Enemies";
			Text ="Você pode ter alguns inimigos ruins; sua aflição é bastante incomum...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Medicus.Ish";
			Text ="Hmmm... Não tenho certeza se posso realmente ajudá-lo...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Medicus.Needs";
			Text ="Posso ver que suas necessidades pelos meus serviços são maiores que o tamanho da sua bolsa. Farei o meu melhor por esta taxa insignificante...";
