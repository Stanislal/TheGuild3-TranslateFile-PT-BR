		LocDirectEntry
		{
			Key ="$nobility.10.female";
			Text ="Senhora";
		},
		LocDirectEntry
		{
			Key ="$nobility.10desc";
			Text ="Os senhores estão acima dos escudeiros e podem, historicamente falando, estar acima de um pequeno feudo.";
		},
		LocDirectEntry
		{
			Key ="$nobility.11";
			Text ="Barão";
		},
		LocDirectEntry
		{
			Key ="$nobility.11.female";
			Text ="Baronesa";
		},
		LocDirectEntry
		{
			Key ="$nobility.11desc";
			Text ="Historicamente, os barões podem comandar um feudo que inclui um punhado de aldeias.";
		},
		LocDirectEntry
		{
			Key ="$nobility.12";
			Text ="Contagem";
		},
		LocDirectEntry
		{
			Key ="$nobility.12.female";
			Text ="Condessa";
		},
		LocDirectEntry
		{
			Key ="$nobility.12desc";
			Text ="Os condes são membros poderosos e influentes da aristocracia, que historicamente comandam um grande feudo.";
		},
		LocDirectEntry
		{
			Key ="$nobility.13";
			Text ="Marquês";
		},
		LocDirectEntry
		{
			Key ="$nobility.13.female";
			Text ="Marquesa";
		},
		LocDirectEntry
		{
			Key ="$nobility.13desc";
			Text ="Um marquês está acima de uma contagem. Historicamente, eles são os senhores feudais das terras fronteiriças e, portanto, envolvem-se em conflitos frequentes com os senhores feudais de outros reinos.";
		},
		LocDirectEntry
		{
			Key ="$nobility.14";
			Text ="Duque";
		},
		LocDirectEntry
		{
			Key ="$nobility.14.female";
			Text ="Duquesa";
		},
		LocDirectEntry
		{
			Key ="$nobility.14desc";
			Text ="Os relativamente poucos duques do reino têm uma quantidade desproporcional de poder. Eles são superados apenas pelos arquiduques em classificação.";
		},
		LocDirectEntry
		{
			Key ="$nobility.15";
			Text ="Arquiduque";
		},
		LocDirectEntry
		{
			Key ="$nobility.15.female";
			Text ="Arquiduquesa";
		},
		LocDirectEntry
		{
			Key ="$nobility.15desc";
			Text ="Como arquiduque, você pertence ao pequeno círculo ilustre da mais alta e poderosa aristocracia do reino.";
		},
		LocDirectEntry
		{
			Key ="$nobility.1desc";
			Text ="Os servos são de longe as pessoas mais frequentemente representadas do nosso tempo. Eles são forçados a trabalhar para os seus senhores e também devem entregar uma parte do que ganham, ajudando assim a financiar a nobreza e o clero.";
		},
		LocDirectEntry
		{
			Key ="$nobility.2";
			Text ="Plebeu";
		},
		LocDirectEntry
		{
			Key ="$nobility.2.female";
			Text ="Plebeu";
		},
		LocDirectEntry
		{
			Key ="$nobility.2desc";
			Text ="Os plebeus não são trabalhadores diretamente escravos, pois têm mais ou menos permissão para viajar mais livremente pelo campo. No entanto, a maioria das pessoas comuns aluga um terreno de um proprietário.";
		},
		LocDirectEntry
		{
			Key ="$nobility.3";
			Text ="Homem";
		},
		LocDirectEntry
		{
			Key ="$nobility.3.female";
			Text ="Mulher";
		},
		LocDirectEntry
		{
			Key ="$nobility.3desc";
			Text ="Yeomen geralmente possuem seu próprio lote de terra e pagam impostos aos senhores do feudo. Eles não são obrigados a realizar trabalhos forçados.";
		},
		LocDirectEntry
		{
			Key ="$nobility.4";
			Text ="Residente";
		},
		LocDirectEntry
		{
			Key ="$nobility.4.female";
			Text ="Residente";
		},
		LocDirectEntry
		{
			Key ="$nobility.4desc";
			Text ="Os residentes residem perto de uma cidade e cultivam as terras pertencentes à cidade para as classes dominantes.";
		},
		LocDirectEntry
		{
			Key ="$nobility.5";
			Text ="Cidadão";
		},
		LocDirectEntry
		{
			Key ="$nobility.5.female";
			Text ="Cidadão";
		},
		LocDirectEntry
		{
			Key ="$nobility.5desc";
			Text ="A cidade cheira a liberdade! Depois de obter este título, você poderá se candidatar a um cargo municipal e também poderá adquirir algumas habilidades poderosas.";
		},
		LocDirectEntry
		{
