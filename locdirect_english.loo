		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v4.char";
			Text ="As pessoas estão rindo de você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v4.char.toMale";
			Text ="Ei, comediante! Ouvi dizer que você nem precisa contar uma piada para fazer as pessoas rirem. Eles estão rindo de você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v4.char.toFemale";
			Text ="Ei, comediante! Ouvi dizer que você nem precisa contar uma piada para fazer as pessoas rirem. Eles estão rindo de você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v4.char";
			Text ="Vamos ver se você ri disso também!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v4.char";
			Text ="Eu não acho isso. Você não vai me provocar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v4.str.toMale";
			Text ="Nem seu cachorro te respeita.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v4.str.toMale";
			Text ="Ei você! É verdade que você é um homem tão ratinho que nem seu cachorro te escuta?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v4.str.male";
			Text ="Quem você está chamando de rato?! Eu vou te mostrar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v4.str.male";
			Text ="Você quer dizer o cachorro que eu nem possuo? Você precisará se esforçar mais para me provocar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v4.str.toFemale";
			Text ="Você parece um sapo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v4.str.toFemale";
			Text ="Você não tem nada melhor para fazer do que espalhar falsos boatos sobre outras pessoas? Você é como um sapo. Feio e venenoso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v4.str.female";
			Text ="Devo mostrar o quão venenoso eu sou?!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v4.str.female";
			Text ="Minhas palavras machucaram você? Bem, isso não tem jeito, a verdade dói.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v4.dex";
			Text ="Qual é a origem do seu cheiro vilão?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v4.dex";
			Text ="Aposto que esse fedor vem da sua boca, mas meu parceiro afirma que vem dos seus pés. Quem está certo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v4.dex";
			Text ="Eu me pergunto que tipo de cheiro suas entranhas têm!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v4.dex";
			Text ="Honestamente, esse insulto não foi criativo o suficiente. Tente novamente mais tarde.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v5.char";
			Text ="Ninguém quer dançar com você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v5.char.toMale";
			Text ="Tenho pena de você porque todas as mulheres estão evitando você para não terem que dançar com você. Mas quem poderia culpá-los?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v5.char.toFemale";
			Text ="Tenho pena de você, porque nenhum dos homens nunca te convidou para dançar. Mas quem poderia culpá-los?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v5.char";
			Text ="Você gostaria de dançar com meu punho?";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v5.char";
			Text ="O que me importa! Eu nem gosto de dançar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v5.str.toMale";
			Text ="Não é a faca mais afiada da gaveta...";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v5.str.toMale";
			Text ="Me escute, seu idiota! Um carneiro envelhecido e com o cérebro confuso tem mais cérebro do que você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v5.str.male";
			Text ="Deixe-me dar uma olhada DENTRO da sua cabeça, estúpido!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v5.str.male";
			Text ="Ouvi dizer que o carneiro de Áries é muito sábio. Você não vai me provocar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v5.str.toFemale";
			Text ="Todo mundo diz que você não tem vergonha...";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v5.str.toFemale";
			Text ="Quando olho para você, entendo o que as pessoas queriam dizer quando falavam de você. Você não tem vergonha!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v5.str.female";
			Text ="Como você ousa falar assim comigo?!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v5.str.female";
			Text ="É uma vergonha espionar as discussões privadas de outras pessoas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.openLine.v5.dex";
			Text ="Sua família tem vergonha de você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fullLine.v5.dex";
			Text ="Qual é a sensação de ser a ovelha negra da pior família da cidade? Um duplo golpe de azar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.sAnswer.v5.dex";
			Text ="Quem você está chamando de ovelha negra?!";
		},
		LocDirectEntry
		{
			Key ="$d.act.duelInsult.fAnswer.v5.dex";
			Text ="Não sei... talvez você possa me dizer.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.openLine.v4.char";
			Text ="Eu posso te dar o mundo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fullLine.v4.char";
			Text ="Garanto que ninguém vai te dar tanto quanto eu posso! O que será? Posso contar com sua ajuda?";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.sAnswer.v4.char.male";
			Text ="Isso é exatamente o que quero ouvir do meu líder! Eu apoiarei sua família.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.sAnswer.v4.char.female";
			Text ="Isso é exatamente o que quero ouvir do meu líder! Eu apoiarei sua família.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fAnswer.v4.char";
			Text ="Quem você está tentando enganar? Isso não faz sentido...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.openLine.v4.intim";
			Text ="Nosso feudo precisa de ordem e sabedoria...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fullLine.v4.intim";
			Text ="Por toda parte sujeira, pecado e tolice! Trarei ordem e sabedoria a este feudo. Isso não seria uma coisa boa?";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.sAnswer.v4.intim";
			Text ="Eu concordo - quem diria não à ordem e à sabedoria? Você pode contar comigo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fAnswer.v4.intim";
			Text ="Suas palavras soam como palavras de um fanático. Na verdade, estou me sentindo desconfortável agora. Adeus.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.openLine.v4.str";
			Text ="As pessoas aqui precisam de orientação moral...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fullLine.v4.str";
			Text ="Precisamos de alguém que finalmente traga sentido moral às vidas desses pecadores! Você concorda, alma pura?";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.sAnswer.v4.str";
			Text ="Isso é verdade. Todas essas pessoas não são como eu; eles pecam todos os dias. Isto tem que parar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fAnswer.v4.str";
			Text ="SUA alma é tão pura assim? Você está andando por aí falando mal de seus irmãos e irmãs.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.openLine.v5.char";
			Text ="Você merece mais alegria na vida...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fullLine.v5.char";
			Text ="As pessoas aqui trabalham duro todos os dias e o que elas recebem em troca? Prometo trazer alegria e relaxamento à vida na cidade!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.sAnswer.v5.char";
			Text ="Oba, só trabalho, trabalho e mais trabalho. Minha vida deveria oferecer algo mais do que isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fAnswer.v5.char";
			Text ="Não, não preciso de RELAXAMENTO, preciso de RENTABILIDADE. Afaste-se...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.openLine.v5.intim";
			Text ="É hora de mudar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fullLine.v5.intim";
			Text ="O povo da nossa terra já sofreu por tempo suficiente. É hora de mudar. Você está comigo ou contra mim?";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.sAnswer.v5.intim";
			Text ="Você está certo! Já fomos oprimidos por tempo suficiente. Estou do seu lado. Hora de se revoltar!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fAnswer.v5.intim";
			Text ="Pelo que você está dizendo, não está claro para mim que tipo de mudança você tem em mente. Estou longe de estar convencido.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.openLine.v5.str";
			Text ="Nossos titulares de cargos não respeitam a lei...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fullLine.v5.str";
			Text ="Nossos funcionários estão ignorando a lei; eles não podem nos liderar. Quero proteger a lei e a ordem em nosso feudo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.sAnswer.v5.str";
			Text ="É exatamente assim! Eu vou apoiá-lo se você estiver pensando em mudar isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goC.fAnswer.v5.str";
			Text ="Você está insinuando que não será corrompido pelo poder? Você é ingênuo ou incrivelmente estúpido.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v2.str";
			Text ="A cidade não tolerará seus crimes...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v2.str";
			Text ="Nossa cidade não está disposta a tolerar seus atos desonrosos. Declaro você, %CharacterTarget%, um fora da lei!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v2.str";
			Text ="Você não pode fazer isso! Por favor, juro que serei um cidadão melhor a partir de agora!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v2.str.female";
			Text ="Você não pode fazer isso! Por favor, juro que serei um cidadão melhor a partir de agora!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v2.str";
			Text ="Você vai se arrepender mais cedo do que pensa!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v2.str.tomale";
			Text ="Ouça-me, 'oh todo-poderoso titular de cargo'. Ninguém se importa com você e seus discursos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v2.str.tofemale";
			Text ="Ouça-me, 'oh todo-poderoso titular de cargo'. Ninguém se importa com você e seus discursos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v2.str";
			Text ="Você teve um desempenho impressionante, mas olhe ao seu redor. Você vê alguém prestando atenção em suas palavras?";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v2.cha";
			Text ="Suas ações estão me forçando a...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v2.cha";
			Text ="%CharacterTarget%, devido aos seus erros, estou marcando você como um fora-da-lei sem a proteção dos guardas da cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v2.cha";
			Text ="Você acha que não trago mais nenhum benefício para a sociedade? Sou um membro valioso da comunidade. Não faça isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v2.cha";
			Text ="Pense no que meus inimigos farão comigo agora? Por favor, não faça isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v2.cha";
			Text ="Pareço alguém que está impressionado com esta declaração?";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v2.cha";
			Text ="Você não deveria parar de se envergonhar? Você está insultando a autoridade deste escritório.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v2.dex";
			Text ="Não tenho outra escolha...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v2.dex";
			Text ="%CharacterTarget%, suas ações não me deixam escolha a não ser condená-lo ao ostracismo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v2.dex";
			Text ="Eu imploro! Admito que fui um pecador, mas tudo isso ficou no passado!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v2.dex";
			Text ="Por favor, apelo à sua misericórdia!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v2.dex";
			Text ="Bravo! Você fez um ótimo discurso. E agora você deveria ir para casa e me deixar em paz.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v2.dex";
			Text ="Não quero destruir suas esperanças, mas temo que suas palavras sejam todas em vão. Vá para casa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v3.str";
			Text ="Suas ações não são toleradas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v3.str";
			Text ="Não podemos mais tolerar os crimes que você cometeu nesta cidade! Declaro você, %CharacterTarget%, um fora da lei!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v3.str.Female";
			Text ="Estou profundamente envergonhado! Mas, por favor, não faça isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v3.str.Male";
			Text ="Estou profundamente envergonhado! Mas, por favor, não faça isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v3.str";
			Text ="Você não pode fazer isso! Você está fazendo o jogo de quem está apenas esperando que isso aconteça!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v3.str";
			Text ="Escute, ninguém dá a mínima para o que você está dizendo. Por que você simplesmente não deixa tudo em paz?";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v3.str";
			Text ="Você terminou? E agora faremos isso: contarei até três, e nesse momento você estará fora da minha vista.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v3.cha";
			Text ="Você e seus atos ímpios...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v3.cha";
			Text ="Não podemos mais fechar os olhos para suas blasfêmias! Declaro você, %CharacterTarget%, um fora da lei!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v3.cha";
			Text ="Sim, eu sei que pequei. Por favor, mostre misericórdia antes da justiça.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v3.cha";
			Text ="Isso é uma piada, não é? Por favor, me diga que você está apenas brincando!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v3.cha.tomale";
			Text ="Estou muito ocupado para essa bobagem. Apenas me deixe em paz, seu idiota.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v3.cha.tofemale";
			Text ="Estou muito ocupado para essa bobagem. Apenas me deixe em paz, seu idiota.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v3.cha.tomale";
			Text ="Meu 'querido amigo', foi uma piada deliciosa. Mas acho que é hora de parar com essa bobagem.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v3.cha.tofemale";
			Text ="Meu 'querido amigo', foi uma piada deliciosa. Mas acho que é hora de parar com essa bobagem.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v3.dex";
			Text ="De agora em diante, você é um fora da lei...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v3.dex";
			Text ="%CharacterTarget%, estou condenando você ao ostracismo! Os guardas da cidade não irão mais intervir nos crimes cometidos contra você.";
