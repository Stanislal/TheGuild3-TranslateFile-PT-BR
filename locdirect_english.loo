		},
		LocDirectEntry
		{
			Key ="$InitiateIntrigueDesc";
			Text ="Como um protestante amante da paz, você nunca usaria violência contra ninguém, pelo menos não em público. Mas você tem outras opções! Então ai do católico que interfere nos seus assuntos, porque sabe usar uma intriga direcionada para destruir a influência dos outros...";
		},
		LocDirectEntry
		{
			Key ="$notification.InitiateIntrigue.Head";
