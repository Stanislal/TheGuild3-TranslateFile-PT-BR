		LocDirectEntry
		{
			Key ="$gui.Char.StoryMode.tooltip";
			Text ="Aqui você pode escolher uma campanha familiar. A campanha padrão é vencida quando você se torna um soberano e mantém a posição por uma rodada completa. Você também pode escolher 'Jogo grátis' para não ter condições de vitória.";
		},
		LocDirectEntry
		{
			Key ="$gui.YearsPerRound.tooltip";
			Text ="Com esta opção você escolhe quantos anos se passarão quando uma rodada terminar.\nIsso afetará principalmente a rapidez com que os personagens no jogo envelhecem - e a rapidez com que seus filhos atingem a idade jogável.";
		},
		LocDirectEntry
		{
			Key ="$gui.MPAIBehavior.tooltip";
