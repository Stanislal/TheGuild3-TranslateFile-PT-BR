		LocDirectEntry
		{
			Key ="$GiveSermon";
			Text ="Faça um sermão na aldeia";
		},
		LocDirectEntry
		{
			Key ="$GiveSermonDesc";
			Text ="Faça um sermão nas ruas da aldeia. Aldeões da mesma fé que você encherão alegremente sua coleção de moedas, enquanto outros estarão menos interessados ​​em ouvi-lo. Na verdade, se você for católico, os protestantes irão ignorar completamente o seu discurso. O mesmo vale para os católicos, se você for protestante.";
		},
		LocDirectEntry
		{
			Key ="$GiveSermonCity";
			Text ="Faça um sermão na cidade";
		},
		LocDirectEntry
		{
			Key ="$GiveSermonCityDesc";
			Text ="Faça um sermão nas ruas da cidade. Cidadãos da mesma fé que você encherão alegremente sua coleção de moedas, enquanto outros estarão menos interessados ​​em ouvi-lo. Na verdade, se você for católico, os protestantes irão ignorar completamente o seu discurso. O mesmo vale para os católicos, se você for protestante.";
