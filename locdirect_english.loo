		{
			Key ="$profession.InnkeeperDesc";
			Text ="O estalajadeiro oferece bebidas e refeições simples na choperia da taberna. Aqui você pode bater um papo sociável, espalhar ou ouvir as últimas fofocas e desfrutar de um jogo de dados!";
		},
		LocDirectEntry
		{
