		LocDirectEntry
		{
			Key ="$d.npc.casualLife.competition.answer.rich2";
			Text ="Talvez eles sejam melhores que você.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceJob.line.poor1";
