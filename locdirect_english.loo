		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v3.dex";
			Text ="Eu realmente me arrependo de minhas ações. Por favor, ouça meu pedido de misericórdia!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v3.dex";
			Text ="Não estou isento de pecado, mas não cometi nenhum crime!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v3.dex";
			Text ="Você não acha que seu comportamento foi ridículo? Apenas pare com isso e siga seu caminho.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v3.dex";
