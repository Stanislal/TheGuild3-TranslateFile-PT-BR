		LocDirectEntry
		{
			Key ="$society.lansquenetbrotherhood.motto";
			Text ="Eu sou a espada e o escudo dos meus irmãos!";
		},
		LocDirectEntry
		{
			Key ="$society.lansquenetbrotherhood.name";
			Text ="Guilda dos Lansquenetes";
		},
		LocDirectEntry
		{
			Key ="$society.merchantsguild.desc";
			Text ="Nesta guilda, os comerciantes ricos trabalham juntos para apoiar uns aos outros em seus esforços, para que seus esforços combinados garantam e aumentem sua influência e prosperidade.";
		},
		LocDirectEntry
