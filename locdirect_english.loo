		LocDirectEntry
		{
			Key ="$action.PonderAboutLifesBigQuestionsDesc";
			Text ="Encontre alguém com quem conversar sobre Deus, a vida e o mundo. Se eles gostarem do seu argumento, isso aumentará a opinião deles sobre você.";
