		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceJob.line.poor2";
			Text ="Pode ser difícil de acreditar, mas gosto do meu trabalho.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceJob.line.com1";
