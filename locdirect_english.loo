		LocDirectEntry
		{
			Key ="$action.LoiteringDesc";
			Text ="Ficar na frente da loja do seu concorrente, isso reduzirá a satisfação do cliente da empresa por um tempo";
		},
		LocDirectEntry
		{
			Key ="$action.GiveProfessionalAdvise";
			Text ="Dê aconselhamento profissional";
		},
		LocDirectEntry
		{
			Key ="$action.GiveProfessionalAdviseDesc";
			Text ="Você é uma pessoa de muita experiência! Você deve compartilhar essa experiência com outras pessoas. Se você der uma dica a um membro de uma dinastia concorrente para aumentar seu lucro, ele certamente apreciará.";
		},
		LocDirectEntry
		{
			Key ="$action.StartATavernFight";
			Text ="Comece uma briga de taverna";
		},
		LocDirectEntry
		{
			Key ="$action.StartATavernFightDesc";
			Text ="Você quer desabafar e prejudicar o negócio de taverna de um concorrente ao longo do caminho? Vá para a próxima Taverna, beba até se fartar e encontre alguém para antagonizar! A luta certamente reduzirá a base de clientes da taverna, se você tiver sorte pode até haver alguns danos materiais!";
		},
		LocDirectEntry
		{
			Key ="$action.AccuseSomeoneOfWitchcraft";
			Text ="Acusar alguém de bruxaria";
		},
		LocDirectEntry
		{
			Key ="$action.AccuseSomeoneOfWitchcraftDesc";
			Text ="Você não sente remorso por mentir para um padre? Muito bom! Vá a uma igreja, peça ao padre que faça sua penitência e diga que alguém o forçou a participar de algum ritual obscuro. Se ele acreditar em você, o padre provavelmente transmitirá suas preocupações ao resto do rebanho e isso levará a rumores sobre o suposto mago. Se você tiver sorte, eles podem até ser atacados! Você não terá nenhuma prova, mas quando foi que a falta de provas impediu a igreja mãe de fazer uma pequena caça às bruxas?";
		},
		LocDirectEntry
		{
			Key ="$action.TellAJoke";
			Text ="Conte uma piada";
		},
		LocDirectEntry
		{
			Key ="$action.TellAJokeDesc";
			Text ="Todo mundo adora uma boa piada. Se você quiser melhorar seu relacionamento com alguém, conte uma piada. Se ele gostar da sua piada, sua reputação aumentará.";
		},
		LocDirectEntry
		{
			Key ="$action.MakePublicCompliment";
			Text ="Admire as habilidades de alguém";
		},
		LocDirectEntry
		{
			Key ="$action.MakePublicComplimentDesc";
			Text ="Você admira as habilidades de alguém? Faça-lhes um elogio público para que saibam! Isso certamente ajudará a melhorar o relacionamento entre suas famílias e custará apenas um pouco de sua influência.";
		},
		LocDirectEntry
		{
			Key ="$action.BoostSomonesBargaining";
			Text ="Ajude alguém a conseguir melhores negócios no mercado";
		},
		LocDirectEntry
		{
			Key ="$action.BoostSomonesBargainingDesc";
			Text ="Você quer ajudar uma dinastia amigável a conseguir melhores negócios no mercado? Se você for suficientemente influente, poderá tentar pressionar os negociantes do mercado a oferecer-lhes melhores preços. Isto dará à outra família um impulso de negociação pelo qual ficarão muito gratos!";
		},
		LocDirectEntry
		{
			Key ="$action.PonderAboutLifesBigQuestions";
