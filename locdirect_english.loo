		},
		LocDirectEntry
		{
			Key ="$BetrayedCaptain";
			Text ="A história do capitão traído";
		},
		LocDirectEntry
		{
			Key ="$BetrayedCaptainDesc";
			Text ="Esta... hum... pintura maravilhosa mostra um capitão pirata em seu navio que está cheio de despojos e alguns amotinados enforcados ao fundo. É motivador, não é?! Portanto, caso você possua um edifício comercial não produtivo, onde seus trabalhadores são preguiçosos demais para o seu gosto, pense em anexar esta bela obra de arte a esse edifício...";
		},
		LocDirectEntry
		{
			Key ="$ApplyBetrayedCaptain";
			Text ="Aplique a história do capitão traído";
		},
		LocDirectEntry
		{
			Key ="$effect.buff.BetrayedCaptain";
			Text ="Os trabalhadores deste edifício comercial estão um pouco apressados e ficam olhando em volta... mas parecem muito motivados!";
		},
		LocDirectEntry
		{
			Key ="$effect.buff.BetrayedCaptain.Worker";
			Text ="Estava convencido de estar motivado...";
		},
		LocDirectEntry
		{
			Key ="$PoisonTrap";
			Text ="Armadilha venenosa";
		},
		LocDirectEntry
		{
			Key ="$PoisonTrapDesc";
			Text ="Você pode anexar esta obra-prima de uma combinação de conhecimento secreto sobre venenos e mecânica delicada a um de seus edifícios. Os vilões que chegarem muito perto enquanto sabotarão seu prédio certamente se arrependerão...";
