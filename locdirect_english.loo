		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceJob.answer.com1";
			Text ="Você tem sorte; não é tão fácil encontrar um trabalho que você goste.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceJob.answer.com2";
