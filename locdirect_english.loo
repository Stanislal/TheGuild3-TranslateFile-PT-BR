		LocDirectEntry
		{
			Key ="$Pepper";
			Text ="Pimenta";
		},
		LocDirectEntry
		{
			Key ="$PepperDesc";
			Text ="A pimenta tem sido um dos produtos mais comercializados entre o Ocidente e os países do outro lado do Oriente desde a Antiguidade. Houve tempos em que a pimenta era até pesada em ouro - e não é menos por isso que comerciantes conhecidos também eram chamados de \"pepper bags\".";
		},
		LocDirectEntry
		{
			Key ="$Perfume";
			Text ="Perfume";
		},
		LocDirectEntry
		{
			Key ="$PerfumeDesc";
			Text ="Hoje o perfume é frequentemente usado para mascarar odores corporais desagradáveis. Tomando banho, você diz? Isso deixa você doente e infeliz! Você não sabia disso?!";
		},
		LocDirectEntry
		{
