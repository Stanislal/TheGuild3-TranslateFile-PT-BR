		LocDirectEntry
		{
			Key ="$EthanolDesc";
			Text ="A aguardente de vinho é obtida a partir de bagas e, ao contrário do álcool puro, contém uma substância especial e volátil que, à luz de descobertas recentes, os estudiosos chamam de sopro de vida.";
		},
		LocDirectEntry
