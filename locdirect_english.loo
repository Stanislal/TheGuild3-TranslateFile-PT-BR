		LocDirectEntry
		{
			Key ="$callToAction.StartRomance";
			Text ="Selecione uma pessoa adulta e consciente, de gênero diferente, que não faça parte de sua família, nem seja um líder de dinastia, nem um funcionário, e que não esteja dentro de um prédio ou dentro de um interior onde você não esteja autorizado a entrar.";
