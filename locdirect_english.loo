		},
		LocDirectEntry
		{
			Key ="$LetterFromInquisitionDesc";
			Text ="Você pode usar sua conexão com uma fonte específica para ter uma carta escrita da Inquisição, ou pelo menos uma que pareça ter sido originada da Inquisição. Isso permitirá que você assuste um pobre protestante a tal ponto que ele verá os cães de caça de Deus literalmente em todos os lugares...";
		},
		LocDirectEntry
		{
			Key ="$notification.LetterFromInquisition.Success.Head";
			Text ="A inquisição está de olho em você!";
		},
		LocDirectEntry
		{
			Key ="$notification.LetterFromInquisition.Success.Body";
			Text ="Um homem envolto em uma capa preta, cujo rosto estava escondido em um capuz, colocou um pergaminho em suas mãos e desapareceu novamente. Você o desenrola e lê:\n\n%CharacterTarget%, sua blasfêmia não passou despercebida. Esteja avisado, que a santa Inquisição Católica está observando cada passo seu!";
		},
		LocDirectEntry
		{
			Key ="$notification.LetterFromInquisition.Success.Body.female";
			Text ="Um homem envolto em uma capa preta, cujo rosto estava escondido em um capuz, colocou um pergaminho em suas mãos e desapareceu novamente. Você o desenrola e lê:\n\n%CharacterTarget%, sua blasfêmia não passou despercebida. Esteja avisado, que a santa Inquisição Católica está observando cada passo seu!";
		},
		LocDirectEntry
		{
			Key ="$notification.LetterFromInquisition.Failure.Head";
			Text ="Alguém tentou assustar você!";
		},
		LocDirectEntry
		{
			Key ="$notification.LetterFromInquisition.Failure.Body";
			Text ="Um homem envolto em uma capa preta, cujo rosto estava escondido em um capuz, colocou um pergaminho em suas mãos e desapareceu novamente. O pergaminho contém uma ameaça da Inquisição, ou pelo menos é o que parece até você ver a assinatura: %CharacterSource%!\n\nQue tentativa mesquinha de assustar você!";
		},
		LocDirectEntry
		{
			Key ="$notification.LetterFromInquisition.Failure.Body.female";
			Text ="Um homem envolto em uma capa preta, cujo rosto estava escondido em um capuz, colocou um pergaminho em suas mãos e desapareceu novamente. O pergaminho contém uma ameaça da Inquisição, ou pelo menos é o que parece até você ver a assinatura: %CharacterSource%!\n\nQue tentativa mesquinha de assustar você!";
		},
