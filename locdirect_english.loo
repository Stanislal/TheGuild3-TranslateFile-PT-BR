		LocDirectEntry
		{
			Key ="$profession.GravediggerDesc";
			Text ="As pessoas consideram os coveiros impuros e portadores da peste. Todos os evitam e murmuram coisas ruins pelas costas. Então apenas os marginalizados e os caídos consideram se tornar coveiros...";
