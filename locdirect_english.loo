		LocDirectEntry
		{
			Key ="$gui.options.warning.shadowmem.title";
			Text ="Memória GPU baixa";
		},
		LocDirectEntry
		{
			Key ="$gui.options.warning.shadowmem.message";
			Text ="O uso de ultra sombras não é recomendado com menos de 8.192 MB de memória de vídeo (quantidade detectada: %gpumem% MB).\n\nVocê ainda pode selecionar esta opção, mas podem ocorrer lentidão inesperada.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Arsenal_header";
			Text ="Arsenal";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Arsenal_text2";
			Text ="O Arsenal é o edifício onde as armas são armazenadas e os prisioneiros são retidos. Você pode ir lá para falar com o Mestre do Arsenal e participar de um Evento de Guerra, um Evento de Guilda ou suborná-la para libertar um prisioneiro.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Arsenal_header2";
			Text ="Guerra e Eventos de Guilda";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Arsenal_text3";
			Text ="Eventos de Guerra permitem que você envie um membro da dinastia ou um lansquenet para a guerra. O sucesso da guerra e o desempenho do seu personagem nela dependerão da sorte, dos atributos e equipamentos do personagem e da dificuldade do jogo. Os Eventos de Guilda são semelhantes, mas não podem ser frequentados por lansquenets e exigem atributos e equipamentos diferentes para serem bem-sucedidos. No entanto, você tem maiores chances de sucesso e de receber recompensas por ser membro da guilda que desencadeou o evento. Se você tiver sucesso em um evento, poderá ganhar itens raros ou bônus, mas se falhar, poderá receber debuffs, ser capturado ou até morrer.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds_Header2";
			Text ="Atitude";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds_Text2";
			Text ="As ações que você realiza determinam a atitude de sua dinastia. Você pode verificar sua atitude atual olhando as informações de sua dinastia, e você pode verificar a atitude que uma ação irá levar você olhando os ícones na janela de dicas da ação. Cada ação pode mudar sua atitude até certo ponto.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Production_Header1";
			Text ="Ações automatizadas baseadas em localização";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Production_Text1";
			Text ="Algumas ações são realizadas em um local, como Quiromancia, Batedor de carteira, Emboscada, etc.\nSe você definir essas ações na lista de pedidos, os trabalhadores se moverão automaticamente para algum lugar aleatoriamente para realizá-las. Para otimizar isso, você pode clicar no ícone de destino para selecionar uma vila ou distrito da cidade onde deseja que a ação seja realizada.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Production_Header2";
			Text ="Locais específicos para ações individuais";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Production_Text3";
			Text ="Se desejar que seus trabalhadores realizem suas ações em um local específico do mapa, você pode arrastar ações que possuem o ícone de alvo (número 1) para o slot de produção individual de um trabalhador (número 2, veja dois capítulos acima para produção individual). Ao fazer isso, o jogo permitirá que você selecione um local específico no mapa (número 3). Feito isso, seu trabalhador sempre tentará realizar aquela ação na posição designada.";
		},
