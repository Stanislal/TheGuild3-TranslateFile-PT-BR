		LocDirectEntry
		{
			Key ="$PickPocketCoordinate";
			Text ="Furtos (com localização)";
		},
		LocDirectEntry
		{
			Key ="$PickPocketDesc";
			Text ="A transferência de moedas e itens das bolsas dos ricos para as dos pobres - como a sua - é o seu comércio! Aqui, a escolha de um distrito alvo não é de pouca importância, uma vez que os bairros ricos podem render mais moedas, mas os guardas da cidade patrulham estas áreas com mais regularidade.";
		},
		LocDirectEntry
		{
			Key ="$Pinewood";
			Text ="Madeira de pinho";
