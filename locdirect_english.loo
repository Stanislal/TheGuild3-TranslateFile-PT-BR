		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.title";
			Text ="Anúncio da Guilda dos Artesãos!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.title.1";
			Text ="Guild of Craftsmen - trabalhe em um acampamento militar";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.body.1";
			Text ="Um general, tão famoso quanto notório, montou seu acampamento militar a poucos dias de viagem. O seu exército precisa de ser reequipado e por isso ele procura artesãos qualificados. A Guilda dos Artesãos segue esse chamado naturalmente! Caso você também queira viajar para lá, por favor compareça ao Mestre do Arsenal até %date%.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.title.2";
			Text ="Guild of Craftsmen - nova máquina de guerra";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.body.2";
			Text ="Um famoso e talentoso mecânico italiano está trabalhando em uma nova máquina de guerra para um alto nobre. O mecânico procura artesãos qualificados para ajudá-lo a concluir o trabalho. A Guilda dos Artesãos segue esse chamado naturalmente! Caso você também queira viajar para lá, por favor compareça ao Mestre do Arsenal até %date%.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.title.3";
			Text ="Guilda dos Artesãos - modernização das obras mecânicas";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.body.3";
			Text ="Estão sendo procurados artesãos e mecânicos talentosos para um grande projeto em uma cidade próxima: o relógio da prefeitura, as fechaduras da tesouraria e muitas outras obras mecânicas serão modernizadas com tecnologia de ponta. A Guilda dos Artesãos segue esse chamado naturalmente! Caso você também queira viajar para lá, por favor compareça ao Mestre do Arsenal até %date%.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.title.4";
			Text ="Guilda dos Artesãos - uma cidade precisa de artesãos";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.body.4";
			Text ="Uma cidade próxima precisa urgentemente de artesãos, uma vez que seus cidadãos qualificados no ofício se mudaram para servir um grande senhor por um bom salário por um tempo. Agora os negócios da cidade estão parados... A Guilda dos Artesãos segue esse chamado naturalmente! Caso você também queira viajar para lá, por favor compareça ao Mestre do Arsenal até %date%.";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.CraftmensGuild.Player.option.short";
			Text ="Chamada da Guilda dos Artesãos";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.CraftmensGuild.Player.option";
			Text ="A Guilda dos Artesãos está se preparando para uma viagem?";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.CraftmensGuild.NPC.answer.positive";
			Text ="Você quer se juntar a eles? Esta viagem irá esconder alguns riscos, mas um bom salário é prometido - especialmente quando você é membro da Guilda dos Artesãos!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.CraftmensGuild.NPC.answer";
			Text ="Sim, a Guilda dos Artesãos está se preparando para uma viagem.";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.CraftmensGuild.Player.option.join";
