		LocDirectEntry
		{
			Key ="$int.Praise.Audience.1";
			Text ="Ouça, ouça!";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Audience.2";
			Text ="Não posso deixar de concordar com ele...";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Audience.3";
			Text ="É isso que queremos ouvir.";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Audience.4";
			Text ="É bom saber.";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Audience.5";
