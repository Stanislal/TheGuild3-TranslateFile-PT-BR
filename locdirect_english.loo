			Text ="Construtor";
		},
		LocDirectEntry
		{
			Key ="$society.freemasons.motto";
			Text ="Ordem a partir do caos.";
		},
		LocDirectEntry
		{
			Key ="$society.freemasons.name";
			Text ="Guilda dos Maçons";
		},
		LocDirectEntry
		{
			Key ="$society.hussites.desc";
			Text ="Desde tempos imemoriais tem havido esforços para reformar o Ocidente cristão. E desde tempos imemoriais estas aspirações têm sido combatidas pelos seguidores da antiga fé. Antigamente, os Reformados – fossem eles seguidores de Jan Hus, João Calvino ou Martinho Lutero – eram iluministas pacíficos. Mas agora a maioria deles tornou-se tão fanática na sua busca de difundir a verdadeira doutrina como os seus homólogos na igreja.";
		},
		LocDirectEntry
		{
			Key ="$society.hussites.leader";
			Text ="Reformador";
		},
		LocDirectEntry
		{
			Key ="$society.hussites.leader.female";
			Text ="Reformador";
		},
		LocDirectEntry
		{
