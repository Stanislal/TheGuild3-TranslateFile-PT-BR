		},
		LocDirectEntry
		{
			Key ="$action.CraftmensGuildEventDesc";
			Text ="Está em viagem de trabalho para outra cidade.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.end.body";
			Text ="Os artesãos viajantes retornarão em breve. No entanto, os participantes precisam de mais algum tempo para chegar às suas casas.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.character.returns.body";
			Text ="%character% volta para casa do trabalho fora do feudo.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.CraftmensGuild.character.returns.body.female";
			Text ="%character% volta para casa do trabalho fora do feudo.";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.title";
			Text ="A Guilda dos Ladrões está espalhando rumores...";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.title.1";
			Text ="Thieves Guild - um torneio de justa é realizado nas proximidades";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.body.1";
			Text ="Há uma certa inquietação na sociedade obscura: um dos torneios de justas que se tornou raro está acontecendo não muito longe! Nobres e ricos de perto e de longe estarão lá... Esta pode ser a oportunidade que você estava esperando! Se você quiser fazer parte do grupo de viagem, entre em contato com o Mestre do Arsenal! Há rumores de que membros da Guilda dos Ladrões viajarão para lá incógnitos... O evento começará às %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.title.2";
			Text ="Thieves Guild - um dia de igreja é realizado nas proximidades";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.body.2";
			Text ="Há rumores sobre um evento possivelmente lucrativo que acontecerá em uma cidade não muito distante: relíquias sagradas serão expostas e maravilhas serão feitas sob o olhar dos Nobres e ricos! Só de pensar nisso faz seus ouvidos vibrarem... Esta pode ser a oportunidade que você estava esperando! Se você quiser fazer parte do grupo de viagem, entre em contato com o Mestre do Arsenal! Há rumores de que membros da Guilda dos Ladrões viajarão para lá incógnitos... O evento começará às %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.title.3";
			Text ="Thieves Guild - um casamento aristocrático é realizado nas proximidades";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.body.3";
			Text ="Os passarinhos cantam nos telhados que haverá um casamento aristocrático em uma cidade a poucos dias de viagem daqui. Já dá para ouvir o tilintar das moedas... Esta pode ser a oportunidade que você estava esperando! Se você quiser fazer parte do grupo de viagem, entre em contato com o Mestre do Arsenal! Há rumores de que membros da Guilda dos Ladrões viajarão para lá incógnitos... O evento começará às %date%!";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.title.4";
			Text ="Thieves Guild - alivie as malas dos curiosos";
		},
		LocDirectEntry
		{
			Key ="$n.arsenal.event.ThievesGuild.body.4";
			Text ="Há rumores de que o oficial de justiça real de um feudo vizinho quer enforcar sonegadores de impostos na praça do mercado de uma cidade próxima. Um homem misterioso que se autodenomina Robin do Capuz quer resgatar os pobres condenados enquanto alivia as malas dos curiosos. Um ou outro da nossa cidade certamente quer viajar para lá... Esta pode ser a oportunidade que você estava esperando! Se você quiser fazer parte do grupo de viagem, entre em contato com o Mestre do Arsenal! Há rumores de que membros da Guilda dos Ladrões viajarão para lá incógnitos... O evento começará às %date%!";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.ThievesGuild.Player.option.short";
			Text ="Ouvi um boato...";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.ThievesGuild.Player.option";
			Text ="Ouvi falar deste evento não muito longe...";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.ThievesGuild.NPC.answer.positive";
			Text ="Essa informação é confidencial, entendeu?! Naturalmente, não quero saber o que a Guilda dos Ladrões está planejando lá. Tem certeza que deseja viajar para o evento?";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.ThievesGuild.NPC.answer";
			Text ="Sim, um amigo meu tem um amigo que conhece alguém da Guilda dos Ladrões e ela contou a ele... ehm...";
		},
		LocDirectEntry
		{
			Key ="$d.arsenal.event.ThievesGuild.Player.option.join";
			Text ="Eu certamente quero!";
		},
		LocDirectEntry
		{
			Key ="$action.ThievesGuildEvent";
			Text ="Em uma viagem para um evento";
		},
		LocDirectEntry
		{
