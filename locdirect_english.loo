		},
		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.Phew";
			Text ="Ufa, que dia...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.Pretzels";
