			Text ="Ei! Bem vindo de volta!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Believe";
			Text ="Você deve acreditar em mim! Eu não fiz nada de errado!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Easy";
			Text ="As provas apresentadas ao tribunal superior facilitaram a decisão: o acusado é culpado!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Enough";
			Text ="Não há necessidade de dizer mais nada, já ouvimos o suficiente!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Flimsy";
			Text ="Parece que essas acusações são bastante frágeis. Portanto, você deve compreender que não podemos dar um veredicto severo.";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.God";
			Text ="Deus é o único que pode fazer justiça!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Guilty";
			Text ="É com grande pesar que o tribunal superior deve declarar o acusado culpado!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Happy";
			Text ="O tribunal superior tem o prazer de absolver o acusado de qualquer culpa neste assunto!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Imbeciles";
			Text ="Vocês são todos imbecis!";
