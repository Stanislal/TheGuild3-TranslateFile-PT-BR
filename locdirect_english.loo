		},
		LocDirectEntry
		{
			Key ="$notification.InitiateIntrigue.Success.Body";
			Text ="Você perdeu parte de sua influência devido a uma intriga maliciosa nas camadas superiores da sociedade. Você não sabe quem estava conspirando contra você, exceto que deve ter sido um protestante!";
		},
		LocDirectEntry
		{
			Key ="$notification.InitiateIntrigue.Failure.Body";
			Text ="O malicioso protestante %CharacterSource% fez uma tentativa fraca de conspirar contra você entre os níveis mais elevados da sociedade da cidade. Mas falhou!";
		},
		LocDirectEntry
		{
			Key ="$notification.InitiateIntrigue.Failure.Body.female";
			Text ="O malicioso protestante %CharacterSource% fez uma tentativa fraca de conspirar contra você entre os níveis mais elevados da sociedade da cidade. Mas falhou!";
