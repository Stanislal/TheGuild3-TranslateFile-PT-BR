		LocDirectEntry
		{
			Key ="$profession.Barber.female";
			Text ="Barbeiro";
		},
		LocDirectEntry
		{
			Key ="$profession.BarberDesc";
			Text ="Barbeiros são extratores de dentes, cortadores de cabelo e fornecedores de banhos populares. Mas há rumores de que as pessoas se comportam de maneira imoral na banheira de hidromassagem, então tome muito cuidado...";
