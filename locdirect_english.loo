		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.Guy";
			Text ="Olha aquele cara ali...";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.Innkeeper";
