			Text ="Obrigado.";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Victim.6";
			Text ="Esperei muito tempo por esse elogio...";
		},
		LocDirectEntry
		{
			Key ="$int.Praise.Victim.7";
			Text ="Você sempre pode confiar em mim.";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.0";
			Text ="Como pode a família %name% cheirar tão mal e ainda assim sobreviver?";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.0.narration";
			Text ="Como alguém pode cheirar tão mal e ainda assim sobreviver?";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.1";
			Text ="Eu certamente baniria a família %name% da minha casa, se não estivéssemos tão maravilhosamente entretidos com toda a sua falta de jeito...";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.1.narration";
			Text ="Eu certamente baniria esta família da minha casa, se não estivéssemos tão maravilhosamente entretidos com toda a sua falta de jeito...";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.2";
			Text ="Eles estão sempre enchendo e depois se recusam a pagar - alguém deveria levar a família %name% ao tribunal por não pagar suas contas!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.2.narration";
			Text ="Eles estão sempre enchendo e depois se recusam a pagar - alguém deveria levar essa família ao tribunal por não pagar suas contas!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.3";
			Text ="Você é o mais querido de todos os meus convidados. Muito diferente desta família fedorenta %name%!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.3.narration";
			Text ="Você é o mais querido de todos os meus convidados. Muito diferente desta família fedorenta!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.4";
			Text ="Até a bebida de Guntram seria boa demais para a família %name%... mesmo que essa cerveja horrível provavelmente tivesse gosto de néctar para eles!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.4.narration";
			Text ="Até a bebida de Guntram seria boa demais para esta família... mesmo que esta cerveja horrível provavelmente tivesse gosto de néctar para eles!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.5";
			Text ="Gosto do seu pacote desorganizado mil vezes mais do que da família %name% - eles caem depois de apenas uma cerveja fraca.";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.5.narration";
			Text ="Gosto do seu pacote desorganizado mil vezes mais do que desta família - eles caem depois de apenas uma cerveja fraca.";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.6";
			Text ="Amigos, quando foi a última vez que vocês viram alguém da família %name% aqui? Isso mesmo, nunca! Suponho que não somos bons o suficiente para eles!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.6.narration";
			Text ="Amigos, quando foi a última vez que vocês viram alguém desta família aqui? Isso mesmo, nunca! Suponho que não somos bons o suficiente para eles!";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.7";
			Text ="Ouvi dizer que a família %name% não bebe cerveja... Eles provavelmente são chiques demais para um simples suco de cevada, né?";
		},
		LocDirectEntry
		{
			Key ="$int.Smear.7.narration";
			Text ="Ouvi dizer que essa família não bebe cerveja... Eles provavelmente são chiques demais para um simples suco de cevada, né?";
		},
		LocDirectEntry
		{
			Key ="$International";
			Text ="Viajantes de longa distância";
		},
		LocDirectEntry
		{
			Key ="$InternationalDesc";
			Text ="Você não quer apenas conhecer sua própria cidade e as poucas vilas ao seu redor, você quer ver o mundo - pois no final das contas, conhecimento é poder e é isso que o separa das massas! Mas você mesmo infelizmente é indispensável, porém pode mandar um parente ou um funcionário sair para saciar sua sede de conhecimento.";
		},
		LocDirectEntry
		{
			Key ="$Investigation";
			Text ="Espionagem";
		},
		LocDirectEntry
		{
			Key ="$InvestigationDesc";
			Text ="Esta habilidade permite que aqueles com habilidade espionem outras pessoas. Em níveis mais altos, um \"spy lodge\" can be built and spies hired who can then make enquiries for its owner or on behalf of others.";
		},
		LocDirectEntry
		{
			Key ="$Iron";
			Text ="Ferro";
		},
		LocDirectEntry
		{
			Key ="$IronBrachelet";
			Text ="Braçadeiras de ferro";
		},
		LocDirectEntry
		{
			Key ="$IronBracheletDesc";
			Text ="Braçadeiras de ferro são usadas para proteger os braços de cortes e estocadas prejudiciais em batalha.";
		},
		LocDirectEntry
		{
			Key ="$IronDesc";
			Text ="O ferro é obtido do minério de ferro. É o metal mais estável que conhecemos. Muitos utensílios úteis são feitos de ferro, incluindo armas e armaduras.";
		},
		LocDirectEntry
		{
			Key ="$Ivory";
			Text ="Marfim";
		},
		LocDirectEntry
		{
			Key ="$IvoryDesc";
			Text ="Já nos primeiros tempos pagãos, o marfim era usado em joias e outros artefatos. A palavra marfim vem da palavra egípcia antiga 'âb, âbu' (elefante), através do latim ebor- ou ebur. Mas os elefantes que outrora viveram na Europa Ocidental foram extintos muito antes do nosso tempo, por isso as presas dos elefantes tiveram de ser importadas de terras distantes, ou usaram o chifre muito mais valioso e ainda mais duro do narval do Árctico...";
		},
		LocDirectEntry
		{
			Key ="$Jasmin";
			Text ="Jasmim";
		},
		LocDirectEntry
		{
			Key ="$JasminDesc";
			Text ="O extrato dessas flores brancas maravilhosamente perfumadas não é usado apenas como ingrediente em perfumes, mas também em outras receitas alquímicas.";
		},
		LocDirectEntry
		{
			Key ="$Lavender";
			Text ="Lavanda";
		},
		LocDirectEntry
		{
			Key ="$LavenderDesc";
			Text ="Embora a lavanda seja elogiada por suas propriedades como planta curativa, ela também é usada como ingrediente em aromas perfumados.";
		},
		LocDirectEntry
		{
			Key ="$Leather";
			Text ="Couro";
		},
		LocDirectEntry
		{
			Key ="$LeatherArmor";
			Text ="Armadura de couro";
		},
		LocDirectEntry
		{
			Key ="$LeatherArmorDesc";
			Text ="Esta armadura leve de couro oferece proteção mínima para o corpo do usuário.";
		},
		LocDirectEntry
		{
			Key ="$LeatherDesc";
			Text ="O couro é fabricado a partir da pele de uma vaca abatida. Primeiro, a carne e os pelos são removidos da pele, que é então completamente limpa e finalmente tornada durável e impermeável com sal e outros minerais. Isso é chamado de bronzeamento.";
		},
		LocDirectEntry
		{
			Key ="$LeatherGloves";
			Text ="Luvas de couro";
		},
		LocDirectEntry
		{
			Key ="$LeatherGlovesDesc";
			Text ="Luvas de couro protegem as mãos do usuário.";
		},
		LocDirectEntry
		{
			Key ="$LeaveOffice";
			Text ="Sair do escritório";
		},
		LocDirectEntry
		{
			Key ="$LeaveOffice.Action";
			Text ="%character% saiu do escritório %office%.";
		},
		LocDirectEntry
		{
			Key ="$LeaveOfficeDesc";
			Text ="Isso permite que você deixe o cargo e tenha um emprego remunerado em outra profissão.";
		},
		LocDirectEntry
		{
			Key ="$Linen";
			Text ="Linho";
		},
		LocDirectEntry
		{
			Key ="$LinenDesc";
			Text ="O linho é um fio obtido a partir de caules de plantas. É mais robusto que a lã, mas menos confortável de usar.";
		},
		LocDirectEntry
		{
			Key ="$Longsword";
			Text ="Espada Longa";
		},
		LocDirectEntry
		{
			Key ="$LongswordDesc";
			Text ="Por muitos séculos a espada longa foi reservada exclusivamente para a nobreza e sua comitiva. No entanto, com a chegada da nova era, tornou-se a arma preferida também das pessoas simples - pelo menos daqueles que podem pagar por ela.";
		},
		LocDirectEntry
		{
			Key ="$LuckyStone";
			Text ="Pedra da sorte";
		},
		LocDirectEntry
		{
			Key ="$LuckyStoneDesc";
			Text ="Diz-se que estas pedras trazem boa sorte. É claro que não há evidências disso, mas muitas pessoas estão convencidas de que com uma pedra da sorte todos os seus empreendimentos terão mais sucesso...";
		},
		LocDirectEntry
		{
			Key ="$Mace";
			Text ="Mace";
		},
		LocDirectEntry
		{
			Key ="$MaceDesc";
			Text ="A maça é uma arma poderosa e temida, que pode causar ferimentos terríveis.";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.difficulty.easy";
			Text ="O nível de dificuldade do seu jogo é \"easy\". This gives you some advantages against the AI players.";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.difficulty.hard";
			Text ="Você escolheu o \"hard\" difficulty level. Respect! It will now be harder for you to gain power and influence, but still not impossible.";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.difficulty.impossible";
			Text ="Você escolheu jogar um \"impossible\" game - good luck, you'll need it!";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.difficulty.normal";
			Text ="Você escolheu o \"normal\" difficulty level. Starting the game will be slightly easier for you until you reach the rank of \"citizen\".";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.dynasty";
			Text ="Seu personagem inicial – seu avatar – envelhecerá durante o jogo, então você deverá se casar e ter filhos, para que seus herdeiros possam continuar o jogo.";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.gamemode.career";
			Text ="Na sua juventude, você foi treinado em uma profissão, então você começa com algumas habilidades e habilidades inestimáveis. Use-os para dar os primeiros passos no caminho do cumprimento da lei ou do crime - você decide!";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.gamemode.poorfellow";
			Text ="Você decidiu assumir o papel de um personagem bastante pobre e inexperiente, que chegou aos portões da cidade há poucos dias. Você terá que trabalhar duro para conquistar os direitos de cidadão que lhe permitirão viver e trabalhar na cidade.";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.gamemode.scenariodependent";
			Text ="Suas condições iniciais dependem da dinastia que você escolheu para jogar neste cenário. Em cenários históricos você pode até se colocar no lugar de uma dinastia que realmente existia na época.";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.story.sandbox";
			Text ="Você está jogando sem campanha familiar, o que permite que você se concentre exclusivamente em si mesmo e no avanço de sua dinastia!!";
		},
		LocDirectEntry
		{
			Key ="$mapStart.narration.welcome";
			Text ="Bem-vindo ao The Guild 3, uma simulação econômica e RPG ambientado no final da Idade Média. Você assume o papel de pessoa nesse cenário histórico, mas não é apenas parte dele, você pode escrever sua própria história de sucesso!";
		},
		LocDirectEntry
		{
			Key ="$MasterOfTheSlideRule";
			Text ="Mestre da régua de cálculo";
		},
		LocDirectEntry
		{
			Key ="$MasterOfTheSlideRuleDesc";
			Text ="Você é um especialista em régua de cálculo e pode fazer muitos cálculos até mesmo de cabeça. Isso permitirá que você planeje com mais eficiência as etapas do seu trabalho com antecedência, se você for o responsável por isso, é claro.";
		},
		LocDirectEntry
		{
			Key ="$Math";
			Text ="Senso comercial";
		},
		LocDirectEntry
		{
			Key ="$MathDesc";
			Text ="Esta habilidade inclui não apenas a apuração correta de lucros e perdas, mas também permite que os qualificados subornem secretamente os tomadores de decisão na Câmara Municipal e nos tribunais.";
		},
		LocDirectEntry
		{
			Key ="$Mead";
			Text ="Hidromel";
		},
		LocDirectEntry
		{
			Key ="$MeadDesc";
			Text ="Este elixir dos Deuses de tempos passados ainda é altamente valorizado hoje devido aos seus poderes de cura e ao seu tão cobiçado \"divine\" rush. Hot mead is the very best medicine, especially for influenza!";
		},
		LocDirectEntry
		{
			Key ="$Medecine";
			Text ="Medicina";
		},
		LocDirectEntry
		{
			Key ="$MedecineDesc";
			Text ="O estudo da medicina é caro e demorado. No entanto, não só permite curar pessoas, mas também encher os bolsos com muitas moedas lindas e tilintantes.";
		},
		LocDirectEntry
		{
			Key ="$message.AreYouSure";
			Text ="Tem certeza que deseja realizar \"%actionName%\"?";
		},
		LocDirectEntry
		{
			Key ="$message.AreYouSureCancelAction";
			Text ="Deseja que %actorName% aborte \"%actionName%\" to start another task?";
		},
		LocDirectEntry
		{
			Key ="$message.AreYouSureToDoAction.RequirementsMissing";
			Text ="Aviso: Você não pode usar o edifício %buildingName%!\n\nRequisitos faltantes:\n%reasons%\n\nTem certeza que deseja realizar a ação %actionName%?";
		},
		LocDirectEntry
		{
