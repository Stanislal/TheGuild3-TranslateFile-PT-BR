		},
		LocDirectEntry
		{
			Key ="$DistractEveryoneDesc";
			Text ="As pessoas justas agarram-se firmemente às suas bolsas. Esses avarentos! Mas você sabe como mudar isso. Para desviar a atenção deles, fique no lugar mais central possível e chame a multidão com uma voz estrondosa: \"Oh my God, you can't go around without clothes and exhibit your lithe body! Help, can't anyone help? - Uh, I mean... fire, fire!\"";
		},
		LocDirectEntry
		{
			Key ="$statusEffect.Distracted";
