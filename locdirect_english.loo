			Key ="$RoastVenisonDesc";
			Text ="A carne de veado assada é uma refeição muito saborosa, particularmente popular na alta sociedade. Não deveria faltar em nenhum banquete adequado.";
		},
		LocDirectEntry
		{
			Key ="$HoldPublicPrayer";
