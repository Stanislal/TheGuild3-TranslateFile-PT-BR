		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.AroundHere";
			Text ="Então, o que está acontecendo aqui?";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.Drink";
			Text ="Ah, finalmente! Algo para beber!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.TavernTalk.Girl";
			Text ="Olha aquela garota ali...";
