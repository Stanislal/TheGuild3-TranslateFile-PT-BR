			Text ="Proteção, abrigo e fé!";
		},
		LocDirectEntry
		{
			Key ="$society.knightsorder.name";
			Text ="Guilda dos Cavaleiros Livres";
		},
		LocDirectEntry
		{
			Key ="$society.lansquenetbrotherhood.desc";
			Text ="Esta irmandade foi fundada por lansquenets que voltavam da guerra. Os horrores dos combates criaram laços fortes entre estes veteranos. A irmandade protege todos os seus membros, e quem tem ligação com um membro da irmandade tem ligação com todos eles!";
		},
		LocDirectEntry
		{
