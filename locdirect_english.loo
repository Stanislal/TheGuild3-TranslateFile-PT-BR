		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v4.str";
			Text ="A paciência dos nossos cidadãos tem limites e você os ultrapassou. %CharacterTarget%, eu declaro você um fora da lei!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v4.str";
			Text ="Você está realmente certo. Aceito meu castigo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v4.str";
			Text ="Quais limites? O que você está falando? Por favor, não faça isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v4.str";
			Text ="Eu também tenho meus limites e você os está ultrapassando agora. Deixe-me em paz.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v4.str";
			Text ="Eu me pergunto quanta paciência eles terão com alguém que mente e abusa de seu cargo? Pare com essa tolice.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v4.char";
			Text ="Você não respeita a lei...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v4.char";
			Text ="A única maneira de ensinar você a respeitar nossas leis é mostrar-lhe o mundo sem elas. Estou marcando você como um fora-da-lei!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v4.char";
			Text ="Qualquer coisa menos isso! Não há necessidade de fazer isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v4.char";
			Text ="Todos podem agir por estupidez. Eu imploro, por favor reconsidere sua decisão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v4.char";
			Text ="Você é a última pessoa que tem o direito de me dar um sermão sobre respeito. Você não tem respeito por nada nem por ninguém.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v4.char";
			Text ="Estou muito emocionado com o seu discurso, mas não estou nem aí. Tenha um bom dia.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v4.dex";
			Text ="Chegou a hora de te dar uma lição...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v4.dex";
			Text ="Seus atos infames são bem conhecidos. Mas chegou a hora de lhe dar uma lição e vou condená-lo ao ostracismo!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v4.dex";
			Text ="O que posso fazer para mudar sua opinião? Diga-me, eu imploro!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v4.dex";
			Text ="Isso é totalmente desnecessário, por favor... eu entendi.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v4.dex";
			Text ="A única coisa que você poderia me ensinar é como fingir ser importante, quando na verdade você está sendo ignorado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v4.dex";
			Text ="Que tal eu te ensinar uma lição? Tenho dois grandes professores: meu punho direito e meu punho esquerdo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v5.str";
			Text ="Nossa cidade não tolerará mais seu comportamento!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v5.str.toMale";
			Text ="Pelo poder investido em mim por lei, declaro %CharacterTarget% um fora da lei. Nossa cidade não tolerará seu comportamento!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v5.str.toFemale";
			Text ="Pelo poder investido em mim por lei, declaro %CharacterTarget% um fora da lei. Nossa cidade não tolerará seu comportamento!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v5.str";
			Text ="Por favor, me dê uma última chance!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v5.str";
			Text ="O que vou fazer agora? Preciso procurar um capanga...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v5.str";
			Text ="Nem estou mais disposto a tolerar sua tolice! Afaste-se!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v5.str";
			Text ="Esse foi um discurso realmente apaixonante; infelizmente ninguém parece estar interessado. Desejo-lhe bom dia!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v5.char";
			Text ="Seus atos maliciosos são terríveis demais...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v5.char";
			Text ="Estou marcando você como um fora da lei. O incidente em que você esteve envolvido é horrível demais para ser falado publicamente!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v5.char";
			Text ="Na verdade, é melhor não falarmos sobre isso. Eu aceito minha punição.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v5.char";
			Text ="O resultado não era previsível, como eu poderia saber disso? Só aconteceu uma vez!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v5.char";
			Text ="Sinta-se à vontade para contar a todos sobre meus supostos crimes, mas ninguém acreditará em suas mentiras. Vá para casa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v5.char";
			Text ="Você esqueceu que a ideia foi SUA? Seria melhor que ambos ficassem calados. Vá embora!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.openLine.v5.dex";
			Text ="Seus atos mancharam o nome de sua família...";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fullLine.v5.dex";
			Text ="%CharacterTarget%, seus atos mancharam a reputação de sua dinastia. É por isso que estou declarando você um fora da lei.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.csAnswer.v5.dex";
			Text ="Eu imploro! Somos todos pecadores, mas também merecemos perdão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.sAnswer.v5.dex";
			Text ="Não entendo, deve ser um erro! Você vai pagar por isso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.fAnswer.v5.dex";
			Text ="Meu nome está tão desonrado quanto o seu, não vou tirar nenhuma lição de moralidade de você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.markOutlaw.cfAnswer.v5.dex";
			Text ="Essa foi uma conversa interessante, porém, tenho COISAS para fazer. Eu recomendo que você faça algo produtivo também.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v2.int_rp";
			Text ="Gosto de pessoas que pagam suas dívidas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v2.int_rp";
			Text ="Que este presente seja uma expressão da minha gratidão pelo seu trabalho árduo! Gosto de ajudar as pessoas que pagam suas dívidas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v2.int_rp";
			Text ="Ninguém nesta cidade sabe como retribuir um favor melhor do que eu.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v2.int_rp";
			Text ="Agradeço sua gratidão. Farei tudo que estiver ao meu alcance para apoiar sua causa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v2.int_rp";
			Text ="Obrigado. Mas infelizmente não poderei aceitar sua oferta.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v2.int_rp";
			Text ="A honestidade é um aspecto importante da minha posição. Nunca mais quero ouvir esse tipo de sugestão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v2.intim_rp";
			Text ="Vamos conversar em segredo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v2.intim_rp";
			Text ="A linguagem do ouro silencia todas as línguas. Então deixe-me \"speak\" to you, and keep quiet about our agreement.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v2.intim_rp";
			Text ="Um dos meus deveres é ouvir a opinião dos outros. De qualquer forma, não tenho muito a dizer. Eu prometo ficar quieto.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v2.intim_rp";
			Text ="Embora eu mesmo goste de falar, também gosto de ouvir a voz do ouro. Ficarei em silêncio por enquanto.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v2.intim_rp.male";
			Text ="Falar é uma das funções do titular de um cargo. Então faça o ouro calar a boca - estou falando agora!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v2.intim_rp.female";
			Text ="Falar é uma das funções do titular de um cargo. Então faça o ouro calar a boca - estou falando agora!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v2.intim_rp";
			Text ="Não estou interessado em ouvir bobagens, seja de você ou do seu ouro. Afaste-se!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v2.char_rp";
			Text ="Vamos jogar um jogo de adivinhação?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v2.char_rp";
			Text ="Deixe-me adivinhar o que você tem no bolso; algo brilhante e dourado que você goste. Se eu estiver certo, você me deve alguma coisa!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v2.char_rp";
			Text ="Na verdade, isso está correto. Não tenho ideia de como essas moedas apareceram no meu bolso. Eu lhe devo uma coisa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v2.char_rp";
			Text ="Isso é um milagre! Uma sacola cheia de moedas acaba de aparecer no meu bolso. O que posso fazer para você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v2.char_rp";
			Text ="Não aceito subornos. Experimente esse truque com outra pessoa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v2.char_rp";
			Text ="Que tipo de truque de mágica é esse! Definitivamente, uma penalidade deveria ser imposta pela prática das artes das trevas!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v3.int_rp";
			Text ="Ouro solta línguas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v3.int_rp";
			Text ="Ouvi uma vez que o ouro ajuda a soltar as línguas. Você concordaria comigo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v3.int_rp";
			Text ="A quantidade certa de ouro pode fazer maravilhas. Sou todo ouvidos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v3.int_rp";
			Text ="Isso iria soltar MINHA língua com certeza. O que você exigiria em troca?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v3.int_rp";
			Text ="Eu não aceito subornos. Tente outra pessoa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v3.int_rp";
			Text ="Todo o ouro do mundo não soltaria minha língua por VOCÊ.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v3.intim_rp";
			Text ="Como resolveremos meu problema?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v3.intim_rp";
			Text ="Como resolveremos meu problema? De maneira fácil e pavimentada com moedas de ouro ou por um caminho mais difícil? A escolha é sua.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v3.intim_rp";
			Text ="Por que se esforçar quando você também pode relaxar?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v3.intim_rp";
			Text ="There's only one right answer to this dilemma: I choose the easy way.
";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v3.intim_rp";
			Text ="Isso parece mais uma ameaça do que uma oferta, e não gosto de ameaças.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v3.intim_rp";
			Text ="Esta é a tentativa de suborno mais desrespeitosa que já recebi! Afaste-se!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v3.char_rp";
			Text ="Este saco de moedas estava caído no chão...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v3.char_rp";
			Text ="Olha o que acabei de encontrar caído no chão. Acho que esse saco de moedas brilhantes pertence a você, correto?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v3.char_rp";
			Text ="Na verdade, parece minha bolsa! Como posso demonstrar minha gratidão?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v3.char_rp";
			Text ="Sim, pode mesmo ser minha bolsa. Deixe-me saber como posso ajudá-lo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v3.char_rp";
			Text ="Esta é a nova forma de oferecer subornos? Eu não estou interessado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v3.char_rp";
			Text ="Isto foi uma tentativa de me subornar? Espero que não! Adeus!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v4.int_rp";
			Text ="Este presente irá ajudá-lo a decidir...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v4.int_rp.toMale";
			Text ="Um titular de um cargo público tem que tomar decisões difíceis. Espero que meu presente torne esse processo mais fácil para você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v4.int_rp.toFemale";
			Text ="Um titular de um cargo público tem que tomar decisões difíceis. Espero que meu presente torne esse processo mais fácil para você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v4.int_rp";
			Text ="Na verdade, acho que isso será muito útil. Obrigado!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v4.int_rp";
			Text ="Este presente poderia realmente me ajudar na tomada de decisões durante minha gestão. Muito obrigado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v4.int_rp";
			Text ="Isto é uma tentativa de suborno? Não seria certo aceitá-lo. Tomo minhas decisões com a mente livre e aberta.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v4.int_rp";
			Text ="Sim, este presente me ajudará a tomar a decisão certa - uma decisão contra você! Estou acima de aceitar subornos!";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v4.intim_rp.toMale";
			Text ="Você é um amigo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v4.intim_rp.toFemale";
			Text ="Você é um amigo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v4.intim_rp.toMale";
			Text ="Você gostaria de ser meu amigo rico e longevo ou um obstáculo que terei que remover o mais rápido possível?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v4.intim_rp.toFemale";
			Text ="Você gostaria de ser meu amigo rico e longevo ou um obstáculo que terei que remover o mais rápido possível?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v4.intim_rp.tomale";
			Text ="Meu querido amigo! Estou muito feliz que você esteja pensando em falar comigo. O que posso fazer por você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v4.intim_rp.tofemale";
			Text ="Meu querido amigo! Estou muito feliz que você esteja pensando em falar comigo. O que posso fazer por você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v4.intim_rp.tomale";
			Text ="Dada a situação, não tenho escolha a não ser ajudá-lo, meu amigo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v4.intim_rp.tofemale";
			Text ="Dada a situação, não tenho escolha a não ser ajudá-lo, meu amigo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v4.char_rp";
			Text ="O que você está escondendo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v4.char_rp";
			Text ="O que você está escondendo? Oh, um saco de moedas! Eu encontrei para você, agora você também faria algo por mim?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v4.char_rp";
			Text ="Incrível! Este é um truque tão engraçado! O que posso fazer para você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v4.char_rp";
			Text ="Bem, bem! Eu estava procurando essa bolsa. Claro que vou te ajudar, basta me dizer o que você precisa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v4.char_rp";
			Text ="Não é minha bolsa e não devo nada a você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v4.char_rp";
			Text ="Esta é realmente a melhor maneira que você pode imaginar para tentar me subornar? Patético.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v5.int_rp";
			Text ="A renda dos titulares de cargos é baixa...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v5.int_rp";
			Text ="Como o salário dos titulares de cargos é baixo, aceite minha ajuda. Deveríamos apoiar uns aos outros, você não acha?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v5.int_rp";
			Text ="Na verdade, os titulares de cargos públicos são pessoas pobres. Obrigado pelo seu apoio. O que posso fazer para você?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v5.int_rp";
			Text ="Ninguém aprecia o trabalho que fazemos... Obrigado, o que você precisa?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v5.int_rp";
			Text ="Não espero mais do que o salário oficial que recebo do tesouro estadual. Um pequeno presente não é necessário.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v5.int_rp";
			Text ="Não me candidatei a este cargo por dinheiro, mas por poder. Adeus.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v5.intim_rp.toMale";
			Text ="Melhor ter um amigo na corte...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v5.intim_rp.toFemale";
			Text ="Melhor ter um amigo na corte...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v5.intim_rp.toMale";
			Text ="Melhor ter um amigo na corte. Se eu te der esse ouro, você será meu amigo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v5.intim_rp.toFemale";
			Text ="Melhor ter um amigo na corte. Se eu te der esse ouro, você será meu amigo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v5.intim_rp.male";
			Text ="Um aperto de mão dourado convence até o juiz mais cético. Vou apertar sua mão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v5.intim_rp.female";
			Text ="Um aperto de mão dourado convence até o juiz mais cético. Vou apertar sua mão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v5.intim_rp";
			Text ="Você reconheceu o valor da minha amizade, aceito de bom grado este presente para selar nosso vínculo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v5.intim_rp";
			Text ="Você tem ouro na mão, mas o silêncio às vezes é ouro. Então fique quieto, a amizade não se compra.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v5.intim_rp";
			Text ="Nem tudo que reluz é ouro, como minha honra. Uma boa reputação é mais importante para mim do que uma aparência brilhante.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.openLine.v5.char_rp";
			Text ="Sua bolsa agora está mais pesada...";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fullLine.v5.char_rp";
			Text ="Você sente que sua bolsa está mais pesada? Eu fiz isso com meus truques, então agora você vai fazer alguns truques para mim?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.csAnswer.v5.char_rp";
			Text ="Adoro truques assim! Claro que vou te ajudar, qual é o seu desejo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.sAnswer.v5.char_rp";
			Text ="Interessante, como isso aconteceu? De qualquer forma, agora vou pegar a sacola de truques para você também.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.fAnswer.v5.char_rp";
			Text ="Sim... Mas não é pesado o suficiente. Adeus.";
		},
		LocDirectEntry
		{
			Key ="$d.act.bribeOff.cfAnswer.v5.char_rp";
			Text ="Bruxaria! Magia negra! Vá embora! Deixe-me em paz!";
		},
		LocDirectEntry
		{
			Key ="$d.act.AwardKeyToCity.openLine.v2.int";
			Text ="A Câmara Municipal agradece o seu trabalho árduo...";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v2.int";
			Text ="Estou lhe apresentando a chave da cidade como um símbolo de nossa apreciação pelo seu trabalho árduo por esta cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.sAnswer.v2.int";
			Text ="Trabalhei muito para receber esta chave. Estou grato por você ter reconhecido meus esforços.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fAnswer.v2.int";
			Text ="Eu aceitaria qualquer coisa sua; até mesmo uma honra.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.openLine.v2.intim";
			Text ="Sua lealdade merece algum reconhecimento...";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v2.intim";
			Text ="Sua lealdade à nossa cidade merece algum reconhecimento. Estou presenteando vocês com estas chaves ornamentais da cidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.sAnswer.v2.intim";
			Text ="Para ser sincero, eu esperava isso. Estou verdadeiramente emocionado com esta honra.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fAnswer.v2.intim";
			Text ="Não sou tão ingênuo a ponto de acreditar em você! Não faça piadas tão estúpidas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.openLine.v2.rb";
			Text ="A sociedade lhe deve muito...";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v2.rb";
			Text ="A sociedade deve muito a você pelo seu apoio. Por favor, aceite esta chave da cidade como um símbolo da nossa gratidão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.sAnswer.v2.rb";
			Text ="Obrigado por este prêmio. Não vou decepcionar a confiança que todos depositaram em mim.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fAnswer.v2.rb";
			Text ="E o que devo fazer com essa chave? Não, obrigado.";
