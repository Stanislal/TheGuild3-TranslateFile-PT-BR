		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v1.bb_intim";
			Text ="Parece um mundo ideal!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v1.bb_intim";
			Text ="A secularidade parece ser uma questão de viver sem Deus! É impensável!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v2.int_intim";
			Text ="Combinar religião e política é impensável.";
