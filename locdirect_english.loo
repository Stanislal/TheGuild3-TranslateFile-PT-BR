		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.BuySkill1";
			Text ="Para desbloquear novos edifícios e produzir novos itens, você precisa desbloquear novas habilidades.\n\n1. Clique no ícone Árvore de habilidades.\n\n2. Selecione a aba Artesanato.\n\n3. Desbloqueie a habilidade Crude Craftsman 2 e a habilidade Metalworking 1 (esta última requer o título Cidadão).\n\n4. Escolha a guia Habilidades sociais.\n\n5. Desbloqueie a habilidade Ambicioso 1.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.BuySkill.Title";
