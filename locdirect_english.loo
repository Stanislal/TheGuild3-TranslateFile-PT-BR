		LocDirectEntry
		{
			Key ="$Scholarly";
			Text ="Escriba";
		},
		LocDirectEntry
		{
			Key ="$ScholarlyDesc";
			Text ="Você sabe copiar e criar novos documentos. Além disso, você também pode misturar as melhores cores e fabricar os melhores papéis para seus cobiçados livros. Isso permite que você possua e opere empresas de escriba.";
		},
		LocDirectEntry
		{
			Key ="$season0";
			Text ="Inverno";
		},
		LocDirectEntry
		{
			Key ="$season1";
			Text ="Primavera";
		},
		LocDirectEntry
		{
			Key ="$season2";
