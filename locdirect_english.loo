		LocDirectEntry
		{
			Key ="$Cutscenes.Medicus.OhRight";
			Text ="Ah, certo, tem algo acontecendo na sua vizinhança. Não se preocupe, tenho o remédio certo para você.";
		},
		LocDirectEntry
		{
