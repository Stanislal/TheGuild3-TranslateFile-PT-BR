		LocDirectEntry
		{
			Key ="$GemstoneDesc";
			Text ="Uma bela joia que reflete a luz em uma variedade de cores e que é usada principalmente em joias caras. Alguns afirmam que podem evocar certos poderes das joias, mas isso deve ser pura superstição...";
		},
		LocDirectEntry
