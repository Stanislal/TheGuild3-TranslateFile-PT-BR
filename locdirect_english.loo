			Text ="Capataz";
		},
		LocDirectEntry
		{
			Key ="$TaskmasterDesc";
			Text ="Você é um mestre em seu ofício como nenhum outro, mas permaneceu no nível mais baixo, então não tenha medo de mostrar aos seus funcionários a melhor forma de trabalhar.";
		},
		LocDirectEntry
		{
			Key ="$ToadExcrements";
			Text ="Suco de pragas de Megenberg";
		},
		LocDirectEntry
		{
			Key ="$ToadExcrementsDesc";
			Text ="Konrad von Megenberg desenvolveu originalmente este remédio para manter as pragas afastadas, mas acabou tendo precisamente o efeito oposto! Então, basta colocar um pouco dentro e ao redor do prédio de um concorrente para atrair todos os vermes da área, que irão infestar o prédio e causar estragos, de modo que a loja da frente atraia menos clientes e o próprio prédio fique constantemente comprometido!";
		},
		LocDirectEntry
		{
			Key ="$ToadSlime";
			Text ="Lodo de sapo";
		},
		LocDirectEntry
		{
			Key ="$ToadSlimeDesc";
			Text ="Este lodo nojento e altamente infeccioso está espalhado na maçaneta da porta de um prédio. Todos os que trabalham naquele edifício sofrerão de uma doença misteriosa que minará as suas forças durante algum tempo e, portanto, trabalharão mais lentamente.";
		},
