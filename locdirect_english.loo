		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Incompetence";
			Text ="Nunca vi tanta incompetência!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Judgement";
			Text ="Tendo ouvido todas as evidências, agora estamos prontos para julgar!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Order";
			Text ="Pedido! Ordem!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.People";
			Text ="As pessoas próximas a mim sabem que meu coração é puro. Eu não fiz nada de errado!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Ridiculous";
			Text ="Esta acusação ridícula é simplesmente uma perda de seu precioso tempo, meritíssimo!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Rogue";
			Text ="Qualquer ladino tem um senso de justiça melhor que você!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Shaky";
			Text ="Parece que essas acusações são bastante instáveis. Estamos prontos para dar nosso veredicto.";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.TheCourt";
			Text ="O tribunal ouvirá agora o réu.";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Travesty";
			Text ="Isso é uma farsa de justiça!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Unfortunately";
			Text ="Infelizmente, o tribunal superior deve considerar que as provas apresentadas são insuficientes para uma condenação.";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Trial.Upstanding";
			Text ="Você me conhece como o cidadão íntegro que sou! Você realmente acredita nessas acusações absurdas?";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.Aaaahh";
			Text ="Aaahh!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.Boohooo";
			Text ="Boohoo!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.Boooo";
			Text ="Booo!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.FrontofGod";
			Text ="Diante de Deus e do povo desta igreja, nos reunimos hoje para unir em matrimônio este homem e esta mulher - que eles tenham filhos saudáveis ​​e uma longa vida juntos!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.Honored";
			Text ="Estamos todos honrados por estar aqui hoje, na presença de Deus, para testemunhar a união destas duas grandes casas no sagrado matrimônio. Que eles permaneçam fortes, tenham filhos e continuem a ser exemplos brilhantes do temor de Deus e da justiça para todos nós!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.Hooray";
			Text ="Viva!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.MyPleasure";
			Text ="É um prazer juntar-me a estes excelentes cidadãos no santíssimo dos sacramentos e, na presença de Deus, abençoar a sua sagrada união como marido e mulher!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.Noooo";
			Text ="Não!";
		},
		LocDirectEntry
		{
			Key ="$Cutscenes.Wedding.Wedding.Oooohhh";
			Text ="Ahhh!";
		},
		LocDirectEntry
		{
			Key ="$Dagger";
			Text ="Adaga";
		},
		LocDirectEntry
		{
			Key ="$DaggerDesc";
			Text ="A adaga é uma arma muito popular. É prático, fácil de esconder e desenhado rapidamente em caso de perigo.";
		},
		LocDirectEntry
		{
			Key ="$DartagnansFragrance";
			Text ="Fragrância de Dartagnan";
		},
		LocDirectEntry
		{
			Key ="$DartagnansFragranceDesc";
			Text ="Se você usar esta fragrância, você receberá a aura de um mestre esgrimista. Então, quem ousará desafiá-lo?";
		},
		LocDirectEntry
		{
			Key ="$Diamond";
			Text ="Diamante";
		},
		LocDirectEntry
		{
			Key ="$DiamondDesc";
			Text ="Ah, como brilha...";
		},
		LocDirectEntry
		{
			Key ="$Disease.Cold";
			Text ="Gripe";
		},
		LocDirectEntry
		{
			Key ="$Disease.ColdDesc";
			Text ="Fadiga, dores nos membros, febre e delírio... aqueles que sofrem de gripe terão uma experiência muito desagradável. Chame o médico sem demora!";
		},
		LocDirectEntry
		{
			Key ="$Disease.Leprosy";
			Text ="Hanseníase";
		},
		LocDirectEntry
		{
			Key ="$Disease.LeprosyDesc";
			Text ="A doença fatal lepra, também conhecida como lepra, cobre o corpo do paciente com úlceras feias e parcialmente purulentas. Se não for tratada, mais cedo ou mais tarde as partes do corpo simplesmente apodrecerão e cairão...";
		},
		LocDirectEntry
		{
			Key ="$Disease.Plague";
			Text ="Praga";
		},
		LocDirectEntry
		{
			Key ="$Disease.PlagueDesc";
			Text ="A peste é uma doença altamente contagiosa e, na maioria dos casos, fatal. Alguns sustentam que o \"Black Death\" is a punishment for all sinners, while others see the plague as an infestation of the unclean, of Satan himself...";
		},
		LocDirectEntry
		{
			Key ="$DogCompanion";
			Text ="Cão de guarda";
		},
		LocDirectEntry
		{
			Key ="$DogCompanionDesc";
			Text ="Este cão vem de uma longa linhagem de cães pastores capazes. Ele já estava acostumado com humanos desde filhote e treinado como cão de companhia e guarda.";
		},
		LocDirectEntry
		{
			Key ="$DrFaustusElixir";
			Text ="Elixir do Dr. Fausto";
		},
		LocDirectEntry
		{
			Key ="$DrFaustusElixirDesc";
			Text ="O Elixir do Dr. Fausto tem efeitos quase mágicos, pois aumenta a sua fertilidade por um período de tempo, possibilitando assim que você tenha filhos mesmo na velhice. Alguns até dizem que prolonga a sua vida de formas quase não naturais... Mas cuidado: o uso do elixir é desaprovado devido à sua potência não natural e aos seus potenciais efeitos secundários.\nBeba este elixir para aumentar a sua fertilidade e a sua esperança de vida.";
		},
		LocDirectEntry
		{
			Key ="$DrunkardBrewBeer";
			Text ="Cerveja de Guntram";
		},
		LocDirectEntry
		{
			Key ="$DrunkardBrewBeerDesc";
			Text ="Guntram é provavelmente um dos cervejeiros mais conhecidos e ao mesmo tempo mais odiados do nosso tempo. Apesar disso (ou talvez justamente por isso), a cerveja dele é muito procurada... por que pergunta? Não sei... experimente!";
		},
		LocDirectEntry
		{
			Key ="$DrunkenComrade";
			Text ="Companheiro de bebida";
		},
		LocDirectEntry
		{
			Key ="$DrunkenComradeDesc";
			Text ="Você mal consegue acreditar, mas o álcool tem um efeito totalmente diferente em você e em qualquer outra pessoa! Assim que você tiver absorvido além da sua sede, você se tornará muito pacífico, mais carismático e adquirirá habilidades retóricas inimagináveis...";
		},
		LocDirectEntry
		{
			Key ="$Ectoplasm";
			Text ="Ectoplasma";
		},
		LocDirectEntry
		{
			Key ="$EctoplasmDesc";
			Text ="Se você misturar ossos finamente moídos de criminosos mortos há muito tempo com outros ingredientes, ele cria ectoplasma: uma substância líquida ou às vezes gasosa. Isso serve como uma espécie de cola para fantasmas e pensamentos sinistros...";
		},
		LocDirectEntry
		{
			Key ="$Effect.SpiedOnBuilding";
			Text ="Um espião está espionando este prédio para você.";
		},
		LocDirectEntry
		{
			Key ="$Effect.SpiedOnCharacter";
			Text ="Um espião está espionando essa pessoa para você.";
		},
		LocDirectEntry
		{
