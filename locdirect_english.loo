		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fAnswer.v3.rb";
			Text ="Receio que esta chave não tenha sentido e seja apenas sua tentativa de comprar minha amizade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.openLine.v4.int";
			Text ="Você é sábio e modesto...";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v4.int";
			Text ="A sabedoria e a modéstia permitiram que você tivesse sucesso. Aceite esta chave da cidade como um símbolo do seu trabalho duro.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.sAnswer.v4.int";
			Text ="Esta homenagem significa muito para mim. Você tem minha sincera gratidão.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fAnswer.v4.int";
			Text ="Por favor, não brinque.";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.openLine.v4.intim";
			Text ="Precisamos de pessoas como você...";
		},
		LocDirectEntry
		{
			Key ="$d.act.awardKey.fullLine.v4.intim";
			Text ="Precisamos de pessoas como você, indomáveis, determinadas. Leve a chave da cidade que construímos juntos.";
