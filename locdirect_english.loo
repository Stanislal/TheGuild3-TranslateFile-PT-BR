		LocDirectEntry
		{
			Key ="$LockPicksDesc";
			Text ="Este conjunto de arrombadores pode ser usado para... você sabe... ehm... abrir portas ou janelas trancadas quando alguém quer arrombar um prédio... mas merda!";
		},
		LocDirectEntry
		{
			Key ="$effect.buff.LockPicks";
