		},
		LocDirectEntry
		{
			Key ="$ui.Subquest.Desc7";
			Text ="Aprenda todas as habilidades em um caminho de habilidades.";
		},
		LocDirectEntry
		{
			Key ="$ui.Subquest.Desc8";
