		LocDirectEntry
		{
			Key ="$d.npc.casualLife.coin.line.rich3";
			Text ="Acabei de encontrar uma moeda. Pode estar coberto de sujeira, mas ainda assim me trará sorte!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.coin.answer.poor1";
			Text ="Eu invejo você...";
