		LocDirectEntry
		{
			Key ="$action.PowerCityGuardsDesc";
			Text ="Utilize os privilégios do seu escritório para planear as rotas de patrulha dos guardas da cidade, permitindo que algumas áreas sejam fortemente vigiadas, enquanto deixam outras mais ou menos indefesas.";
		},
		LocDirectEntry
		{
