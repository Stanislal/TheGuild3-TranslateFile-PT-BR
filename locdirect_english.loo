		LocDirectEntry
		{
			Key ="$CharcoalDesc";
			Text ="O carvão é usado para produtos que requerem alto calor para processamento. Isso se aplica principalmente a produtos metálicos e de panificação.";
		},
		LocDirectEntry
		{
