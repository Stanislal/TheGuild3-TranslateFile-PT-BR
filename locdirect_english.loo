		{
			Key ="$action.StackBoxes";
			Text ="Empilhar caixas no mercado";
		},
		LocDirectEntry
		{
			Key ="$action.StackBoxesDesc";
			Text ="Você é jovem e forte, então por que não se tornar útil? Vá ao mercado e ajude os comerciantes. Você certamente ganhará algumas moedas e as pessoas da vila ou distrito certamente irão admirá-lo por sua diligência.";
		},
		LocDirectEntry
		{
			Key ="$action.CatchRats";
			Text ="Caça ratos";
		},
		LocDirectEntry
		{
			Key ="$action.CatchRatsDesc";
			Text ="Os ratos são uma praga terrível! Eles devoram e estragam os alimentos e transmitem doenças. Vá para outro negócio e pegue alguns desses bastardos! Isso melhorará a reputação da sua família junto ao proprietário da empresa.";
		},
		LocDirectEntry
		{
			Key ="$action.ApologizeToNeighbors";
			Text ="Peça desculpas aos vizinhos";
		},
		LocDirectEntry
		{
			Key ="$action.ApologizeToNeighborsDesc";
			Text ="Seu malandro, você está sempre tramando algo ruim, então deve haver algumas coisas pelas quais você precisa se desculpar com os vizinhos! Então peça desculpas e isso melhorará a reputação da sua família na aldeia ou distrito.";
		},
		LocDirectEntry
		{
			Key ="$action.RaidTheKitchens";
			Text ="Invadir as cozinhas";
		},
		LocDirectEntry
		{
			Key ="$action.RaidTheKitchensDesc";
			Text ="Você gosta de comer um bolo doce ou uma salsicha picante? Sua fome deve ser saciada, então vá até a vitrine da cozinha de uma empresa que produz alimentos e pegue algo saboroso! Se você tiver sucesso, sua saúde melhorará por um curto período e você será mais rápido. A satisfação do cliente da empresa também diminuirá temporariamente.";
		},
		LocDirectEntry
		{
			Key ="$action.ReadStories";
			Text ="Leia algo em voz alta";
		},
		LocDirectEntry
		{
			Key ="$action.ReadStoriesDesc";
			Text ="Nem todo mundo teve a sorte de nascer em uma família rica que pode mandar seus filhos para a escola. Use seu grande privilégio e leia histórias de heróis e terras distantes para entreter outras pessoas. Isso não apenas aumentará a reputação de sua família entre os ouvintes, mas também ganhará alguma influência para sua família.";
		},
		LocDirectEntry
		{
			Key ="$action.GoCampaigning";
			Text ="Relações públicas";
		},
		LocDirectEntry
		{
			Key ="$action.GoCampaigningDesc";
			Text ="A multidão... ehm... as pessoas justas passam por momentos difíceis hoje em dia, pois são dominadas e exploradas pela nobreza, pelo clero e pelas dinastias familiares ricas. Bem, não por você, mas pelos outros... Então vá e fale com a máfia... er... com as pessoas comuns e convença-as de que sua dinastia é diferente de todas as outras. Isto aumentará a sua reputação na aldeia ou distrito e você ganhará influência.";
		},
		LocDirectEntry
		{
			Key ="$action.Palmistry";
			Text ="Quiromancia";
		},
		LocDirectEntry
		{
			Key ="$action.PalmistryCoordinate";
			Text ="Quiromancia (com localização)";
		},
		LocDirectEntry
		{
			Key ="$action.PalmistryDesc";
			Text ="Você não tem ideia de como ler o futuro de uma pessoa na palma da mão? Não importa, porque eles também não! O importante é parecer que você sabe o que está fazendo! Isso pode render algumas moedas. As pessoas ficarão felizes e você ganhará algum dinheiro, então é uma situação ganha-ganha.";
		},
		LocDirectEntry
		{
			Key ="$action.TakeFencingClass";
			Text ="Faça algumas aulas de esgrima";
		},
		LocDirectEntry
		{
			Key ="$action.TakeFencingClassDesc";
			Text ="Faça algumas aulas de esgrima para melhorar permanentemente seu poder de ataque.";
		},
		LocDirectEntry
		{
			Key ="$action.SimpleRepairs";
			Text ="Realize alguns pequenos reparos";
		},
		LocDirectEntry
		{
			Key ="$action.SimpleRepairsDesc";
			Text ="Você não precisa chamar um artesão especialista e bem pago para consertar seus edifícios. Com tempo e motivação suficientes, você será perfeitamente capaz de realizar alguns pequenos reparos! Use esta ação em edifícios danificados para restaurar alguns pontos da estrutura.";
		},
		LocDirectEntry
		{
			Key ="$action.TakeMedicineClass";
			Text ="Aprenda algumas lições com um curador de feridas";
		},
		LocDirectEntry
		{
			Key ="$action.TakeMedicineClassDesc";
			Text ="Neste mundo difícil, um pouco de conhecimento como curador de feridas pode ser muito útil. Assista a uma aula na sua escola para aprender como ajudar alguém a evitar que tenha que visitar um médico. Isso melhorará sua habilidade de atributo secundário “Medicina”.";
		},
		LocDirectEntry
		{
			Key ="$action.SendToMonastery";
			Text ="Enviar para um mosteiro";
		},
		LocDirectEntry
		{
			Key ="$action.SendToMonasteryDesc";
			Text ="Algum dos membros da sua família está sendo desobediente e tendo um relacionamento com alguém que você não aprova? Em seguida, envie o membro da família para um mosteiro por um tempo, onde aprenderá obediência.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTree1";
			Text ="A Árvore genealógica mostra todos os membros de uma família.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTree2";
			Text ="Ter uma família grande é crucial para permitir que você concorra de forma mais eficaz com seus concorrentes. É importante ter mais do que apenas um herdeiro potencial para escolher, principalmente no início do jogo.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTree3";
			Text ="O primogênito normalmente é o herdeiro legítimo de sua dinastia, mas você também pode nomear um herdeiro diferente usando o botão Nomear herdeiro se perceber mais potencial de liderança neste indivíduo. Mas tenha sempre em mente que o herdeiro anterior não apreciará muito a mudança.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTree5";
			Text ="Árvore genealógica";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTree7";
			Text ="Sucessão";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree1";
			Text ="Títulos e Habilidades";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree2";
			Text ="Para avançar sua dinastia, você deve adquirir títulos mais elevados e desenvolver habilidades mostradas na Árvore de habilidades. Desbloqueando esses custos você cria e/ou influencia. Para abrir a árvore de habilidades, clique no respectivo ícone no painel Dinastia próximo ao seu brasão (número 1). Aqui você encontrará uma lista de títulos (número 2), quatro abas para os diferentes caminhos profissionais (número 3) e uma aba para suas habilidades sociais.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree4";
			Text ="Mova o cursor sobre um título ou habilidade para ver as vantagens que ele concede e quanto custa.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree5";
			Text ="Habilidades";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree6";
			Text ="Habilidades desbloqueiam novos edifícios, níveis de construção, itens e ações. Algumas habilidades também aprimoram os atributos de seus familiares ou funcionários.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree7";
			Text ="Caminhos de habilidade";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree8";
			Text ="Existem vários caminhos de habilidade nos quais você pode investir. Os custos das habilidades são altos, então faz sentido focar inicialmente no caminho de habilidade que você selecionou no início do jogo.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree9";
			Text ="Habilidades de compra";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TitlesAndSkillTree10";
			Text ="Para comprar uma habilidade, clique no ícone de habilidade com o botão esquerdo do mouse. Você só pode comprar habilidades que já desbloqueou (sem ícone de cadeado).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics1";
			Text ="Livro de orçamento";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics2";
			Text ="A janela de estatísticas fornece uma visão geral de suas receitas e despesas. Também mostra a posição da sua família em comparação com a de seus concorrentes.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics3";
			Text ="Empresas";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics4";
			Text ="Você pode selecionar um edifício na janela para visualizar todas as informações importantes relacionadas ao edifício mostrado.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics5";
			Text ="Família";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics6";
			Text ="A aba família mostra receitas e despesas relacionadas a ações e qualquer renda oficial de seus familiares e capangas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics7";
			Text ="";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics8";
			Text ="A aba Pontuação mostra a classificação da sua dinastia em comparação com a de outras dinastias. Você pode comparar todas as dinastias ou selecionar apenas aquelas de seu interesse. Além disso, ao passar o cursor sobre uma crista, a respectiva função será destacada no gráfico.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics9";
			Text ="Linha do tempo";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Statistics10";
			Text ="Se você quiser ver as estatísticas de um determinado período de tempo, basta definir os anos relevantes aqui.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection1";
			Text ="Janela de caracteres";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection2";
			Text ="Para obter informações básicas sobre um personagem, você deve abrir a janela do personagem: selecione o respectivo personagem e clique no pequeno ícone quadrado que mostra o nível do personagem ao lado de seu retrato – ou use o \"i\" (button or keyboard). \nBelow the character's model, the character window contains basic information about the character.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection3";
			Text ="Equipamento";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection4";
			Text ="Cada personagem possui 5 slots de equipamento (número 1), 3 slots para artefatos (número 2) e 2 a 4 slots de inventário (número 3).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection5";
			Text ="Atributos";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection6";
			Text ="O lado direito da janela do personagem também mostra os atributos e os atributos secundários do personagem. Itens, profissões, efeitos de status e outras coisas podem influenciar atributos e atributos secundários. Mova o cursor do mouse sobre um atributo para visualizar informações mais detalhadas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection7";
			Text ="Níveis de personagem";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CharacterInspection8";
			Text ="Cada vez que os personagens realizam ações, eles ganharão “pontos de experiência”. XP é necessário para aumentar o nível do seu personagem. Você pode melhorar os atributos de um personagem toda vez que sobe de nível.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview1";
			Text ="Livro das Dinastias";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview2";
			Text ="O Livro das Dinastias permite que você acesse informações muito importantes sobre seus concorrentes e sua reputação na cidade.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview3";
			Text ="";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview4";
			Text ="A janela Dinastias fornece acesso à árvore genealógica de outras dinastias. Você também pode ver todos os edifícios pertencentes a uma dinastia aqui.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview5";
			Text ="Atitude";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview6";
			Text ="Informações mais importantes sobre uma dinastia incluem Atitude: Honesto e Astuto, Generoso e Egoísta e Diplomático e Agressivo. Quando você fizer um de seus personagens realizar uma ação, tenha em mente que isso pode influenciar a atitude de sua dinastia!\n\nMais tarde no jogo, as guildas convidarão dinastias para seu círculo se as atitudes da dinastia e da guilda forem basicamente as mesmas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview7";
			Text ="Romances e ligações";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview8";
			Text ="Selecione Romances para ver todos os romances e ligações de sua dinastia.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview9";
			Text ="Reféns";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview10";
			Text ="O botão Refém permite que você encontre todos os personagens que você raptou. Aqui, você também pode optar por libertar o personagem ou negociar um “acordo” com sua família para pagar um resgate.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview11";
			Text ="Popularidade";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview12";
			Text ="Use o botão Popularidade para ver a reputação de uma dinastia em cada vila e distrito. Se você for popular em uma vila ou distrito, a produtividade dos seus funcionários será maior e os residentes farão compras com mais frequência na sua loja.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview13";
			Text ="Evidências";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview14";
			Text ="Você pode coletar (ou falsificar) evidências de crimes cometidos por seus concorrentes durante o jogo. Para ver as evidências que você coletou contra uma respectiva dinastia, você precisa selecionar seu brasão (número 1) e selecionar a seção de evidências (número 2). As evidências podem ser usadas para processar um personagem no tribunal se você apresentar uma queixa. Alternativamente, você também pode negociar evidências com outras dinastias como parte de um “comércio dinástico”.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview15";
			Text ="Favorece o relacionamento entre dinastias";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyOverview16";
			Text ="Para ver a relação de favorecimento entre dinastias, basta mover o cursor sobre o brasão da dinastia.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds1";
			Text ="Guildas";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds2";
			Text ="Em algum momento, sua dinastia terá se tornado tão bem sucedida e poderosa que você poderá receber um convite de uma das guildas, que você pode aceitar ou recusar no Livro das Guildas. Sua Atitude (a maneira como você se comporta no jogo) torna-se então importante. Se a sua atitude corresponder à atitude de uma guilda, os membros terão interesse em ter você em suas fileiras (número 4). Você só pode ser membro de uma guilda por vez.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds3";
			Text ="Benefícios";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds4";
			Text ="Quando você se torna membro de uma guilda, você ganha acesso a “ações específicas da guilda” e recebe certas “melhorias de atributos” (número 4).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds7";
			Text ="Saindo de uma guilda";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Guilds8";
			Text ="Você pode deixar uma guilda voluntariamente, mas também pode ser expulso se a atitude de sua dinastia começar a se desviar muito da atitude da guilda.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.QuestLog1";
			Text ="Livro de missões";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.QuestLog2";
			Text ="Se você selecionou uma campanha familiar no início do jogo, você pode encontrar as missões individuais no Livro de Missões. Você também verá algumas oportunidades favoráveis ​​de “comércio distante” com outras cidades listadas aqui.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.QuestLog3";
			Text ="Missões";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.QuestLog4";
			Text ="Na seção Missões disponíveis você pode ver suas tarefas e progresso. Selecione uma missão na lista para obter mais informações.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.QuestLog5";
			Text ="Ordens comerciais";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.QuestLog6";
			Text ="As ordens comerciais são oportunidades favoráveis para o comércio de longa distância com outras cidades. Cidades comerciais de longa distância são acessíveis através de placas de sinalização nas extremidades do cenário. Geralmente, você pode comprar produtos lá mais barato ou vendê-los com um lucro maior. Clique com o botão esquerdo para obter mais informações sobre uma ordem de negociação.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics1";
			Text ="Política";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics2";
			Text ="A política desempenha um papel importante no mundo de The Guild 3. No menu Leis da Cidade (número 1), você encontra a árvore de Escritórios, onde pode ver quem ocupa cada cargo (números 2 e 4). Os escritórios estão organizados em câmaras e concedem privilégios de cargos específicos. Você pode ver os detalhes dos vários escritórios clicando no nome do escritório ou no ícone do calendário (número 5). Finalmente, devemos mencionar que os funcionários municipais são pagos pelos seus esforços.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics3";
			Text ="Como conseguir um cargo";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics4";
			Text ="Antes de se candidatar a um cargo com um de seus familiares, você precisa ter o privilégio para isso. Os privilégios para ocupar determinados níveis de cargos são concedidos por títulos.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics5";
			Text ="Período de inscrição";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics6";
			Text ="Cada cargo tem um prazo de inscrição específico, e um personagem só pode se inscrever nesse período. O ícone de pena ao lado do escritório indica se o período de inscrição está ativo. O número adjacente mostra quantos outros candidatos existem.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics7";
			Text ="Leis municipais";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Politics8";
			Text ="Se você selecionar a aba Leis municipais (número 1), você poderá ver todas as diferentes leis da sua cidade. As leis determinam se a tomada de certas medidas é legal (número 2) ou ilegal (número 3).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticsDetails1";
			Text ="Escritórios";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticsDetails2";
			Text ="Certifique-se de que sua família possui o título correto (Cidadão para cargos de primeiro nível).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticsDetails3";
			Text ="Candidatura a um escritório";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticsDetails4";
			Text ="Para subir na hierarquia política, você precisa ter um título específico e ocupar um cargo de nível inferior àquele que deseja alcançar. Se ainda não tem escritório, só pode candidatar-se aos cargos de nível inferior. Na eleição para o cargo de Soberano, todos os líderes da dinastia podem participar, independentemente de ocuparem ou não o cargo, mas a eleição só é aberta após a morte do Soberano anterior.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.AreaMap1";
			Text ="Mapa";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.AreaMap2";
			Text ="A janela do mapa da área fornece uma visão geral de todo o cenário. Você pode ver quem é o dono do quê e também pode enviar seus personagens para edifícios clicando com o botão direito no edifício relevante.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.AreaMap3";
			Text ="Controles";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.AreaMap4";
			Text ="Você pode ampliar o mapa da área usando os botões no canto inferior direito ou, alternativamente, usar a roda do mouse.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.AreaMap5";
			Text ="Para mover o mapa de área, você pode segurar o botão esquerdo do mouse no mapa e então mover o mouse.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.AreaMap6";
			Text ="Filtros de mapa";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.AreaMap7";
			Text ="Para mais detalhes sobre o cenário, abra os filtros do mapa. Aqui, por exemplo, você verá o número de habitantes e guardas municipais de uma vila ou distrito.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding1";
			Text ="Erguer um novo prédio";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding2";
			Text ="Você pode construir um novo edifício clicando em Erguer um novo edifício no painel Mundo. Existem dois tipos de edifícios que você pode construir: Residências e Negócios (números 1 e 2). À esquerda, há um \"style\"list of all buildings, which you can filter, and on the right, you can find additional information about the buildings, such as how much a building costs and whether or not you can currently build it (number 4). By hovering the cursor over the image of a building, even more information is displayed.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding3";
			Text ="Residências";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding4";
			Text ="Sua família precisa de uma residência para morar e que seja seu ponto de partida para ações com seus familiares. Algumas casas só podem ser construídas na cidade, enquanto outras só são permitidas no campo.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding5";
			Text ="Empresas";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding6";
			Text ="Os negócios são cruciais para o sucesso da sua dinastia, pois geram dinheiro para você. Seu título determinará quantas empresas você pode possuir.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding7";
			Text ="Atualizar edifício";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding8";
			Text ="Muitas empresas têm 3 níveis de construção. Se você possui um desses negócios no nível de edifício 1 e adquiriu a habilidade necessária para o nível 2, você pode atualizá-lo para o nível de edifício 2. Você também pode, é claro, construir novos negócios do mesmo tipo diretamente no nível de edifício 2. Observe que a maioria dos negócios nos níveis de edifício 2 e 3 só podem ser construídos em uma cidade!";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding9";
			Text ="Construir um edifício";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.BuildBuilding10";
			Text ="Clique no edifício relevante, insira um nome - ou mantenha o nome do edifício proposto - e então encontre um espaço livre em uma rua. Note aqui que alguns edifícios só podem ser construídos numa aldeia e outros apenas numa cidade. Além disso, você não pode construir em determinadas estradas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticalPowerProposal1";
			Text ="Privilégios de cargo";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticalPowerProposal2";
			Text ="Depois de ocupar um cargo, você terá certas ações disponíveis. Você também pode propor alterações nas leis atribuídas ao seu cargo e votá-las em sua câmara.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticalPowerProposal3";
			Text ="Proponha algo";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticalPowerProposal4";
			Text ="Para propor uma mudança na lei, você precisa:\n1. Selecione um membro da família que ocupe um cargo.\n2. Clique na categoria de ação Diplomacia e Política (número 1).\n3. Clique na ação Proposta para alterar as leis municipais (número 2).\n4. A interface de votação aparecerá. À esquerda, você vê as leis que você pode propor alterar (número 3).\n5. Faça a sua proposta (número 4) e confirme-a (número 5).\n6. Será exibida uma entrada no calendário que mostra quando ocorrerá a votação da sua proposta. No horário agendado, seu personagem correrá automaticamente para a reunião na prefeitura. Caso seu personagem falte à reunião, seu personagem receberá multa ou até perderá o cargo caso não consiga pagar a multa. Além disso, o voto não é levado em consideração.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticalPowerProposal5";
			Text ="Votação";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.PoliticalPowerProposal6";
			Text ="Uma ou várias leis podem ser alteradas com uma única proposta e serão votadas ao mesmo tempo em uma única reunião de gabinete.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow1";
			Text ="Produção";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow2";
			Text ="O menu de produção é um dos menus mais importantes do jogo, pois seus negócios podem lhe proporcionar uma renda estável e se tornar a base de sua riqueza.\nExistem abordagens diferentes para administrar um negócio usando uma variedade de configurações que podem ser ajustadas nas diferentes guias do menu de negócios. Aqui você pode executar a produção (número 1), definir as regras de armazenamento (número 2), colocar itens à venda (número 3), comprar complementos de construção para aumentar diferentes valores de construção (número 4) e obter algumas informações gerais sobre o seu edifício (número 5).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow3";
			Text ="Contratar transportadores";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow4";
			Text ="Os transportadores transportarão os itens produzidos pela empresa para um mercado ou outro destino que você definiu em uma rota comercial, bem como transportarão os itens para a sua empresa (informações detalhadas podem ser encontradas na seção do tutorial Rotas comerciais).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow6";
			Text ="Os transportadores são automatizados por padrão, o que significa que você não precisa se preocupar em vender seus produtos ou obter suprimentos de matéria-prima, pois a IA mestre fará isso por você. No entanto, você mesmo pode controlar seus transportadores e criar rotas comerciais para eles.\nObservação: Ervas e outros ingredientes podem ser coletados por seus trabalhadores e familiares.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow8";
			Text ="Os trabalhadores produzirão itens ou realizarão ações. Para que seus funcionários saibam o que fazer, você deve dar-lhes ordens usando a lista de pedidos. Arraste e solte os itens que deseja produzir ou as ações que deseja realizar da seção esquerda para a lista de pedidos e defina a quantidade de itens/ações que seus trabalhadores devem produzir/executar. Você pode acompanhar facilmente o que seus funcionários estão fazendo olhando seus retratos.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow10";
			Text ="Se sua empresa tem a opção de oferecer serviços, você pode definir se (número 1) e quantos de seus funcionários (número 2) devem estar envolvidos na prestação de quais serviços, caso o cliente visite sua empresa. Se não houver clientes presentes, os trabalhadores produzirão automaticamente os itens de acordo com a lista de pedidos. Os trabalhadores aos quais é atribuída uma tarefa diretamente nunca fornecerão um serviço e trabalharão apenas nessa tarefa.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow11";
			Text ="Para decidir por si mesmo qual tarefa um trabalhador deve realizar, você pode arrastar um item ou ação da área esquerda do menu de produção diretamente para o trabalhador (número 1). O trabalhador então “apenas” produzirá aquele item específico ou executará aquela ação específica e, em particular, não produzirá quaisquer “intermediários”, mesmo que a matéria-prima esteja disponível no armazenamento do edifício. Os trabalhadores atribuídos a uma produção individual recebem um bônus de produtividade.\nLembre-se de que você sempre pode cancelar a produção individual (número3).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow12";
			Text ="Membros da família em uma empresa";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow13";
			Text ="Os familiares adultos também podem trabalhar como transportadores ou trabalhadores, desde que haja um local de trabalho disponível para eles. A grande vantagem aqui é que você não precisa pagar salário e seus familiares não precisam dormir.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow14";
			Text ="Regras de armazenamento";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow15";
			Text ="Você pode usar as regras de armazenamento para otimizar a IA mestre do seu negócio de acordo com seus desejos. Você pode definir se os itens devem, em geral, ser comprados ou vendidos, quantos itens devem ser mantidos no mínimo (número 1) e quantos itens devem ser armazenados no máximo (número 2). Ao selecionar o botão Vender, todos os itens que ultrapassarem o armazenamento máximo serão vendidos por transportadores que executam rotas automatizadas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow16";
			Text ="Mestre de IA";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow17";
			Text ="Nas Opções do jogo, você pode decidir sobre diferentes configurações que também influenciam sua produção, como o aumento automático de nível para funcionários e se os transportadores devem atualizar automaticamente seu inventário carregando sacolas ou carrinhos sem sua instrução manual, para que possam transportar mais itens.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow18";
			Text ="Atualizações de construção";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow19";
			Text ="Os complementos de construção trazem uma série de vantagens para um edifício, como locais de trabalho adicionais ou aumento de produtividade. Dependendo do “nível de construção” de um tipo de construção, podem ser adquiridos mais complementos/complementos de maior qualidade.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow20";
			Text ="Loja frontal";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow21";
			Text ="A loja da frente é uma área onde você pode “oferecer itens à venda”. Você pode estocá-lo sozinho (número 1) ou automatizar o processo usando as “regras de armazenamento”. Usando as configurações, você pode determinar quais itens devem ser movidos para a loja da loja (número 2) e quanto eles devem custar em comparação com o preço de mercado (número 3).\nSe a sua empresa tiver um alto nível de satisfação do cliente, mais pessoas da vila ou distrito passarão para fazer compras na sua loja da frente. A sua popularidade na aldeia ou distrito pode até incentivá-los a pagar preços excessivos.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow24";
			Text ="Descartar itens";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.ProductionWindow25";
			Text ="Se quiser descartar um item, selecione e arraste-o sobre a área do lixo (número 8). Isso também funciona para uma pilha de itens.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Residence1";
			Text ="Residência";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Residence2";
			Text ="Você pode possuir várias residências, mas apenas uma é a residência de sua família. Se você perder sua residência, terá 1 rodada para encontrar uma nova, caso contrário perderá.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Residence4";
			Text ="O menu do edifício da sua residência é muito semelhante ao de um edifício comercial. Você pode contratar membros da família (incluindo crianças) como trabalhadores, montar uma lista de pedidos que eles precisam cumprir e atribuir-lhes tarefas individuais. Informações detalhadas podem ser encontradas na seção do tutorial Produção.\nNo entanto, em alguns aspectos a residência é especial comparada a um negócio. Por exemplo, você pode deter reféns aqui ou produzir itens e realizar ações que não podem ser acessadas em nenhum outro lugar do jogo. Quanto mais alto for o nível da sua residência, mais opções você terá.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Residence7";
			Text ="Itens sociais";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Residence8";
			Text ="Itens sociais só podem ser produzidos em residências. Estes são para “uso pessoal” e, portanto, não podem ser comprados ou vendidos. Você pode usá-los para, por exemplo, melhorar temporariamente os atributos de seus personagens, equipá-los ou impressionar outras pessoas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes1";
			Text ="Rotas comerciais";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes2";
			Text ="Muitas vezes faz sentido criar suas próprias rotas comerciais. Isso permite que você determine o que seus transportadores vendem ou compram e onde.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes3";
			Text ="Crie uma rota comercial";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes4";
			Text ="Por padrão, os transportadores são automatizados e só seguem suas regras de armazenamento em conjunto com as regras do tipo de produção que você selecionou. Para criar uma nova rota comercial, você precisa ter pelo menos um transportador. Clique no botão rota (número 1) e o pop-up da rota comercial aparecerá. Selecione o botão Criar Rota (número 2).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes5";
			Text ="Atribuir rota comercial";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes6";
			Text ="Para atribuir uma rota comercial a um transportador, clique no botão Selecionar uma Rota do respectivo transportador (número 1), selecione a rota relevante na lista de rotas (número 2) e confirme sua escolha (número 3).";
		},
		LocDirectEntry
		{
			Key ="$gui.traderoute.automatic";
			Text ="Rota automática";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes7";
			Text ="Editar rotas comerciais";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes8";
			Text ="Você pode editar uma rota comercial clicando no botão relevante próximo ao nome da rota.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes9";
			Text ="Excluir rotas comerciais";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutes10";
			Text ="Para excluir uma rota comercial, basta clicar no ícone de exclusão próximo ao nome da rota comercial.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail2";
			Text ="Na janela de detalhes da rota comercial você pode definir todas as configurações para os transportadores que irão viajar ao longo da rota. Você pode selecionar destinos e determinar quais produtos coletar e descarregar. Os transportadores que executam rotas comerciais personalizadas também respeitarão as configurações mínimas e máximas de armazenamento para cada empresa que visitarem.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail3";
			Text ="Adicionar e remover destinos";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail4";
			Text ="Você pode adicionar ou remover destinos clicando no botão + ou - próximo ao destino. Alternativamente, você pode escolher um destino na lista suspensa ou através do mapa.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail5";
			Text ="Descarregando e carregando mercadorias";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail6";
			Text ="Para definir quais mercadorias devem ser carregadas ou descarregadas, basta clicar no ícone de um slot vazio, selecionar o item desejado e definir uma quantidade. As quantidades são relativas ao estoque do transportador. Um valor positivo significa que o transportador deve recolher os itens, um valor negativo significa que o transportador deve descarregar os itens. Você pode definir quantos embarques e desembarques por waypoint desejar, a ordem dos itens representa a prioridade com que o transportador irá lidar com essas ações. Um transportador sempre tentará primeiro soltar os itens da esquerda para a direita e depois tentar coletar os itens da esquerda para a direita. Se um item não estiver disponível ou não couber no inventário, o transportador verificará o próximo item até que esteja no final da lista.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail7";
			Text ="Quantidades";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail8";
			Text ="Para alterar a quantidade de itens a serem carregados/descarregados clique no número abaixo do item. Você pode mover o controle deslizante de -20 a 20 (valores negativos estão disponíveis apenas em pontos de referência onde você tem permissão para descarregar). Se quiser carregar mais de uma pilha completa de 20 itens de uma vez, você pode adicionar o mesmo item várias vezes a um ponto de referência.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail9";
			Text ="Rotas comerciais defeituosas";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.TradeRoutesDetail10";
			Text ="Lembre-se de que os transportadores seguirão suas rotas comerciais com precisão. É aconselhável verificar ocasionalmente os destinos e quais itens devem ser carregados e/ou descarregados ali. A janela da rota comercial destacará itens para os quais o número de coletas e entregas não está equilibrado na rota. No lado direito você também terá um resumo que também listará os avisos. Você ainda pode salvar e atribuir essas rotas, mas esteja ciente de que os transportadores podem ter problemas ao seguir as ordens dessas rotas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTrade1";
			Text ="Comércio dinástico";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTrade2";
			Text ="Você pode realizar “negociações dinásticas” com outras dinastias. Estes incluem edifícios comerciais, provas e reféns, bem como forjar alianças e arranjar casamentos.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTrade3";
			Text ="Faça uma oferta";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTrade5";
			Text ="Responder a uma oferta";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTrade6";
			Text ="Você será notificado se alguém lhe fizer uma oferta para uma comércio Dinástica. Clique nele para ver a oferta da outra dinastia. Agora você pode aceitar ou recusar.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTrade7";
			Text ="Ofertas boas e ruins";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.DynastyTrade8";
			Text ="Se você fizer uma oferta ruim durante uma Negociação Dinástica, isso terá um impacto negativo na sua reputação com as outras dinastias. No entanto, se você for generoso, sua reputação com a outra dinastia provavelmente aumentará.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Calendar1";
			Text ="Calendário de compromissos";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Calendar2";
			Text ="Reuniões oficiais e processos judiciais aparecem no calendário como compromissos. Você pode obter mais detalhes clicando no botão no canto superior direito de um compromisso.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment1";
			Text ="Compromissos";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment2";
			Text ="Existem vários motivos pelos quais um de seus personagens tem um compromisso. Você poderia, por exemplo, ser um acusado ou mesmo um juiz em processos judiciais, ou pode haver uma votação na câmara do seu escritório. Você verá outra janela, dependendo do motivo do agendamento.\nVocê pode obter mais detalhes clicando no botão no canto superior direito de um agendamento.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment3";
			Text ="Como juiz";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment4";
			Text ="Se alguém apresentou provas de violações de uma ou mais leis e você faz parte da câmara de juízes, então você é juiz em processos judiciais. Você deve dar seu veredicto antes do julgamento real, clicando no botão relevante e movendo o controle deslizante para o veredicto que considerar apropriado. Os possíveis veredictos são determinados com base na gravidade dos crimes e na quantidade de provas.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment5";
			Text ="Como acusado";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment6";
			Text ="Se você for acusado de um ou mais crimes, você verá do que foi acusado, quem julgará seu caso e quem o acusou. Agora você poderia ir contra os juízes ou o acusador, ou melhorar sua reputação junto a um juiz (incluindo romances) para receber um julgamento mais brando.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment7";
			Text ="Reunião de escritório";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.CalendarAppointment8";
			Text ="As reuniões do escritório ocorrem quando você ou outro membro da sua câmara apresenta uma proposta para alterar uma lei ou para outra ação do escritório. Vote antecipadamente (número 1), e seu personagem irá automaticamente para a prefeitura no horário marcado (número 2). Se seu personagem faltar em uma reunião, você pagará multa e o voto não será contabilizado. Se você tiver que indicar candidatos para outro cargo, basta votar, mas não precisa comparecer à prefeitura posteriormente.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.MessageLog1";
			Text ="Registro de mensagens";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.MessageLog2";
			Text ="No Registro de mensagens você pode encontrar as últimas 100 notificações que recebeu.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.MessageLog3";
			Text ="Filtro de mensagens";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.MessageLog4";
			Text ="Você pode filtrar suas notificações usando o botão Filtro de mensagens. Observe que você poderá perder mensagens importantes se definir um filtro.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market1";
			Text ="Mercado";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market2";
			Text ="O mercado é o centro mais importante para o comércio de mercadorias e onde qualquer personagem pode comprar e vender mercadorias.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market3";
			Text ="O menu do mercado";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market4";
			Text ="Transportadores automatizados ou transportadores que partem em uma rota comercial interagirão de forma independente com o mercado. Se quiser comprar ou vender mercadorias manualmente, você deve primeiro enviar um de seus personagens ao mercado selecionando um personagem e clicando com o botão direito para enviá-lo ao mercado. O personagem aparecerá no menu do mercado quando chegar.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market5";
			Text ="Comprar";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market6";
			Text ="Para comprar mercadorias, basta arrastá-las do mercado para um espaço vazio no inventário do seu personagem. Agora selecione a quantidade necessária na janela de transação. Depois de confirmada a quantidade, a compra será negociada.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market7";
			Text ="Vender";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market8";
			Text ="A venda de mercadorias funciona essencialmente como a compra de mercadorias, mas é exatamente o contrário. Arraste um item que deseja vender do inventário do seu personagem para o mercado. Depois de confirmar a quantidade na janela de transação, a venda será negociada.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market9";
			Text ="Categorias";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.Market10";
			Text ="As mercadorias à venda no mercado estão divididas em diversas categorias. Basta clicar em uma categoria e você verá os produtos disponíveis no mercado nessa categoria e os preços. Se quiser uma visão geral de todos os produtos que são importantes para você no momento, você também pode clicar no botão Todos os produtos importantes.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.FrontStore1";
			Text ="Loja frontal";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.FrontStore2";
			Text ="Você também pode fazer compras nas lojas de outras empresas, incluindo a mina, a pedreira e a madeira. Às vezes pode ser muito mais barato, mas nem sempre. Portanto, reserve um tempo para ver os preços mais de perto.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.FrontStore3";
			Text ="Comprar";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.FrontStore4";
			Text ="Para comprar algo em uma “loja de frente”, arraste e solte a mercadoria em um espaço vazio no inventário do seu personagem. A janela de transação será exibida onde você pode definir a quantidade. Agora confirme e a compra será efetivada.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls1";
			Text ="Controle da câmera";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls2";
			Text ="Você pode mover a câmera usando $(#23)$(#13)$(#20)$(#15) e as teclas de seta ou movendo o ponteiro do mouse até a borda da tela. Para ampliar, você pode usar a roda do mouse ou as teclas Page up e Page down. Para girar a câmera, você pode usar as teclas $(#19) e $(#16) ou manter pressionada a roda do mouse e mover o mouse. Mantenha pressionada a tecla $(#22) enquanto se move para diminuir a velocidade do movimento da câmera.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls3";
			Text ="Movimento horizontal";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls4";
			Text ="$(#23)$(#13)$(#20)$(#15), teclas de seta ou mova o ponteiro do mouse para a borda da tela.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls5";
			Text ="Zoom";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls6";
			Text ="roda do mouse ou as teclas Page up e Page down.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls7";
			Text ="Girar";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls8";
			Text ="Mantenha pressionados $(#19) e $(#16) ou a roda do mouse e mova o mouse.\nNota: no modo de câmera livre, mantenha pressionada a roda do mouse para ajustar a inclinação da câmera.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls9";
			Text ="Incline a câmera";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls10";
			Text ="Para alterar a inclinação da câmera, mantenha pressionada a roda do mouse e mova o mouse. A inclinação da câmera só pode ser alterada no modo de câmera livre.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls11";
			Text ="Modos de câmera";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CameraControls12";
			Text ="Você pode alternar entre a câmera RTS e a câmera livre .";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls1";
			Text ="Selecionar caracteres";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls2";
			Text ="Você pode usar o botão esquerdo do mouse para selecionar personagens tanto no mundo 3D quanto através de seu retrato em qualquer janela.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls3";
			Text ="Selecionar edifício";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls4";
			Text ="Tal como acontece com os personagens, você pode usar o botão esquerdo do mouse para selecionar qualquer edifício no mundo 3D e usar o ícone relevante em qualquer menu e janela.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls5";
			Text ="Mova seu próprio personagem";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls6";
			Text ="Para mover seu próprio personagem, primeiro selecione o personagem e depois clique com o botão direito em qualquer lugar de uma rua ou prédio.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls7";
			Text ="Câmera com foco";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.CharacterControls8";
			Text ="Você pode focar a câmera em um personagem ou edifício clicando duas vezes no retrato ou ícone ou pressionando $(#24).";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions1";
			Text ="Ações";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions2";
			Text ="Você pode realizar diferentes ações com seus personagens. Inicialmente você tem muito poucas ações disponíveis, mas receberá mais conforme o jogo avança por meio de títulos, habilidades, talentos e cargos, etc.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions3";
			Text ="Barra de ação";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions4";
			Text ="Quando um personagem ou edifício é selecionado, a barra de ação é exibida no canto inferior esquerdo. Aqui você verá as ações listadas em categorias que você pode realizar com o personagem ou edifício.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions5";
			Text ="Usar ações";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions6";
			Text ="Clique com o botão esquerdo do mouse em uma ação na barra de ações. Algumas ações serão então realizadas diretamente, enquanto outras abrirão uma janela contendo mais opções e outras exigirão um alvo específico. Você pode selecionar o alvo de uma ação tanto no mundo do jogo quanto nas interfaces do usuário.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions7";
			Text ="Selecione um alvo";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions8";
			Text ="Os alvos válidos para ações são destacados em verde e os inválidos em vermelho. Se você quiser saber por que um alvo é inválido, basta mover o ponteiro do mouse sobre o alvo.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions9";
			Text ="Chance de sucesso";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions10";
			Text ="A maioria das ações não tem um resultado fixo. A chance de sucesso geralmente depende dos atributos do seu personagem e dos atributos do alvo. Você pode ver sua chance de sucesso por meio de uma meta válida na janela de comparação.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions11";
			Text ="Custos e tempo";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions12";
			Text ="Ações podem custar dinheiro ou influência. Geralmente leva algum tempo para realizar uma ação e algumas podem ser repetidas após um determinado período de tempo.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions13";
			Text ="Informações adicionais";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions14";
			Text ="Se desejar visualizar informações adicionais sobre uma ação, mova o ponteiro do mouse até o ícone da ação e aguarde alguns instantes.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions15";
			Text ="Ações com consumíveis";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Actions16";
			Text ="Alguns itens podem ser usados. Esses “consumíveis” desbloqueiam ações para o personagem em cujo inventário eles estão localizados.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing1";
			Text ="Romances";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing2";
			Text ="Fundar uma família é uma das tarefas mais importantes em The Guild 3, se não a mais importante! Para fazer isso, primeiro você precisa que uma pessoa do sexo oposto se apaixone por você. Depois de casado, você pode produzir descendentes. Você pode se casar com um parceiro adequado de outra dinastia através de um “comércio dinástico”, mas nos estágios iniciais do jogo em particular, é mais provável que você inicie um relacionamento com um simples personagem de uma vila ou cidade.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing3";
			Text ="Embarque em um romance";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing4";
			Text ="Antes de poder se casar com outro personagem, você deve primeiro embarcar em um romance com ele. Para isso, selecione seu próprio personagem e depois escolha a ação Embarcar em um romance na categoria Romances & ligações.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing5";
			Text ="Encontre um parceiro";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing6";
			Text ="Agora você verá uma lista de parceiros em potencial e poderá escolher entre selecionar um personagem da lista ou escolher outro clicando no botão Escolher do mundo (número 1). Tendo em mente um casamento posterior, certifique-se de que seu parceiro ainda seja solteiro!\nAo selecionar um personagem, você pode ver as chances de sucesso de sua empreitada abaixo do campo de diálogo (número 2). Se você quiser mais informações sobre seu interesse amoroso em potencial antes de decidir, clique no \"i\" icon next to the character's name.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing9";
			Text ="Namoro";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing10";
			Text ="Assim que seu romance começar, você poderá cortejar seu parceiro. Para isso, selecione seu personagem, clique na categoria Romances e ligações na barra de ação e selecione uma das ações. Pode fazer sentido primeiro familiarizar-se com os sentimentos do seu amante e ver se ele prefere ser abordado de uma maneira específica. Se o namoro for bem-sucedido, essa pessoa olhará para você de maneira mais favorável.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing11";
			Text ="Proposta de casamento";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing12";
			Text ="Quando seu relacionamento com seu romance está bem avançado (você pode ver seu progresso selecionando um de seus parceiros como alvo de uma ação romântica ou no Livro das Dinastias). Você pode dar o próximo passo e propor.\nSe sua proposta foi aceita, é hora de começar a planejar um casamento. Para isso você pode escolher entre um casamento informal ali mesmo ou realizar uma cerimônia adequada na igreja.\nApós o casamento, o novo parceiro do seu personagem se tornará um membro da sua família que você pode controlar.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing13";
			Text ="Você é constantemente rejeitado?";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Romancing14";
			Text ="Se o personagem com quem você iniciou um romance rejeita constantemente seus avanços, o personagem pode ser de um nível muito mais elevado. Ou seu atributo carisma simplesmente não é alto o suficiente... neste caso você pode, por exemplo, acessar os itens sociais que você pode criar em sua residência.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Offspring2";
			Text ="Você deve garantir que sua família tenha descendentes o mais rápido possível. Caso contrário, há um grande risco de que sua dinastia acabe quando você morrer e o jogo acabe para você.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Offspring3";
			Text ="Produzir descendentes";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Offspring4";
			Text ="Para produzir descendentes, você e seu cônjuge precisam estar dentro de sua residência. Aqui você pode realizar a ação Produzir descendentes. Se tiver sucesso, a personagem feminina ficará grávida. A probabilidade de sucesso desta ação depende do atributo secundário Fertilidade de ambos os personagens.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Offspring5";
			Text ="Adoção";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Offspring6";
			Text ="Você também pode optar por adotar um órfão da igreja, mas isso lhe custará moedas. Além disso, os atributos dos órfãos muitas vezes não são tão bons quanto os atributos dos seus próprios filhos.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation1";
			Text ="Reputação";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation2";
			Text ="Em The Guild 3 cada dinastia tem uma reputação específica com todas as outras dinastias e com todas as outras aldeias e distritos.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation3";
			Text ="Reputação junto ao povo";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation4";
			Text ="A reputação reflete como a sua dinastia é vista pelos habitantes de uma aldeia ou distrito (número 2). Se você tratar mal as pessoas, sua reputação diminuirá, e uma reputação baixa significa que os residentes locais não estarão dispostos a gastar muito dinheiro nas fachadas de seus negócios, e a produtividade dos funcionários também diminuirá. Da mesma forma, nos processos judiciais, as pessoas, ou seja, os habitantes das aldeias e distritos, expressarão sempre em termos inequívocos qual o julgamento que esperam dos juízes no seu caso! Você pode imaginar as consequências de as pessoas odiarem você... A opinião dos cidadãos ricos tem mais peso aqui do que a dos pobres, e esse também é um fator que você deve ter em mente.\nFelizmente para você, existem várias maneiras de aumentar sua reputação. Da mesma forma, algumas ações podem prejudicar a reputação de seus concorrentes...";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation5";
			Text ="Reputação com outras dinastias";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation6";
			Text ="A reputação ou favorecimento de sua dinastia com outras dinastias (número 1) depende muito de como você lida com elas, ou seja, quais ações você toma contra ou a favor delas. Também é relevante se você se posicionará a favor ou contra eles em reuniões oficiais ou processos judiciais.\nTambém existem ações que melhorarão sua reputação com outra dinastia, assim como há ações que prejudicarão sua reputação com outras dinastias.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation7";
			Text ="Briga familiar";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation8";
			Text ="Se sua reputação ou favorecimento com outra dinastia for muito ruim, eles podem até declarar uma rivalidade. Será então altamente provável que eles ataquem seus funcionários e familiares e causem problemas para você de outras maneiras.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation9";
			Text ="Aliança";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Reputation10";
			Text ="Se sua reputação ou favorecimento com outra dinastia for muito alto, eles provavelmente lhe oferecerão uma aliança ou aceitarão sua proposta de aliança. Não só será mais fácil para você concluir negócios de dinastia com eles, mas também será mais provável que eles fiquem do seu lado durante votações e processos judiciais.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Resources1";
			Text ="Dinheiro e influência";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Resources2";
			Text ="Para progredir no The Guild 3, é crucial que você tenha dinheiro e influência.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Resources3";
			Text ="Dinheiro";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Resources4";
			Text ="Dinheiro ou, no nosso caso, moedas, são necessários para criar negócios, equipar personagens, realizar ações e muito mais. Você deve tentar evitar ficar endividado, porque se seu dinheiro cair abaixo de zero, você terá apenas uma rodada para voltar ao vermelho, caso contrário perderá o jogo. Seu nível atual de dinheiro é exibido no painel Mundial próximo ao ícone de moeda amarela.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Resources5";
			Text ="Influência";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Resources6";
			Text ="A influência é necessária para muitas ações diplomáticas, mas também para desbloquear títulos e habilidades. Você ganha influência quando ocupa um cargo ou quando se envolve na diplomacia, mas existem várias outras medidas que você pode usar para ganhar influência. Sua quantidade atual de pontos de influência é exibida no painel Mundo próximo ao ícone vermelho do prêmio.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Time1";
			Text ="Rodadas e anos";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Time2";
			Text ="O Guild 3 é jogado em rodadas, sendo uma rodada a cada 24 horas. Antes de iniciar um cenário você pode decidir quantos anos devem passar por rodada.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Time3";
			Text ="Tempo de controle";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Time4";
			Text ="No modo single-player, você pode usar as teclas $(KEY_PLUS) e $(KEY_MINUS) para controlar a rapidez ou lentidão com que deseja que uma rodada passe. Pressione $(KEY_P) para pausar o jogo.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo1";
			Text ="Tutorial";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo2";
			Text ="Bem-vindo à Guilda 3! Este tutorial foi desenvolvido para fornecer uma visão dos principais conceitos do jogo e dos controles do jogo.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo3";
			Text ="Missões";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo4";
			Text ="O tutorial consiste em uma sequência de missões. Cada missão irá desbloquear novas informações para você.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo5";
			Text ="Menu tutorial";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo6";
			Text ="Não se preocupe se quiser ver uma explicação ou informação novamente. Você sempre pode retornar e consultar novamente o menu do tutorial. Para fazer isso, clique no \"?\" icon in the top middle bar.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo7";
			Text ="Ajuda";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo8";
			Text ="Você pode acessar este menu se precisar de ajuda durante o jogo, onde encontrará muitas informações úteis para explicar a mecânica do jogo.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo9";
			Text ="";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.TutorialHowTo10";
			Text ="Os jogos Guild têm uma comunidade incrivelmente útil. Se o tutorial não puder responder a perguntas específicas que você possa ter, vale a pena visitar nosso site ou os fóruns.\n\nSite oficial: https://theguildgame.com\n\nCanal Discord: https://discord.gg/CGnN2Vb\n\nFórum Steam: https://steamcommunity.com/app/311260/discussions/ \n\nFórum GOG: https://www.gog.com/forum/the_guild_3";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat1";
			Text ="Combate";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat2";
			Text ="Quando as palavras não são mais eficazes, então pode ser hora de desembainhar sua espada... Você pode pegar em armas ou contratar um capanga. O número de capangas que você pode ter depende dos privilégios concedidos a você pelo seu título.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat3";
			Text ="Atacar alguém";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat4";
			Text ="Para atacar um personagem, primeiro selecione um de seus personagens. Clique na categoria Agressão e proteção na barra de ação e clique na ação Atacar alguém. Em seguida, selecione o alvo que deseja atacar.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat5";
			Text ="Envolva-se em combate";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat6";
			Text ="Você também pode participar de uma batalha que está sendo travada no momento, selecionando um dos personagens inimigos em combate como alvo do ataque. Você então intervirá diretamente no combate.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat7";
			Text ="Ganhar ou perder";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat8";
			Text ="Quando um personagem perde muitos pontos de saúde, ele fica inconsciente. Se todos os lutadores de um lado ficarem inconscientes (ou morrerem), eles perderão a batalha.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat9";
			Text ="Personagens inconscientes";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Combat10";
			Text ="Se um personagem estiver inconsciente, você pode quebrar seus ossos, roubá-lo ou até mesmo matá-lo...";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD1";
			Text ="HUD";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD2";
			Text ="Você pode acessar a maioria dos recursos do The Guild 3 usando o HUD.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD3";
			Text ="Painel Dinastia";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD4";
			Text ="Este painel mostra o brasão de sua família, seu dinheiro disponível ($(#3)) e sua influência ($(Prestige)). Você também pode abrir três menus importantes aqui: a Árvore de habilidades, onde você pode adquirir novos títulos e habilidades; o Livro de Orçamento, que mostra as estatísticas da sua dinastia; e a Árvore genealógica, que lista todos os membros da sua dinastia. Além disso, você tem acesso aos membros do seu grupo de jogadores aqui.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD5";
			Text ="Painel da cidade";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD6";
			Text ="O painel da cidade permite que você acesse o Livro das Dinastias, onde você pode encontrar todas as informações importantes sobre a sua e outras dinastias. Você também pode acessar o Livro das Guildas, onde você pode obter informações sobre as guildas, o Livro de Missões, onde você pode verificar se tem alguma tarefa em aberto, e os Registros da Cidade, que mostram todos os escritórios e leis de cada cidade.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD7";
			Text ="Painel de horário";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD8";
			Text ="Aqui você vê a hora, ano e temporada atuais, e pode definir a velocidade do jogo aqui. O tempo e as estações podem desempenhar um papel importante na jogabilidade.";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD9";
			Text ="Painel de acesso rápido";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD10";
			Text ="Este painel fornece acesso a alguns dos menus e listas mais importantes: o primeiro botão acessa o Menu Jogo. Os seguintes botões são Mostrar personagens ociosos (mostra todos os seus personagens que não estão realizando ações no momento), Edifícios (mostra uma lista de seus próprios edifícios, edifícios espionados e todos os edifícios públicos e mercados de comércio distante) e Personagens (mostra uma lista de seus familiares e funcionários vivos). Abaixo, você vê o Calendário (mostra entradas de compromissos) e o botão Ajuda (abre um menu contendo breves descrições dos elementos importantes do jogo).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD11";
			Text ="Painel de foco";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD12";
			Text ="Aqui você pode verificar o status de um personagem ou edifício selecionado, abrir uma janela de detalhes para a unidade selecionada (ícone ou letra “i” do teclado) e escolher uma ação (ícones quadrados) na barra de ação. Notificações do mundo estão localizadas acima do painel de status (dois pequenos ícones redondos).";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD13";
			Text ="Painel mundial";
		},
		LocDirectEntry
		{
			Key ="$ui.HelpTutorial.HUD14";
			Text ="O painel Mundo contém três botões. O botão “Erguer um novo edifício” (martelo) permite construir novos edifícios. O botão Mapa de área (bússola) mostra um mapa geral da área. O botão Alternar modo de câmera permite alternar entre câmera RTS e câmera livre.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.ConstructBuilding1";
			Text ="Erguer um novo prédio";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.ConstructBuilding2";
			Text ="Para construir um novo negócio, primeiro clique no botão Construir um novo edifício à esquerda da bússola no canto inferior direito do HUD.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.ConstructBuilding3";
			Text ="Selecione o edifício que deseja construir.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.ConstructBuilding4";
			Text ="Escolha um nome";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.ConstructBuilding5";
			Text ="Coloque o edifício ao lado de uma rua e o mais próximo possível de um mercado.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.Produce1";
			Text ="Produção";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.Produce2";
			Text ="Clique duas vezes na sua empresa ou selecione o edifício e, em seguida, selecione a ação Abrir menu de edifício na barra de ações.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.Produce3";
			Text ="Contrate um transportador";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.Produce4";
			Text ="Clique em Contratar funcionários na seção de transporte do menu de produção.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.Produce5";
			Text ="Contratar trabalhadores";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.Produce6";
			Text ="Clique em Contratar funcionários na seção trabalhadores do menu de produção.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.Produce7";
			Text ="Arraste um produto da lista de produtos para um de seus trabalhadores.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.BuyTitle1";
			Text ="Reivindique um título";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.BuyTitle2";
			Text ="Abra a Árvore de habilidades.";
		},
		LocDirectEntry
		{
			Key ="$ui.GuidedTutorial.BuyTitle3";
			Text ="Clique em Reivindicar título.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.BuildBuilding1";
			Text ="O primeiro passo para o sucesso é construir um negócio.\n\n1. Clique no \"Erect a new building\" button in the World panel.\n\n2. Choose Crude Craftsman's Hut from the category Businesses.\n\n3. Build the building by placing it on empty ground near to a street and the marketplace.\n\nTip! To speed up the building process, you can use the time options in the upper right corner of the screen.\n\nView more detailed information in the tutorial section (middle top bar, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ProduceItems1";
			Text ="Para completar esta missão, você precisa fabricar produtos que poderá vender mais tarde.\n\n1. Clique duas vezes no novo edifício comercial.\n\n2. Contrate pelo menos um trabalhador e um transportador. Não envie seu avatar para o trabalho, pois precisaremos do chefe da sua dinastia mais tarde.\n\n3. Arraste e solte o ferro diretamente no trabalhador ou em sua lista de pedidos e defina o número de itens para pelo menos 3 para atender aos requisitos da missão.\n\n4. Espere e observe seus funcionários trabalharem para você.\n\nDica! A produção pode ser manual, em loop ou automatizada. Para melhorar seu negócio, você pode considerar comprar complementos para seus edifícios.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Produção (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ProduceSocialItems1";
			Text ="Em sua residência, você também pode produzir itens exclusivos que não podem ser comprados no mercado. A flanela, por exemplo, pode melhorar seus atributos e tornar mais fácil cortejar um parceiro.\n\n1. Selecione a residência (ou clique em qualquer lugar se estiver dentro) e abra o menu de construção na barra de ação.\n\n2. Arraste e solte Flanela da área Itens no lado esquerdo para a Lista de pedidos no meio e escolha a quantidade.\n\n3. Faça o mesmo com o Buquê de flores.\n\n4. A ação atual do seu avatar é pausada ao enviá-lo manualmente para uma tarefa.\nCertifique-se de que seu avatar retome o trabalho encontrando o personagem no painel do trabalhador e clicando no botão Retomar trabalho. Você também pode fazer isso selecionando o personagem e clicando em Retomar trabalho na barra de ação dele.\nAguarde até que seu avatar termine os pedidos.\n\n5. Dispensa seu avatar de funcionário selecionando a ação no prédio ou na barra de ação do personagem.\n\n6. Arraste e solte a Flanela e o Buquê de flores da área de armazenamento para o inventário do seu avatar.\n\n7. Clique na categoria Consumíveis na barra de ação e selecione Flanela.\n\n8. Você pode ver um novo status aparecendo no HUD no canto inferior esquerdo, abaixo do nome do seu personagem.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Residência (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.UseSocialItems1";
			Text ="Agora você aprenderá como usar itens sociais para melhorar seus atributos, como tornar mais fácil cortejar um parceiro.\n\n1. Arraste uma Flanela e um Buquê de flores do depósito de sua residência e coloque-os no inventário do seu personagem (espaços vazios ao lado do retrato do seu personagem).\n\n2. Feche o menu de construção da sua residência.\n\n3. Selecione seu personagem.\n\n4. Abra a categoria Consumíveis na barra de ação do seu personagem.\n\n5. Clique no ícone de flanela.\n\n6. Selecione seu personagem como alvo da flanela clicando no retrato dele.\n\nLembre-se, nem todos os personagens podem usar todos os itens. Itens sociais só podem ser usados por membros da família, enquanto itens como bombas só podem ser usados por capangas.\n\nVeja informações mais detalhadas na seção do tutorial da janela do personagem (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.StartRomance1";
			Text ="O primeiro passo para constituir família é encontrar um cônjuge. Para isso, você precisa embarcar em um romance.\n\n1. Selecione seu personagem.\n\n2. Clique na categoria Romances e ligações na barra de ação.\n\n3. Clique na ação Embarcar em um romance.\n\n4. Escolha seu alvo.\n\n5. Espere até que seu personagem se aproxime do alvo. Além disso, você pode clicar nos ícones de diálogo que aparecem acima das cabeças dos personagens e escolher uma opção de diálogo.\n\n6. Aguarde o diálogo terminar. Se sua abordagem falhou, tente realizar a ação novamente.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Romances (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.CourtRomance1";
			Text ="O próximo passo é cortejar seu parceiro romântico. Ações e itens podem ajudar você a melhorar seus relacionamentos românticos.\n\n1. Selecione seu personagem.\n\n2. Clique na categoria Romances e ligações na barra de ação.\n\n3. Clique na ação Elogiar alguém e selecione seu alvo.\n\n4. Para dar flores a alguém, coloque-as no inventário e clique na categoria Consumíveis na barra de ação para escolher o Buquê de flores.\n\n5. Execute ambas as ações com sucesso duas vezes.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Romances (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.Marriage1";
			Text ="Você está noivo, mas agora é hora de levar a sério e casar!\n\n1. Selecione seu personagem.\n\n2. Clique na categoria Romances e ligações na barra de ação.\n\n3. Clique em Propor casamento.\n\n4. Escolha seu alvo e confirme sua escolha.\n\nDica! A barra de progresso da apelação é útil para avaliar a probabilidade de um personagem aceitar sua proposta.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Romances (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ProduceOffspring1";
			Text ="Agora é hora de produzir um herdeiro.\n\n1. Selecione seu personagem principal (o avatar).\n\n2. Clique na categoria Dinastia e empresas na barra de ação.\n\n3. Clique na ação Produzir descendentes (ícone com um bebê recém-nascido).\n\n4. Aguarde até que a ação termine.\n\n5. Uma notificação sobre a gravidez será exibida. Você pode verificar se a personagem feminina está grávida verificando os ícones de status.\n\nVeja informações mais detalhadas na seção do tutorial Família (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.BoastAboutExploits1";
			Text ="Você pode ganhar Influência através de diferentes ações. É hora de cuidar da sua reputação pública.\n\n1. Clique duas vezes na sua residência.\n\n2. Clique no botão Adicionar trabalhador no lado direito. Escolha seu avatar e confirme.\n\n3. Arraste e solte a ação Orgulhe-se de suas conquistas do lado esquerdo (Itens e ações) para a Lista de pedidos no meio.\n\n4. Escolha quantas vezes a ação deve ser executada. Precisa ser pelo menos 3 para atender aos requisitos da missão.\n\n5. Espere até que seu avatar termine esses pedidos.\n\nDica! Algumas ações disponíveis em sua residência são apenas para adultos ou crianças.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Residência (barra superior central, \"?\" icon on the right.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ClaimTitle1";
			Text ="Mais uma vez é hora de adquirir um “título superior” que abra mais oportunidades para você. Os títulos representam seu lugar na hierarquia social e concedem novos privilégios, ações e o direito de possuir mais negócios.\n\n1. Clique no ícone da Árvore de habilidades (o primeiro ícone no canto superior esquerdo do HUD).\n\n2. Uma lista de todos os títulos é exibida à esquerda. Clique no botão Reivindicar título para obter um novo título.\n\n3. Reivindique o título Yeoman.\n\nVeja informações mais detalhadas na seção do tutorial Títulos e habilidades (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.DriveWorkers1";
			Text ="Seu novo título permite que você use a ação Estimule seus funcionários para aumentar a produtividade deles.\n\n1. Selecione seu personagem.\n\n2. Clique na categoria Dinastia e negócios na barra de ação e selecione a ação Conduza seus trabalhadores.\n\n3. Em seguida, selecione o prédio da sua empresa no mundo ou no Painel de acesso rápido no lado direito do HUD.\n\n4. Repita a ação quando puder usá-lo novamente.\n\nVeja informações mais detalhadas na seção do tutorial Títulos e habilidades (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ProduceMoreItems1";
			Text ="Depois de melhorar suas habilidades, você poderá produzir outros itens mais valiosos. Para completar esta missão, você precisa alterar os produtos que está fabricando atualmente. Adicione Adagas e Acessórios à lista de pedidos. Se quiser acelerar o andamento, você pode cancelar os pedidos anteriores.\n\nDica! Lembre-se, seus familiares também podem trabalhar em seus negócios.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Produção (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.BuildAnotherBuilding1";
			Text ="Para ter sucesso no The Guild 3, você deve possuir mais de um negócio. É aconselhável ter múltiplas fontes de renda e expandir seu poder.\n\n1. Clique no botão Erguer um novo edifício (canto inferior direito no HUD).\n\n2. Selecione seu próximo negócio, como uma Fundição).\n\n3. Renomeie-o se desejar.\n\n4. Selecione o local certo para construir sua construção.\n\nVeja informações mais detalhadas na seção do tutorial Erguer construção (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ClaimHigherTitle1";
			Text ="Seu próximo objetivo importante é adquirir o título de Cidadão. Produza, impulsione seus funcionários, melhore sua reputação e ganhe influência. Mas tente, acima de tudo, ganhar moedas suficientes para pagar o título. Não se esqueça de comprar atualizações para sua construção.\n\nVeja informações mais detalhadas na seção do tutorial Produção (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ApplyForOffice1";
			Text ="Como cidadão, você recebeu o direito de se candidatar a um cargo. Os escritórios dão acesso a ações especiais e permitem propor alterações nas leis da cidade.\n\n1. Clique no ícone Registros da cidade na barra central superior.\n\n2. Encontre qualquer cargo de nível mais baixo que tenha um ícone de pena, o que significa que você pode se inscrever imediatamente.\n\n3. Clique na pena, depois clique no botão Aplicar e selecione seu personagem.\n\n4. Se nenhum cargo estiver aberto para inscrição, você também pode clicar nos ícones do calendário para ver quando um cargo será eleito novamente.\n\n4. Enquanto espera pela eleição, você deve tentar aumentar sua reputação junto aos nomeadores. Isso pode ser feito realizando ações específicas (por exemplo: Pedir um favor) ou usando itens (por exemplo, Envio imponente).\n\n5. Passado o tempo de votação, você saberá se foi votado ou não.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ExecuteOfficeAction1";
			Text ="Agora que você ocupa um cargo, é hora de usar os privilégios do escritório a seu favor.\n\n1. Selecione o titular do cargo recém-eleito.\n\n2. Clique na categoria Diplomacia e Política na barra de ação. Você pode explorar as ações recém-adicionadas!\n\n3. Clique na ação Influenciar a opinião pública.\n\n4. Você entrará imediatamente na cena da votação. Clique no botão Influenciar a opinião pública ao lado do brasão de uma dinastia cuja reputação você gostaria de mudar.\n\nDica! Lembre-se, como titular de um cargo, você ganha dinheiro e influência a cada rodada.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Política e Escritórios (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.HireHenchmen1";
			Text ="Quanto mais poderosa sua dinastia se tornar, mais inimigos você fará. Para proteger sua família, você pode contratar um capanga.\n\nVocê pode fazer isso selecionando qualquer construção de sua propriedade e clicando na ação Contratar um capanga na barra de ação da construção. \n\nDica! O número de capangas que você pode empregar depende do seu título.\n\nInformações detalhadas podem ser encontradas na seção do tutorial Combate (barra superior central, \"?\" icon on the right).";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.ExecuteGuardAction1";
			Text ="Agora proteja seu Avatar. Use a ação Escoltar alguém na barra de ação do seu capanga e selecione seu avatar como alvo.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.Attack1";
			Text ="A paz acabou! Selecione seu avatar e envie-o para atacar um membro de uma dinastia concorrente. Se você quiser aumentar suas chances de sucesso, compre uma arma e uma armadura no mercado e equipe seu avatar adequadamente.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters3";
			Text ="Hierarquia familiar";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters4";
			Text ="No topo da sua família está o chefe da família, seu avatar! O avatar é o personagem mais valioso e, quando morrer, seu herdeiro será o novo chefe da família e, portanto, seu avatar.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters5";
			Text ="Cônjuge";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters6";
			Text ="O cônjuge é a melhor metade do seu avatar. Você deve ter um cônjuge para produzir descendentes.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters7";
			Text ="Herdeiro";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters8";
			Text ="Seu herdeiro será o próximo líder de sua família. Portanto, você deve preparar e nutrir esse personagem desde o início, para que mais tarde ele prove ser um avatar digno.";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters9";
			Text ="Crianças";
		},
		LocDirectEntry
		{
			Key ="$ui.GameplayConceptTutorial.Characters10";
			Text ="As crianças da sua dinastia tornam-se jogáveis ​​quando atingem a idade de 5 anos. As crianças têm um conjunto especial de ações disponíveis até crescerem.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.DeclareFeud1";
			Text ="Vamos oficializar! Declare uma rivalidade contra uma dinastia que você odeia. Selecione a dinastia e clique na ação Declarar uma rivalidade com alguém na barra de ação.\n\n1. Abra o Livro das Dinastias\n\n2. Selecione uma dinastia com a qual você deseja declarar uma rivalidade\n\n3. Selecione um personagem dessa família\n\n4. Na barra de ação deste personagem selecione Declarar uma rivalidade com alguém";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.MakeAnAlliance1";
			Text ="Você não pode apenas ter inimigos, você também precisa de amigos! Encontre uma dinastia com a qual você gostaria de estabelecer uma aliança.\n\nPara propor uma aliança, selecione um membro ou edifício da dinastia e clique em Comércio de Dinastia. Lá você pode propor a entrada em uma aliança.\n\nDica! Outras dinastias raramente unirão forças com você se você não lhes oferecer algo de valor. Você também precisa ter uma boa reputação com eles e ocupar uma posição próxima a eles na visão geral dos lucros.\n\nA visão geral dos lucros pode ser visualizada no livro de orçamento. Veja informações mais detalhadas na seção Tutorial de estatísticas.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.IncreaseMoney1";
			Text ="Simples: fique rico! Usando qualquer meio.";
		},
		LocDirectEntry
		{
			Key ="$ui.TutorialQuest.IncreasePrestige1";
			Text ="O dinheiro por si só não o tornará poderoso. Então é por isso que você deve tentar adquirir influência suficiente para controlar a cidade a seu critério.";
		},
		LocDirectEntry
		{
