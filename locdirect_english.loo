		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v3.bb_intim";
			Text ="Esse argumento não é convincente. O ouro é apenas um objeto temporal, a fé é para a eternidade.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v4.int_intim";
