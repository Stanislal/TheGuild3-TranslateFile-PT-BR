		},
		LocDirectEntry
		{
			Key ="$quickmessage.drought";
			Text ="Ocorreu uma seca severa!";
		},
		LocDirectEntry
		{
			Key ="$quickmessage.iciness";
			Text ="O gelo está a assolar o país e todas as estradas e rotas estão congeladas.";
		},
		LocDirectEntry
		{
			Key ="$quickmessage.mainbuildingchanged";
			Text ="A nova residência da Dinastia é agora: %building%";
		},
		LocDirectEntry
		{
			Key ="$quickmessage.rainfall";
			Text ="A chuva persistente está causando inundações!";
		},
		LocDirectEntry
		{
			Key ="$quickmessage.snowstorm";
			Text ="Uma forte tempestade de neve está assolando a área!";
		},
		LocDirectEntry
		{
			Key ="$quickmessage.soldbuildingonsale";
			Text ="Um edifício foi vendido: %building%";
		},
		LocDirectEntry
		{
			Key ="$quickmessage.thunder";
			Text ="Uma forte tempestade está assolando a região!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.1";
			Text ="Em um culto na igreja, %fullname% cheira você aparentemente por coincidência antes de fazer uma careta.\n\nParece que sua nova eau de toilette não agrada aos narizes refinados da família %dynasty%...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.10";
			Text ="Por cantar músicas indecentes em uma taverna você é condenado a uma multa de %coins%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.11";
			Text ="Na competição anual de menestréis em %neighborhood% em %city%, você afunda um pouco demais em sua caneca. Isso leva você a decidir se tornar um participante ativo em vez de apenas um membro do público, momento em que você sobe no palco e canta sua música favorita.\nNo entanto, em vez de aplausos entusiasmados, você não recebe nada além de risadas...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.12";
			Text ="Vestido com suas melhores roupas, você parte para o festival anual do repolho em %city%, enquanto alguém inadvertidamente esvazia seu penico pela janela bem aos seus pés. Não tendo mais certeza de quais maldições e insultos você lançou sobre os residentes, talvez você deva evitar o distrito %neighborhood% por enquanto...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.13";
			Text ="Ao caminhar pelo distrito %neighborhood% de %city%, você percebe que os moradores olham fixamente para você e muitos até se afastam de você.\nO que há de errado com essas pessoas de repente permanece um mistério...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.14";
			Text ="Enquanto caminha pelo bairro %neighborhood% de %city%, você afasta um mendigo chato. Eles tropeçam e derrubam alguns andaimes ao cair, ferindo vários moradores no processo. Quando a poeira baixar, é claro que você já terá desaparecido na próxima esquina.\nA distância você pode ouvir pessoas amaldiçoando seu nome...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.15";
			Text ="Você irritou um membro renomado do conselho %city% com muita frequência. Você é advertido e colocado em seu lugar na próxima reunião pública no mercado %neighborhood%.\nAs pessoas lá se divertem e mais de uma delas aponta o dedo para você rindo!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.16";
			Text ="Na recepção de um funcionário estadual na prefeitura você se dirigiu ao convidado mais importante usando o título errado. Após esta indignação, você deve assumir que sua reputação no país se deteriorou.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.17";
			Text ="Um amigo do tribunal de %kingdom% escreveu-lhe recentemente uma carta indicando que a sua outrora boa reputação lá foi prejudicada. Ele aconselha você a evitar, no futuro, explicar aos comerciantes estrangeiros que nosso %king% é um idiota...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.18";
			Text ="O que quer que tenha levado você a acreditar que os carismáticos comerciantes estrangeiros realmente venderiam você 1 \"%itemname%\" for a mere %coins%, at least you learned something out of it...\nFor when you finally open the bag, all it holds is a measly 1 %resourcename%! Of course, by this time the scoundrel was long gone...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.19";
			Text ="De um dia para outro, %employee%, que trabalhava em %building%, deixa de comparecer ao trabalho. Alguém informa que %employee% é procurado pela guarda municipal e provavelmente já saiu da cidade.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.2";
			Text ="Por acaso, você vê %fullname% acidentalmente pisar em uma pilha de esterco de vaca no mercado e eles começam a xingar freneticamente.\nAo passar, você se vê incapaz de conter o riso por mais tempo. O olhar irritado que %fullname% lhe dá revela que isso não ajudou em nada o seu relacionamento com a família %dynasty%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.20";
			Text ="%employee%, que trabalha em %building%, chega bêbado ao trabalho e se recusa a seguir suas instruções. Portanto, você envia %employee% embalado com uma bota robusta na parte traseira.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.21";
			Text ="Você irritou um membro renomado do conselho %city% com muita frequência. Na próxima reunião do conselho, você será solicitado a se explicar e receberá um aviso rude.\nOs outros conselheiros estão claramente divertidos!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.22";
			Text ="No mercado, você discute com entusiasmo os últimos rumores sobre %sovereign% com um trader. Infelizmente, você não percebe que um membro da família do soberano está ouvindo cada palavra sua. Ai de você...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.23";
			Text ="Você parece ter pisado no pé de alguém com muita frequência! Você acorda em uma rua lateral com o lábio sangrando e as costelas doloridas. Tudo o que você lembra é que percebeu dois personagens te seguindo, e depois disso sua memória ficou um pouco turva...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.24";
			Text ="No melhor dos humores, você caminha pelo mercado, onde acidentalmente esbarra em uma velha cuja cesta de ervas recém colhidas cai na lama. Ela simplesmente lhe lança um olhar maligno e murmura algo ininteligível antes de desaparecer na multidão...\nPouco depois você percebe que sua suspeita estava correta, pois a velha amaldiçoou você: %malediction%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.25";
			Text ="Você coloca moedas %coins% em um santuário e pede saúde, vida longa, riqueza incalculável e felicidade eterna.\nMas o santo pode ter entendido você mal, porque parece que ele te amaldiçoou: %malediction%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.3";
			Text ="Você acidentalmente soltou um peido em uma execução pública. Embora isso não seja nada particularmente questionável por si só, %fullname% infelizmente estava atrás de você naquele momento.\nA família %dynasty% doravante evita você e os seus, especialmente em eventos públicos.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.4";
			Text ="Tomando uma caneca de cerveja em uma taverna, você inicia uma conversa animada com outro convidado. Ao enfatizar uma de suas declarações com um amplo movimento de braço, você acidentalmente derrama um pouco de cerveja nas roupas de %fullname%.\nApesar de seu sincero pedido de desculpas, você ainda é alvo de um olhar fulminante. Não é preciso muita imaginação para perceber que toda a família %dynasty% vai levar isso \"accident\" the wrong way...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.5";
			Text ="%fullname% aparece de repente atrás de uma árvore do nada, olha para você com condescendência e diz: \"I don't like you!\"\nIn your amazement you barely manage to utter: \"why not?\" as %fullname% has already turned and is walking away with a sneer. Well, whatever it was, it is obvious that the %dynasty% family doesn't like you any more...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.6";
			Text ="Você perdeu %coins% em um negócio de contrabando terrivelmente fracassado.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.7";
			Text ="Você tem que pagar um adicional de %coins% no dízimo da igreja.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.8";
			Text ="Um comerciante estrangeiro aparentemente sério convence você em um momento de fraqueza a comprar algumas terras na recentemente redescoberta ilha de Atlântida.\nVocê recebe 13 1/2 hectares pelo preço de banana de apenas %coins%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.9";
			Text ="Tarde demais, você percebe que foi vítima de um batedor de carteira. Agora está faltando uma bolsa contendo %coins% moedas.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.narration.1";
			Text ="Você é um incômodo público!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.narration.2";
			Text ="Ah, querido!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.narration.3";
			Text ="Alguém não gosta de você!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.narration.4";
			Text ="Você é muito azarado!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.negative.narration.5";
			Text ="Isso também não...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.1";
			Text ="Você recebe notícias da última moda de Paris primeiro, então decide prender várias fitas coloridas em seu chapéu.\nIsso faz com que os tacanhos habitantes da cidade sorriam para você com desconfiança...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.10";
			Text ="Um gato preto cruza seu caminho da direita para a esquerda... agora você se pergunta: você é supersticioso?";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.11";
			Text ="Essa é a última vez que você bebe a cerveja Guntram... Se você não tivesse passado tanto tempo olhando pelo fundo de um copo ontem à noite, você não teria tanta dor de cabeça hoje. Aprenda com seus erros!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.12";
			Text ="Ontem à noite você viu uma estrela cadente. Foi um anjo caindo do céu para a terra?";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.13";
			Text ="Você sempre se perguntou qual a probabilidade de ser atingido por um raio. A resposta é metade da probabilidade de você compreender completamente a criação de Deus! No entanto, como Deus usa um raio como punição para os pecadores, pode haver uma maneira de influenciar essa probabilidade...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.14";
			Text ="Você ouviu recentemente que eles criaram novas regras para o xadrez; estes incluem roque. Você certamente poderá usar isso a seu favor em seu próximo jogo.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.15";
			Text ="Mais uma vez, você está perdido em seus próprios pensamentos e finalmente chega à conclusão de que, embora um saco cheio de moedas possa não te fazer feliz, pode ter um efeito extremamente tranquilizador...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.16";
			Text ="Mais uma vez, sua bolsa está cheia de tantas moedas que seu cinto está caído em um ângulo perigoso e suas calças ameaçam escorregar. Notas de títulos escritas em pergaminho ou papel seriam muito mais fáceis, mas provavelmente nunca vão pegar...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.17";
			Text ="Durante uma caminhada pela cidade você vê um homem assobiando alegremente enquanto bate em uma porta e grita: \"Open, my dear wife, for I am home again\".\nAs the man enters the house, a window on the first floor opens and a half-naked man with a bundle of clothes under his arm hurriedly climbs out...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.18";
			Text ="\"Hey, I have something for you\".\nWith a smile that could melt icebergs, a little girl hands you a daisy.\n\"This should bring you luck. I think you need it more than I do!\"";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.19";
			Text ="Um cachorro cochilando à beira da estrada se levanta de repente e, como que por acaso, roça em suas calças. Você acha que viu vários pontos pretos saltarem de seu pelo para você... \nVocê corre para o porco chafurdado mais próximo, onde rapidamente se senta e cobre suas calças com lama.\nUfa, isso deve livrar-se de até a última daquelas pulgas!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.2";
			Text ="Em um sonho, você está voando como um pássaro pelos países e águas do nosso mundo para finalmente voltar para casa, mesmo que continue voando em linha reta!\nSem mais delongas, você pega o mapa-múndi da parede da sua sala de trabalho e cola-o em um grande globo de madeira. Seus parceiros de negócios são de fato \"somewhat\" irritated, but they leave you your little foible...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.20";
			Text ="Um saco de trigo cai em Constantinopla!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.21";
			Text ="Andando pelo mercado você encontra um documento amarelado. Com um pouco de esforço você consegue decifrar as palavras \"this is the Song of the Nibelungs\". You shrug an put it back.\nShortly thereafter an obviously learned man picks up the document and joyously shouts: \"What an incredible find! This will earn me a fortune!\"";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.22";
			Text ="Você recebe uma bênção disfarçada. Se você não tivesse pisado em um cocô de vaca fresco e parado irritado, você teria sido atropelado por uma carroça puxada por cavalos apenas um segundo depois...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.3";
			Text ="Uma carroça puxada por cavalos corre imprudentemente pela estrada através de um sulco lamacento. Se você não tivesse se esquivado rapidamente, suas roupas finas estariam agora salpicadas de sujeira fétida...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.4";
			Text ="Seu pai sempre lhe disse para ser sempre diligente e honesto. Você deveria seguir seu sábio conselho!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.5";
			Text ="Por direito, você tem negócios importantes para resolver hoje, mas simplesmente não consegue se concentrar... você realmente trancou a porta de sua casa corretamente antes de sair? Há tantos bandidos por aí...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.6";
			Text ="Você está caminhando despreocupado pelo seu caminho quando de repente alguém puxa seu cinto e, com um movimento rápido de faca, corta os cordões de sua bolsa. E antes que você possa chamar o guarda, ele já desapareceu em uma rua lateral. Pouco depois você ouve um \ abafado"bong\" from the same street. You take a look and can't help gasping a sigh of relief: the brazen thief collided head first with the breastplate of a city guard when he ran around the corner. Now the villain is lying unconscious on the ground...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.7";
			Text ="Que sonho maravilhoso você teve ontem à noite!\nNão, foi mais como uma visão!\nPorque você sonhou com uma refeição tão deliciosa, que só o seu paladar poderia realmente apreciá-la: \"cheese on toast\" will be your favourite dish from now on...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.8";
			Text ="De repente, você sente uma vontade irresistível de comer uma batata. Mas onde você poderia conseguir um? E é assim que você tem que suprimir o seu desejo, mas não pode esquecê-lo...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.9";
			Text ="Você está simplesmente cansado de sempre poder comer apenas com a mão direita. Por que ninguém inventa um pano ou papel com o qual você possa limpar o traseiro depois de visitar o banheiro?";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.narration.1";
			Text ="Você é um visionário!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.narration.2";
			Text ="Está tudo bem";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.narration.3";
			Text ="A vida é assim...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.narration.4";
			Text ="Isso é muito lamentável";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.neutral.narration.5";
			Text ="Isso certamente será útil";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.1";
			Text ="Devido a uma feliz coincidência você conseguiu evitar um ataque a um prédio pertencente a %fullname%.\nVocê pode ter certeza da gratidão da família %dynasty%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.10";
			Text ="Você ganha %coins% com a especulação imobiliária.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.11";
			Text ="Você estava a caminho de uma reunião importante com um parceiro de negócios em %neighborhood% em %city% quando um cavalo de carroça se assustou e galopou direto em direção a uma garotinha. Você imediatamente entrou em ação e resgatou a garota!\nOs habitantes do distrito estão impressionados com sua bravura heróica!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.12";
			Text ="Você caminha alegremente pelo distrito %neighborhood% de %city% e se aproxima de todos que encontra com uma saudação amigável. Embora as pessoas estejam realmente surpresas, elas sorriem de volta para você.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.13";
			Text ="Seus negócios no distrito %neighborhood% em %city% trouxeram riqueza para muitos dos cidadãos que vivem lá. Você é recebido de uma forma muito mais amigável do que antes sempre que está no distrito.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.14";
			Text ="Por capricho, você não manda jogar aos porcos as sobras da festa de ontem em sua residência. Em vez disso, você os dá para alimentar os pobres no distrito %neighborhood% em %city% e garante que o nome do nobre doador seja divulgado a todos.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.15";
			Text ="Você deu a uma menina pobre do distrito %neighborhood% de %city% um pedaço de pão seco. E no dia seguinte todo o distrito soube da sua caridade. Talvez você devesse distribuir pão aos pobres com mais frequência...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.16";
			Text ="O relatório de viagem de um alto funcionário do estado que visitou recentemente a cidade menciona explicitamente a sua dinastia. Sua reputação no reino aumenta de acordo.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.17";
			Text ="Um de sua confiança \"informants\" reports to you that hostile forces are planning to poison your ruler... You therefore immediately send a despatch to the court of %kingdom%. You can rest assured that your name will now certainly receive more attention there.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.18";
			Text ="Você encontra 1 %itemname% na estrada, reconhecidamente com sinais de desgaste, mas em muito bom estado.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.19";
			Text ="Você simplesmente não pode recusar um acordo como este: você pode comprar 1 %itemname% por apenas %coins% moedas de um comerciante claramente em desvantagem mental.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.2";
			Text ="No mercado você percebe que as calças de %fullname% não estão tão abotoadas quanto deveriam. Graças à sua dica discreta, a família %dynasty% é poupada de uma situação embaraçosa, o que aumenta sua posição e favorecimento junto a eles.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.20";
			Text ="Bem, isso foi incrível... Para comemorar o dia do nome de um parente distante, você leva várias garrafas de vinho para uma reunião na prefeitura. Embora, em retrospecto, nenhuma decisão significativa tenha sido tomada, provou ser uma ocasião realmente alegre.\nOs membros do conselho em %city% estão, em qualquer caso, gratos a você pela pequena diversão...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.21";
			Text ="Em um campo perto da cidade você encontra um broche com o brasão da família %sovereign%. É claro que você corre imediatamente para a residência do soberano e devolve a peça valiosa.\nVocê pode ter certeza do agradecimento de %sovereign%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.22";
			Text ="Perdido em pensamentos, você coloca algumas moedas ao lado de uma cruz na beira da estrada e faz uma oração. De repente, uma música incrivelmente adorável ressoa em seus ouvidos e você vê uma luz... Você recebe assim %xp% pontos de experiência.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.23";
			Text ="Por apenas %coins% moedas você pode pedir a uma cartomante para contar o seu futuro. Embora pareça que o destino tem muitas aventuras reservadas para você, agora você está mais rico em %xp% pontos de experiência...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.24";
			Text ="Você finalmente foi ouvido! Todos os dias da sua vida você orou fielmente e agora acordou sentindo uma nova e maravilhosa força: %blessing%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.25";
			Text ="Perdido em pensamentos, você deita %coins% próximo a uma cruz à beira da estrada e faz uma oração. De repente você ouve uma voz alta e clara em seu ouvido:\n\"Fear not, for the Lord has sent me to you as his protecting hand!\"\nYou feel strengthened and full of energy, for God's own angel has blessed you: %blessing%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.3";
			Text ="Por acaso você percebe um batedor de carteira prestes a cortar a bolsa de %fullname%. Sem hesitar um momento, você afasta o ladrão.\nToda a família %dynasty% expressa sua gratidão a você.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.4";
			Text ="Alguém contratou um assassino para matar %fullname%! Você, porém, estava no lugar certo na hora certa e foi capaz de assustar o vilão com um alto grito de \"murderer! Help!\".\nThe %dynasty% family is most grateful.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.5";
			Text ="Num debate público sobre direitos comerciais, você fica do lado de %fullname%.\nEmbora você não tivesse necessariamente a intenção de fazê-lo, a família %dynasty% agora parece vê-lo de forma mais favorável.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.6";
			Text ="Você ganhou %coins% jogando cartas depois da igreja!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.7";
			Text ="A morte de um parente distante traz para você uma herança de %coins%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.8";
			Text ="Em um campo fora da cidade você encontra alguns fragmentos antigos.\nApesar de sua insistência de que eles não passam de bugigangas, você recebe uma bolsa no mercado contendo uma recompensa de %coins% pela sua descoberta.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.9";
			Text ="O conselho municipal decidiu reembolsar %coins% dos impostos pagos em excesso.\nFinalmente!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.narration.1";
			Text ="A sorte está do seu lado!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.narration.2";
			Text ="Alguém gosta de você!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.narration.3";
			Text ="Algo incrível está acontecendo com você!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.narration.4";
			Text ="Você é respeitado!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.positive.narration.5";
			Text ="Você esperou muito tempo por isso!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Clothing";
			Text ="Ei! É semana de moda em %city%. A Tailors' Guild está organizando uma competição para ver quem será o estilista mais vanguardista! Envie seu mais lindo %productcategory% até %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Food";
			Text ="Uma fome terrível estourou em %city%. A casa de contabilidade da cidade está buscando urgentemente %productcategory% até %date% e está pronta para pagar preços altos!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Luxury";
			Text ="O arcebispo visitará a cidade de %city%. Então o prefeito está desesperado por um %productcategory% como presente para Sua Santidade. Ele está preparado para pagar preços altos até %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Weapon";
			Text ="Ouça, ouça! O conselho de %city% está convocando seus cidadãos às armas. Corra, pois a demanda será muito alta para %productcategory% até %date%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Clothing";
			Text ="Atenção! Um grupo de comerciantes de terras estrangeiras chegou a %city%. Eles estão oferecendo %productcategory% a bons preços. Os comerciantes permanecerão na área até %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Food";
			Text ="Devido a uma colheita excepcionalmente boa, a casa de contagem de %city% pode oferecer %productcategory% a preços razoáveis. Corra, pois esta oferta termina em breve: %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Luxury";
			Text ="Pssiu! Como sempre, um estranho desconhecido colocou as mãos em algum %productcategory%. Ele agora deve vendê-los até %date% em %city%, e está preparado para lhe fazer um bom negócio...";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Weapon";
			Text ="A cidade de %city% está vendendo %productcategory% de seu arsenal a preços baratos até %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Tinctury";
			Text ="Há rumores de que a Guilda dos Alquimistas em %city% precisa limpar seu armazém antes que alguns de seus produtos expirem. Eles querem vender %productcategory% até %date% por um bom preço.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Tinctury";
			Text ="Um grupo de cavalheiros que escondem seus rostos sob longos capuzes estará comprando %productcategory% a preços altos até %date%. Encontre-os em um beco escuro em %city% - senha: 'queijo com torrada'!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Livestock";
			Text ="Ouça, ouça! Os agricultores de %city% querem se livrar dos seus excedentes %productcategory% e os colocam à venda a bons preços até: %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Livestock";
			Text ="Devido a uma seca horrível em %city% os agricultores perderam quase todos os seus %productcategory% e estão agora dispostos a pagar preços elevados até: %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.RawMaterials";
			Text ="A casa de contagem em %city% está atualmente oferecendo %productcategory% a preços muito vantajosos. Porém, a oferta terminará em breve: %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.RawMaterials";
			Text ="A demanda por %productcategory% em %city% é atualmente maior que a quantidade disponível. Os compradores estão, portanto, dispostos a pagar preços elevados até, no máximo, %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Trinkets";
			Text ="Uma grande venda no mercado de %productcategory% a preços baixos está sendo realizada atualmente em %city%. Corra, pois o mercado fechará em breve: %date%!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Trinkets";
			Text ="Devido à falta de bens comerciais, %city% está disposto a comprar %productcategory% a preços elevados. A demanda terminará em breve no dia %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Components";
			Text ="Ouça, ouça! Os artesãos de %city% querem se desfazer de seus excedentes %productcategory% e os colocam à venda a bons preços até: %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Components";
			Text ="A cidade de %city% precisa de %productcategory% para construir um novo projeto de construção urbana para homenagear seu soberano. Os artesãos estão pagando bons preços até %date%.";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Offer.Transportation";
			Text ="Seus transportadores precisam de carrinhos maiores para transportar todos os seus produtos até o mercado? Então você está com sorte! A cidade de %city% está vendendo itens %productcategory% até %date% por quase nada!";
		},
		LocDirectEntry
		{
			Key ="$randomEvents.TradeMarket.Demand.Transportation";
			Text ="Os cidadãos de %city% precisam desesperadamente de %productcategory%. Mas a demanda terminará em breve: %date%.";
		},
		LocDirectEntry
		{
			Key ="$Rapier";
			Text ="Rapieira";
		},
		LocDirectEntry
		{
			Key ="$RapierDesc";
			Text ="Mais leve e elegante que uma espada comum. O uso de um florete requer maior habilidade, pois é uma arma de esgrima e não de lâmina.";
		},
		LocDirectEntry
		{
			Key ="$reason.MaxBusiness";
			Text ="Número máximo de empresas alcançadas";
		},
		LocDirectEntry
		{
			Key ="$reason.MissingRequiredNobilityTItle";
			Text ="Você precisa do seguinte título %nobility%";
		},
		LocDirectEntry
		{
			Key ="$reason.MissingRequiredSkill";
			Text ="Você precisa da seguinte habilidade: %skill%";
		},
		LocDirectEntry
		{
			Key ="$reason.NotEnoughMoney";
			Text ="Dinheiro insuficiente";
		},
		LocDirectEntry
		{
			Key ="$RemainingXPPoints";
			Text ="Pontos de experiência grátis:";
		},
		LocDirectEntry
		{
			Key ="$Responsabilities";
			Text ="Missões";
		},
		LocDirectEntry
		{
			Key ="$revolt.1";
			Text ="Queime-os! Queime suas casas!";
		},
		LocDirectEntry
		{
			Key ="$revolt.10";
			Text ="Acenda-o!";
		},
		LocDirectEntry
		{
			Key ="$revolt.2";
			Text ="Abaixo a escória!";
		},
		LocDirectEntry
		{
			Key ="$revolt.3";
			Text ="Boooh!";
		},
		LocDirectEntry
		{
			Key ="$revolt.4";
			Text ="Pendure todos eles!";
		},
		LocDirectEntry
		{
			Key ="$revolt.5";
			Text ="Poder ao povo!";
		},
		LocDirectEntry
		{
			Key ="$revolt.6";
			Text ="Queime-os!";
		},
		LocDirectEntry
		{
			Key ="$revolt.7";
			Text ="Não vamos tolerar isso!";
		},
		LocDirectEntry
		{
			Key ="$revolt.8";
			Text ="Saiam, seus cães covardes!";
		},
		LocDirectEntry
		{
			Key ="$revolt.9";
			Text ="Vamos! Vamos demolir a casa!";
		},
		LocDirectEntry
		{
			Key ="$Rhetoric";
			Text ="Retórica";
		},
		LocDirectEntry
		{
			Key ="$RhetoricDesc";
			Text ="Se você aprender a arte da retórica, doravante será capaz de usar a palavra escrita ou falada de forma eficaz como bajulação ou como arma contra seus concorrentes.";
		},
		LocDirectEntry
		{
			Key ="$RhetoricPrivate";
			Text ="Sedutor";
		},
		LocDirectEntry
		{
			Key ="$RhetoricPrivateDesc";
			Text ="Domine a arte de seduzir e você será capaz de usar suas palavras, expressões e gestos para envolver outras pessoas em seu dedo mínimo.";
		},
		LocDirectEntry
		{
			Key ="$RhetoricPublic";
			Text ="Eloqüência";
		},
		LocDirectEntry
		{
			Key ="$RhetoricPublicDesc";
			Text ="Esta habilidade fará de você um orador magistral, capaz de atrair seu público sob seu feitiço.";
		},
		LocDirectEntry
		{
			Key ="$RidingHorse";
			Text ="Cavalgando";
		},
		LocDirectEntry
		{
			Key ="$RidingHorseDesc";
			Text ="Andar a cavalo não apenas permite que você chegue ao seu destino mais rapidamente, mas também o eleva acima da sujeira e da sujeira da cidade para evitar que suas roupas caras fiquem sujas nas ruas imundas.\nE sim, um cavalo de montaria também tem alforjes nos quais você pode carregar coisas.";
		},
		LocDirectEntry
		{
			Key ="$RoastBeef";
			Text ="Rosbife";
		},
		LocDirectEntry
		{
			Key ="$RoastBeefDesc";
			Text ="Enquanto o cidadão da classe alta recua diante do estalo gorduroso de um porco assado, ele começará a salivar ao ver um suculento pedaço de rosbife. Assim, o rosbife é a refeição desejada e condizente com o cidadão abastado.";
		},
		LocDirectEntry
		{
			Key ="$Rogue";
			Text ="Ladino";
		},
		LocDirectEntry
		{
			Key ="$RogueDesc";
			Text ="O caminho do ladino é realmente uma profissão obscura. Aqui, roubos e contravenções se misturam à nobre ou menor integridade do lansquenet.";
		},
		LocDirectEntry
		{
			Key ="$RubinStaff";
			Text ="Equipe Ruby";
		},
		LocDirectEntry
		{
			Key ="$RubinStaffDesc";
			Text ="Andar por aí com uma equipe incrustada de rubi aumenta sua reputação junto a todos os cidadãos.";
		},
		LocDirectEntry
		{
			Key ="$RunForOffice";
			Text ="Candidatura a cargo";
		},
		LocDirectEntry
		{
			Key ="$RunForOfficeDesc";
			Text ="Este privilégio permite que você ocupe um cargo político na prefeitura de sua cidade.";
		},
		LocDirectEntry
		{
			Key ="$Sabotage";
			Text ="Edifício de sabotagem";
		},
		LocDirectEntry
		{
			Key ="$SabotageDesc";
			Text ="Sabote o prédio de um de seus concorrentes para reduzir a produtividade do prédio e a satisfação do cliente.";
		},
		LocDirectEntry
		{
			Key ="$Salt";
			Text ="Sal";
		},
		LocDirectEntry
		{
			Key ="$SaltDesc";
			Text ="O sal sempre foi um dos produtos mais importantes. Algumas cidades e seus comerciantes ficaram extremamente ricos com o sal.";
		},
		LocDirectEntry
		{
			Key ="$SandingBlock";
			Text ="Lixar tijolo";
		},
		LocDirectEntry
		{
			Key ="$SandingBlockDesc";
			Text ="Os tijolos de lixa são usados para rebarbar ferramentas, afiar lâminas ou alisar superfícies.";
		},
		LocDirectEntry
