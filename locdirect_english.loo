		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.cha.toMale";
			Text ="Meu concidadão! Se você apoiar minha família, podemos tornar esta cidade um lugar melhor. Para um amanhã mais brilhante!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.cha.toFemale";
			Text ="Meu concidadão! Se você apoiar minha família, podemos tornar esta cidade um lugar melhor. Para um amanhã mais brilhante!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.cha";
			Text ="Isso parece maravilhoso!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.cha";
			Text ="Apoia você e o resto de sua família ridícula? Não, obrigado, prefiro beijar um leproso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.cha.female";
			Text ="Apoia você e o resto de sua família ridícula? Não, obrigado, prefiro beijar um leproso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.intim";
			Text ="Você sabe quem você deve apoiar...";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.intim";
			Text ="Ei! Você! Sim, você sabe de quem é a família que deve sustentar, certo? Fui claro?";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.intim";
			Text ="Eu... uhm... s... sim... claro.";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.intim";
			Text ="Hahaha! Que ridículo! Você não me intimida!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.openLine.str";
			Text ="Precisamos de líderes fortes!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fullLine.str";
			Text ="Precisamos de líderes fortes! E MINHA família tem os braços fortes e as costas fortes necessárias para governar melhor nossa cidade!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.sAnswer.str";
			Text ="Você está certo! Precisamos de sua liderança forte com mais urgência do que nunca!";
		},
		LocDirectEntry
		{
			Key ="$d.act.goCamp.fAnswer.str";
			Text ="O quê?! Somos líderes com ideias, e não apenas músculos. Não estamos mais nos anos 1300!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.per";
			Text ="Trabalho de baixa qualidade...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.per";
			Text ="Seus produtos são de tão baixa qualidade que eu queimaria meus negócios de vergonha se fosse você!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.per";
			Text ="*soluçando*";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.per";
			Text ="Sinto muito...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.per";
			Text ="Como você ousa?! Você não é tão inteligente quanto pensa que é! Meus negócios produzem apenas produtos da mais alta qualidade!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.per";
			Text ="Hahaha, seu idiota cego. Você provavelmente abriu seu próprio negócio e viu seus produtos de lixo lá.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.prod";
			Text ="Os funcionários mais preguiçosos da cidade...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.prod";
			Text ="Se os porcos tivessem polegares, seriam mais produtivos que seus funcionários! Pelo menos os porcos são mais espertos que eles...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.prod";
			Text ="*chorando*";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.prod";
			Text ="Com licença? Meus funcionários são pelo menos tão produtivos quanto qualquer porco por aí!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.prod";
			Text ="Você está brincando comigo? Meus funcionários são apenas os melhores dos melhores. Eu mesmo escolhi cada um!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.prod";
			Text ="Hahaha, obrigado por me fazer rir com seus grunhidos! Isso foi muito engraçado.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.openLine.int";
			Text ="Insulto à humanidade...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fullLine.int";
			Text ="Sua família é tão estúpida! Sempre que tenho que falar com um de vocês, tenho vontade de me afogar num barril de bebida do Guntram.";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.csAnswer.int";
			Text ="Eu... uh... uh...";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.sAnswer.int";
			Text ="Eu... estúpido...?";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.fAnswer.int";
			Text ="Você está me chamando de estúpido? Todo mundo sabe que você não consegue nem contar até dez!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.int.toMale";
			Text ="Ah não, você está louco? Guarda Municipal! Ajuda! Temos um louco aqui!";
		},
		LocDirectEntry
		{
			Key ="$d.act.PublicShaming.cfAnswer.int.toFemale";
			Text ="Ah não, você está louco? Guarda Municipal! Ajuda! Temos uma mulher louca aqui!";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.openLine.int.toFemale";
