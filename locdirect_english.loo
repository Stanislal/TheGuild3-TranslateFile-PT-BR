		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceJob.line.rich1";
			Text ="Gosto da minha profissão. Acredito que outras pessoas me respeitam.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceJob.answer.poor1";
			Text ="Tenho inveja de você porque odeio meu trabalho.";
