		LocDirectEntry
		{
			Key ="$gui.MPLanguage.tooltip";
			Text ="Aqui você pode definir em qual idioma você planeja se comunicar no jogo. Isso definirá o ícone da bandeira mostrado ao lado da entrada do jogo no lobby.";
