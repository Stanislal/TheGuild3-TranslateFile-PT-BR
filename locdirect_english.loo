		},
		LocDirectEntry
		{
			Key ="$season3";
			Text ="Outono";
		},
		LocDirectEntry
		{
			Key ="$SendToSchool";
			Text ="Enviar para a escola";
		},
		LocDirectEntry
		{
			Key ="$SendToSchoolDesc";
			Text ="Use seu privilégio para enviar seu filho para a escola onde ele permanecerá por vários anos e receberá educação. Quando seu filho se formar, ele receberá pontos de experiência e uma melhoria permanente em um atributo primário aleatório.";
		},
		LocDirectEntry
		{
			Key ="$SevenMilesBoots";
			Text ="Chuteiras de sete léguas";
		},
		LocDirectEntry
		{
			Key ="$SevenMilesBootsDesc";
			Text ="Graças aos músculos das pernas bem desenvolvidos, você é mais rápido do que os outros ao caminhar e correr.";
		},
		LocDirectEntry
		{
			Key ="$ShadowDagger";
			Text ="Adaga sombria";
		},
		LocDirectEntry
		{
			Key ="$ShadowDaggerDesc";
			Text ="Esta adaga foi habilmente embrulhada em várias camadas de linho, por isso é totalmente normal e pode ser usada discretamente, sem atrair a menor atenção. Combina bem com qualquer tipo de traje comum e mais parece uma ferramenta de trabalho, embora seja uma arma letal...";
		},
		LocDirectEntry
		{
			Key ="$Sheep";
			Text ="Ovelha";
		},
		LocDirectEntry
		{
			Key ="$SheepDesc";
			Text ="As ovelhas podem ser tosquiadas e sua lã pode ser transformada em linha.";
		},
		LocDirectEntry
		{
			Key ="$Shield";
			Text ="Escudo";
		},
		LocDirectEntry
		{
			Key ="$ShieldDesc";
			Text ="O valor da sua armadura aumentará quando você carregar este escudo de ferro.";
		},
		LocDirectEntry
		{
			Key ="$ShortSword";
			Text ="Espada curta";
		},
		LocDirectEntry
		{
			Key ="$ShortSwordDesc";
			Text ="A espada curta é uma arma leve e ágil, mais perigosa que uma adaga em batalha, mas não pode ser escondida quando carregada.";
		},
		LocDirectEntry
		{
			Key ="$Silk";
			Text ="Seda";
		},
		LocDirectEntry
		{
			Key ="$SilkDesc";
			Text ="A seda é um tecido altamente precioso feito do casulo do bicho-da-seda.";
		},
		LocDirectEntry
		{
			Key ="$Silver";
			Text ="Prata";
		},
		LocDirectEntry
		{
			Key ="$SilverChain";
			Text ="Corrente de prata";
		},
		LocDirectEntry
		{
			Key ="$SilverChainDesc";
			Text ="Uma corrente de prata pode ser usada para adornar lindamente o pescoço de um cidadão ereto.";
		},
		LocDirectEntry
		{
			Key ="$SilverDesc";
			Text ="A prata é obtida do minério de prata. Um pouco menos valiosa que o ouro, embora mais dura, a prata não é usada apenas em joias, mas também em roupas finas e até em armaduras.";
		},
		LocDirectEntry
		{
			Key ="$SilverRing";
			Text ="Anel de Prata";
		},
		LocDirectEntry
		{
			Key ="$SilverRingDesc";
			Text ="Um anel de prata é a joia adequada para os cidadãos.";
		},
		LocDirectEntry
		{
			Key ="$SlateBoard";
			Text ="Quadro de ardósia";
		},
		LocDirectEntry
		{
			Key ="$SlateBoardDesc";
			Text ="O quadro de ardósia é um brinquedo que pode impulsionar o desenvolvimento intelectual do seu filho.";
		},
		LocDirectEntry
		{
			Key ="$SlateTile";
			Text ="Bloco de ardósia";
		},
		LocDirectEntry
		{
			Key ="$SlateTileDesc";
			Text ="Em vez das telhas de madeira comumente usadas, você pode colocar telhas de ardósia no telhado do seu edifício. Isto aumentará a robustez do edifício e a proteção contra incêndios.";
		},
		LocDirectEntry
		{
			Key ="$SleightOfHand";
			Text ="Prestidigitação";
		},
		LocDirectEntry
		{
			Key ="$SleightOfHandDesc";
			Text ="A prestidigitação permite que aqueles habilidosos nesta habilidade ganhem a vida como ladrões. Se você continuar nesse caminho, você se verá afundando cada vez mais em um mundo de crime, onde poderá aprender outras coisas."skills\"...";
		},
		LocDirectEntry
		{
			Key ="$SleightOfHandStealth";
			Text ="Artes de sombra";
		},
		LocDirectEntry
		{
			Key ="$SleightOfHandStealthDesc";
			Text ="Quem optar por adquirir esta habilidade deve estar ciente de que não há como voltar atrás! Pela primeira vez treinado nisso \"art\", you will be a villain feared and despised by all, and it won't be long before you feel the first sticky, innocent blood on your hands...
";
		},
		LocDirectEntry
		{
			Key ="$SmallBeer";
			Text ="Cerveja fraca";
		},
		LocDirectEntry
		{
			Key ="$SmallBeerDesc";
			Text ="Uma cerveja bastante amarga e com baixo teor alcoólico que pode ser bebida o dia todo. A cerveja fraca é menos contaminada do que a água de poço devido ao processo de fermentação, por isso não deixa você doente com tanta frequência...";
		},
		LocDirectEntry
		{
			Key ="$society.Alchimists.desc";
			Text ="A Guilda dos Alquimistas está procurando \"alternatives\" to the more mainstream sciences. Alchemists are not sorcerers, but many fear them merely for their knowledge and covert research.";
		},
		LocDirectEntry
		{
			Key ="$society.Alchimists.leader";
			Text ="Grande Alquimista";
		},
		LocDirectEntry
		{
			Key ="$society.Alchimists.leader.female";
			Text ="Grande Alquimista";
		},
		LocDirectEntry
		{
			Key ="$society.Alchimists.member";
			Text ="Alquimista";
		},
		LocDirectEntry
		{
			Key ="$society.Alchimists.member.female";
			Text ="Alquimista";
		},
		LocDirectEntry
		{
			Key ="$society.Alchimists.motto";
			Text ="Pesquisa e sabedoria.";
		},
		LocDirectEntry
		{
			Key ="$society.Alchimists.name";
			Text ="Guilda dos Alquimistas";
		},
		LocDirectEntry
		{
			Key ="$society.antonianorder.desc";
			Text ="A Ordem dos Médicos surgiu da Ordem de Santo António - Canonici Regulares Sancti Antonii - fundada em 1095 como Ordem Hospitalar Cristã. Os membros da guilda se dedicam ao tratamento de doenças e epidemias utilizando a medicina moderna.";
		},
		LocDirectEntry
		{
			Key ="$society.antonianorder.leader";
			Text ="Arco Médico";
		},
		LocDirectEntry
		{
			Key ="$society.antonianorder.leader.female";
			Text ="Arch Médica";
		},
		LocDirectEntry
		{
			Key ="$society.antonianorder.member";
			Text ="Médico";
		},
		LocDirectEntry
		{
			Key ="$society.antonianorder.member.female";
			Text ="Médico";
		},
		LocDirectEntry
		{
			Key ="$society.antonianorder.motto";
			Text ="Cure o mundo!";
		},
		LocDirectEntry
		{
			Key ="$society.antonianorder.name";
			Text ="Guilda dos Médicos";
		},
		LocDirectEntry
		{
			Key ="$society.artificers.desc";
			Text ="Este culto segue o caminho antigo e oculto de criar vida a partir do barro, como o próprio Deus fez. Eles não são adoradores do diabo nem hereges, mas na verdade são criadores e alquimistas que querem revelar o mistério da própria vida.";
		},
		LocDirectEntry
		{
			Key ="$society.artificers.leader";
			Text ="Grande Cultista";
		},
		LocDirectEntry
		{
			Key ="$society.artificers.leader.female";
			Text ="Grande Cultista";
		},
		LocDirectEntry
		{
			Key ="$society.artificers.members";
			Text ="Cultista";
		},
		LocDirectEntry
		{
			Key ="$society.artificers.members.female";
			Text ="Cultista";
		},
		LocDirectEntry
		{
			Key ="$society.artificers.motto";
			Text ="A criação é um mistério que queremos revelar.";
		},
		LocDirectEntry
		{
			Key ="$society.artificers.name";
			Text ="Guilda dos Ocultistas";
		},
		LocDirectEntry
		{
			Key ="$society.brotherhoodoflight.desc";
			Text ="Uma das associações mais misteriosas e perigosas é a Guilda dos Iluminados. Os membros desta guilda acreditam que o fim do mundo está próximo e que é sua missão sagrada acelerar esse fim. São almas torturadas; uma associação de fanáticos com o objetivo claro de eventualmente destruir todas as outras guildas.";
		},
		LocDirectEntry
		{
			Key ="$society.brotherhoodoflight.leader";
			Text ="Arco Iluminado";
		},
		LocDirectEntry
		{
			Key ="$society.brotherhoodoflight.leader.female";
			Text ="Arco Iluminado";
		},
		LocDirectEntry
		{
			Key ="$society.brotherhoodoflight.member";
