		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceSong.answer.poor2";
			Text ="Prefiro ter algumas moedas na minha bolsa de dinheiro do que ouvir música!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceSong.answer.com1";
			Text ="De novo não! Pare com seus poemas e músicas e, por favor, encontre um emprego adequado!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.niceSong.answer.com2";
