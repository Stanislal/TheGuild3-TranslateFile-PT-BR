		LocDirectEntry
		{
			Key ="$d.act.embRom.cfAnswer.int.toMale.1";
			Text ="Eu? Andar ao seu lado e conversar? Não, obrigado!";
		},
		LocDirectEntry
		{
			Key ="$d.act.embRom.cfAnswer.int.toMale.2";
			Text ="Gosto de uma boa conversa... se a pessoa com quem estou conversando não fosse tão burra quanto você. Vá e encontre outra pessoa.";
