		LocDirectEntry
		{
			Key ="$action.BribeEnemyEmployeesDesc";
			Text ="Um pequeno suborno pode fazer com que os funcionários dos seus concorrentes diminuam o ritmo. Se o suborno for bem-sucedido, os funcionários trabalharão mais devagar por um tempo.";
		},
		LocDirectEntry
		{
			Key ="$action.Loitering";
