			Text ="Minha mãe poderia fazer melhor!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.fight.com4";
			Text ="Bom soco!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.fight.com5";
			Text ="Quero apostar 10 moedas! Quem está organizando as apostas?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.fight.com6";
			Text ="Por que toda essa violência?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.fight.com7";
