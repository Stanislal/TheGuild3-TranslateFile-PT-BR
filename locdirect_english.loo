		LocDirectEntry
		{
			Key ="$d.act.mProtestant.openLine.v5.bb_intim";
			Text ="Protestantes são modestos...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fullLine.v5.bb_intim";
			Text ="Na Igreja Católica, as regras só se aplicam aos pobres. Os protestantes são mais modestos.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.sAnswer.v5.bb_intim";
			Text ="Pessoas modestas são dignas de respeito.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mProtestant.fAnswer.v5.bb_intim";
			Text ="Os protestantes não são modestos, são apenas POBRES.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v1.int_intim";
			Text ="A Igreja Católica tem a tradição mais longa.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v1.int_intim";
			Text ="A Igreja Católica tem a mais longa tradição e história. Nossa Igreja proporciona uma sensação de estabilidade para nossos crentes.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v1.int_intim";
			Text ="É difícil argumentar contra isso. A Igreja Católica é estável e segura.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v1.int_intim";
			Text ="Tradição e história não bastam.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v1.char_intim";
			Text ="A Igreja Católica ajuda os pobres...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v1.char_intim";
			Text ="A Igreja Católica ajuda os pobres, os doentes, as viúvas e os órfãos. Quem não gostaria de fazer parte de uma igreja assim?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v1.char_intim";
			Text ="De fato. Os católicos fazem muito pelos pobres.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v1.char_intim";
			Text ="O clero faz tanto pelos pobres como por si mesmo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v1.bb_intim";
			Text ="O próprio São Pedro fundou a nossa Igreja...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v1.bb_intim";
			Text ="O próprio São Pedro fundou nossa igreja. Somente a autoridade dele deveria ser suficiente para persuadi-lo a se converter.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v1.bb_intim";
			Text ="A autoridade de São Pedro é convincente...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v1.bb_intim";
			Text ="Não há evidências de que isso seja verdade! Sobre o que mais os católicos estão mentindo?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v2.int_intim";
			Text ="Protestantes querem permitir o divórcio...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v2.int_intim";
			Text ="Os protestantes só se separaram dos católicos porque queriam poder divorciar-se.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v2.int_intim";
			Text ="O divórcio significa quebrar o sacramento do casamento. Isso é ultrajante!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v2.int_intim";
			Text ="O que há de errado nisso?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v2.char_intim";
			Text ="É ótimo fazer parte de algo maior...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v2.char_intim";
			Text ="Não é ótimo fazer parte de algo maior que você? A Igreja Católica desperta esse sentimento em você.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v2.char_intim";
			Text ="Exatamente, é uma sensação maravilhosa!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v2.char_intim";
			Text ="Algumas pessoas valorizam mais a liberdade do que o sentimento de pertencimento.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v2.bb_intim";
			Text ="Os católicos oferecem mais ajuda que os protestantes...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v2.bb_intim";
			Text ="A Igreja Católica ajuda os pobres, a arte e a ciência. O que os protestantes têm a oferecer?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v2.bb_intim";
			Text ="Precisamente! Os protestantes não têm nada de significativo a oferecer.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v2.bb_intim";
			Text ="Fé verdadeira e ensino de Deus. O clero católico só gasta o ouro dos outros.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v3.int_intim";
			Text ="Os católicos patrocinam a arte e a ciência...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v3.int_intim";
			Text ="A arte e a ciência só se desenvolvem devido ao patrocínio da Igreja Católica. Nenhuma outra Igreja demonstra isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v3.int_intim";
			Text ="Que verdade! Que conquista – a arte e a ciência são realmente importantes para o artesanato.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v3.int_intim";
			Text ="A igreja deve ser devotada a Deus e à fé, não a quaisquer pinturas e invenções.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v3.char_intim";
			Text ="A ira de Deus dominará os protestantes...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v3.char_intim";
			Text ="A ira de Deus dominará os protestantes e sua heresia! Ninguém vai querer pertencer a eles no Dia do Julgamento!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v3.char_intim";
			Text ="Ah... nesse caso, ser católico parece ser uma aposta mais segura.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v3.char_intim";
			Text ="Os católicos veem heresia em todos os lugares. Todos vocês deveriam orar, mediar e distanciar-se do mundo.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v3.bb_intim";
			Text ="Os protestantes não são confiáveis...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v3.bb_intim";
			Text ="Os protestantes são como crianças que se rebelam contra os pais. Um homem sábio confiaria sua alma a essas pessoas?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v3.bb_intim";
			Text ="Uma pessoa sábia não faria isso. Somente a Igreja Católica parece ser confiável.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v3.bb_intim";
			Text ="Uma pessoa sábia também não confiaria a sua alma à Igreja Católica.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v4.int_intim";
			Text ="Nossos crentes podem pedir ajuda aos santos...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v4.int_intim";
			Text ="Os santos desempenham um papel importante na Igreja Católica. Nossos crentes sempre podem recorrer a eles em momentos de angústia.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v4.int_intim";
			Text ="É verdade, existe um padroeiro de tudo que pode interceder em favor dos fiéis.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v4.int_intim";
			Text ="Santos são apenas pessoas! Somente Deus tem o poder de nos ajudar.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v4.char_intim";
			Text ="Protestantes são contra imagens sagradas...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v4.char_intim";
			Text ="As igrejas protestantes não têm imagens sagradas... que deprimente! Temos imagens de Deus em nossas casas.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v4.char_intim";
			Text ="Todo mundo adora imagens sagradas! Uma igreja sem eles é simplesmente uma abóbada sombria!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v4.char_intim";
			Text ="E se essas imagens sagradas não agradarem a Deus?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v4.bb_intim";
			Text ="É sensato arriscar sua alma por hereges?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v4.bb_intim";
			Text ="É sensato arriscar sua alma por hereges? Tome a decisão certa e faça parte da Igreja Católica.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v4.bb_intim";
			Text ="Ninguém deveria arriscar sua alma. É melhor seguir o caminho seguro.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v4.bb_intim";
			Text ="E se, aos olhos de Deus, o catolicismo for uma heresia?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v5.int_intim";
			Text ="Ser católico tem muitas vantagens...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v5.int_intim";
			Text ="Fazer parte da Igreja Católica garante respeito, influência e a salvação da sua alma.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v5.int_intim";
			Text ="Ser respeitado e influente parece tentador. E claro, aquela coisa da alma também faz bem!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v5.int_intim";
			Text ="Isso não é verdade, há muitos católicos pobres e impotentes.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v5.char_intim";
			Text ="Deus valoriza a Igreja Católica...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v5.char_intim";
			Text ="Se Deus não valorizasse a Igreja Católica, Ele não a teria destruído há muito tempo? Os protestantes não passam de hereges!";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v5.char_intim";
			Text ="Essa é uma maneira interessante de pensar sobre esse problema, e até bastante persuasiva.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v5.char_intim";
			Text ="Os pagãos também viveram por muito tempo em suas terras antes do surgimento do Cristianismo. Onde eles estão agora, hein?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.openLine.v5.bb_intim";
			Text ="Os pecadores deveriam ser salvos?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fullLine.v5.bb_intim";
			Text ="Os protestantes prometem salvação a qualquer crente, mesmo que esta pessoa seja um pecador! Isso não parece muito fácil?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.sAnswer.v5.bb_intim";
			Text ="Sim, é verdade! Algumas pessoas tentam viver sem pecado, mas recebem a mesma recompensa que pecadores terríveis.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mCatholic.fAnswer.v5.bb_intim";
			Text ="Para ser sincero, acredito (haha) que muitas pessoas gostam das regras protestantes nesse aspecto. Incluindo eu.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor1";
			Text ="Conte-nos mais!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor2";
			Text ="Que milagres...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor3";
			Text ="Bem-aventurados os pobres!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor4";
			Text ="Amém.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor5";
			Text ="Fala baixo, quero ouvir...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor6";
			Text ="Arrependa-se!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor7";
			Text ="Deus seja louvado.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor8";
			Text ="Somos todos amados...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor9";
			Text ="Essa é a palavra de Deus.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor10";
			Text ="Senhor, nos abençoe!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor11";
			Text ="Senhor, perdoe-nos...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor12";
			Text ="Todos nós somos pecadores!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.poor13";
			Text ="Alguém entende isso?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com1";
			Text ="Quais são os mandamentos?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com2";
			Text ="Aleluia!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com3";
			Text ="Graça aos humildes.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com4";
			Text ="Sinto o espírito santo.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com5";
			Text ="Vamos orar.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com6";
			Text ="A grandeza de Deus não tem limites!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com7";
			Text ="Deus tenha misericórdia de seus pecadores...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.com8";
			Text ="Que vergonha...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.rich1";
			Text ="Ave Maria, cheia de graça...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.rich2";
			Text ="Deus, dê-nos a sua graça!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.rich3";
			Text ="Nós imploramos por perdão...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.giveSermon.rich4";
			Text ="Louvado seja o Senhor!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor1";
			Text ="O que é uma alma?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor2";
			Text ="Louvado seja Sua glória!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor3";
			Text ="Isso pode realmente ser verdade?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor4";
			Text ="O que deveria ser o Paraíso?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor5";
			Text ="Podemos ser salvos?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor6";
			Text ="Um arbusto falante?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor7";
			Text ="É difícil de acreditar..";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor8";
			Text ="É esse o caminho?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor9";
			Text ="Quem acreditaria nisso?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor10";
			Text ="Essas são apenas histórias.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor11";
			Text ="Que Deus parece ser interessante.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.poor12";
			Text ="Precisamos desse tipo de Deus.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com1";
			Text ="Eu nunca soube!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com2";
			Text ="Existe outro Deus?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com3";
			Text ="Seus ensinamentos tocam meu coração.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com4";
			Text ="Deus ama... MIM?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com5";
			Text ="estou ouvindo...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com6";
			Text ="Vá em frente...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com7";
			Text ="Isso não é convincente.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.com8";
			Text ="Isso é algo novo.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.rich1";
			Text ="Fascinante...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.rich2";
			Text ="Serei perdoado?";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.rich3";
			Text ="Esse Deus é o melhor!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.winBelivers.rich4";
			Text ="Louvado seja Ele! O Senhor!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor1";
			Text ="Por favor, pegue esta última moeda...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor2";
			Text ="Hmmm... pão...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor3";
			Text ="Isso é chato...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor4";
			Text ="O Senhor está conosco.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor5";
			Text ="Livra-nos do mal.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor6";
			Text ="Conceda-nos uma boa colheita...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor7";
			Text ="Nós te pedimos, ó Senhor...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor8";
			Text ="Amém.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor9";
			Text ="Senhor, conceda-nos saúde.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor10";
			Text ="Em Deus confiamos.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor11";
			Text ="Deus, ajude-nos.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.poor12";
			Text ="Pedimos perdão.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com1";
			Text ="Perdoa-nos os nossos pecados.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com2";
			Text ="Dá-nos o pão nosso de cada dia...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com3";
			Text ="Ore por nossas famílias...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com4";
			Text ="Nossa fé é forte.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com5";
			Text ="Deus seja louvado.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com6";
			Text ="Por favor, apoie-nos...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com7";
			Text ="Deus esteja conosco.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.com8";
			Text ="Sejamos fortes em nossa fé.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.rich1";
			Text ="In nomine patris et filii et spiritus sancti...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.rich2";
			Text ="O Senhor está conosco.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.rich3";
			Text ="Deveríamos doar mais.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.churchService.rich4";
			Text ="Senhor, por favor proteja as pessoas ricas...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor1";
			Text ="Vamos dançar!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor2";
			Text ="Continue jogando!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor3";
			Text ="Que melodia linda.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor4";
			Text ="Eu amo essa música.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor5";
			Text ="Toque mais alto!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor6";
			Text ="Chato...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor7";
			Text ="Lalala..lala..lalala";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor8";
			Text ="Dundun..dadah..";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor9";
			Text ="Isso é ótimo!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor10";
			Text ="Excelente!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor11";
			Text ="Continue!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor12";
			Text ="Todos nós gostamos dessa música!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.poor13";
			Text ="Toque outra coisa!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com1";
			Text ="Ótimo desempenho.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com2";
			Text ="Esse é o verdadeiro talento.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com3";
			Text ="Música direto do coração.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com4";
			Text ="Nada mal.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com5";
			Text ="Que música alegre.";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com6";
			Text ="Acho que conheço esse...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com7";
			Text ="É uma música fabulosa!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com8";
			Text ="Mais rápido!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.com9";
			Text ="Que melodia!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.rich1";
			Text ="Bravo!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.rich2";
			Text ="Magnífico!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.rich3";
			Text ="Já ouvi performances melhores...";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.rich4";
			Text ="Ainda!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.rich5";
			Text ="Música é pura alegria!";
		},
		LocDirectEntry
		{
			Key ="$d.poi.music.rich6";
			Text ="Poderia ser melhor...";
		},
		LocDirectEntry
		{
			Key ="$SkullLamp";
			Text ="Lâmpada de caveira";
		},
		LocDirectEntry
		{
			Key ="$SkullLampDesc";
			Text ="Uma lâmpada de caveira é um item assustador. Por si só é inofensivo. Mas ai se for aceso, porque as órbitas oculares brilham com uma luz azulada e sombras misteriosas dançam ao redor do crânio. O pior, porém, são os ruídos da cavidade oral, que lembram o lamento dos mortos...";
		},
		LocDirectEntry
		{
			Key ="$action.SkullLamp";
