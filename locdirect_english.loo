		LocDirectEntry
		{
			Key ="$Command";
			Text ="Integridade";
		},
		LocDirectEntry
		{
			Key ="$CommandDesc";
			Text ="Você passou por uma escola de duras dificuldades, lutou tanto com cidadãos honestos quanto com bandidos para finalmente levar sua dinastia à prosperidade e renome. Como resultado, a sua confiança e a sua força de vontade amadureceram e agora você irradia uma força interior que lhe traz o respeito de muitos cidadãos, mas que intimida outros...";
		},
		LocDirectEntry
		{
			Key ="$CommonerClothes1";
			Text ="Roupas de camponês";
		},
		LocDirectEntry
		{
			Key ="$CommonerClothes1Desc";
			Text ="Este traje grosseiro é adequado para pessoas comuns.";
		},
		LocDirectEntry
		{
			Key ="$CommonerClothes2";
			Text ="Roupas de plebeu";
		},
		LocDirectEntry
		{
