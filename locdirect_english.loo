		LocDirectEntry
		{
			Key ="$RoseWater";
			Text ="Água de rosas";
		},
		LocDirectEntry
		{
			Key ="$RoseWaterDesc";
			Text ="O extrato de rosas silvestres é misturado ao mel para produzir água de rosas. O resultado é uma bebida que combina o delicado aroma das rosas e a doçura do mel. Diz-se que a água de rosas aumenta o bem-estar. Experimente!";
		},
		LocDirectEntry
		{
			Key ="$action.DrinkRoseWater";
			Text ="Beba água de rosas";
		},
		LocDirectEntry
		{
			Key ="$action.DrinkRoseWaterDesc";
			Text ="Se você beber água de rosas, seu bem-estar aumentará, o que terá um efeito positivo na sua fertilidade, mas terá um efeito negativo na sua capacidade de intimidar os outros.";
		},
		LocDirectEntry
		{
			Key ="$Soap";
			Text ="Sabonete de barbeiro";
		},
		LocDirectEntry
		{
			Key ="$SoapDesc";
