		},
		LocDirectEntry
		{
			Key ="$ui.Subquest.Desc9";
			Text ="Declare uma rivalidade contra outra dinastia.";
		},
		LocDirectEntry
		{
			Key ="$ui.Subquest.Name1";
			Text ="Ganhe moedas %nb%.";
		},
		LocDirectEntry
		{
			Key ="$ui.Subquest.Name10";
			Text ="Destrua todas as três dinastias traidoras.";
		},
		LocDirectEntry
		{
			Key ="$ui.Subquest.Name11.1";
			Text ="Encontre a primeira das dinastias traidoras.";
		},
		LocDirectEntry
