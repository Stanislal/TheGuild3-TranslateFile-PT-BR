		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v2.int_intim";
			Text ="Combinar religião e política é impensável. Como o sagrado e o profano poderiam ser unidos?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v2.int_intim";
			Text ="Ponto de vista interessante... Sim, gosto disso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v2.int_intim";
			Text ="Não, não, SEPARAR religião e política é impensável. Eles precisam ser combinados para um bem maior.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v2.char_intim";
			Text ="Rezar sem pensar em política...";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v2.char_intim";
			Text ="Não seria maravilhoso poder orar a Deus sem pensar em política?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v2.char_intim";
			Text ="De fato! A política não deve influenciar a nossa fé e as nossas orações.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v2.char_intim";
			Text ="Não há necessidade de levar uma vida secular para conseguir isso.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v2.bb_intim";
			Text ="Você acha que Deus estaria interessado em política?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v2.bb_intim";
			Text ="Você acha que Deus estaria interessado em política? Não deveríamos manter nosso Senhor e a política separados?";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v2.bb_intim";
			Text ="Ele provavelmente não estaria interessado. Então sim, uma ideologia secular também serviria a Deus.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fAnswer.v2.bb_intim";
			Text ="Deus é o único capaz de salvar a política. Sem fé, a política seria um jogo de poder sem moral.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.openLine.v3.int_intim";
			Text ="O sagrado e o profano não devem ser combinados.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.fullLine.v3.int_intim";
			Text ="A fé, a religião e a moralidade não devem ser combinadas com coisas mundanas como a política, a economia e o poder.";
		},
		LocDirectEntry
		{
			Key ="$d.act.mSecular.sAnswer.v3.int_intim";
			Text ="Esta separação de fato faz sentido.";
