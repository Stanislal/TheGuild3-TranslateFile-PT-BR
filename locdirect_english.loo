		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.answer.com2";
			Text ="Por favor, não. Não estou interessado.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.answer.rich1";
			Text ="Vá para a ralé com suas piadas. Talvez eles achem você divertido...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodJoke.answer.rich2";
			Text ="Nem se preocupe, eu não entendo piadas.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.line.poor1";
			Text ="Você já ouviu isso...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.line.poor2";
			Text ="Alguém me disse isso...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.line.com1";
			Text ="Há um boato de que...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.line.com2";
			Text ="As pessoas estão dizendo isso...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.line.rich1";
			Text ="Não gosto de boatos, mas...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.answer.poor1";
			Text ="Tenho certo desdém por boatos.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.answer.poor2";
			Text ="Você acha que devemos levar a fofoca a sério?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.answer.com1";
			Text ="Pare de espalhar fofoca no meio da via pública! Conversaremos mais tarde.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.answer.com2";
			Text ="Nada me deixa mais feliz do que ouvir rumores ruins sobre meus concorrentes.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.answer.rich1";
			Text ="Eu não presto atenção.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.heardRumor.answer.rich2";
			Text ="Os rumores são vergonhosos! Por favor, pare de me incomodar com esse lixo.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.line.poor1";
			Text ="Tenho uma ótima oferta para você!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.line.poor2";
			Text ="Gostaria de apoiar meus negócios?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.line.com1";
			Text ="Gostaria de investir em um negócio muito lucrativo?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.line.rich1";
			Text ="Preciso de uma pequena quantia de dinheiro para financiar meu novo empreendimento!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.answer.poor1";
			Text ="Preciso do meu dinheiro para mim.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.answer.poor2";
			Text ="Você está me pedindo para lhe dar um dinheiro que não tenho. Preciso de mais ajuda do que você!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.answer.com1";
			Text ="Tem certeza de que tem uma boa ideia de negócio?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.answer.com2";
			Text ="Deixe-me pensar sobre isso. Enquanto isso, você gostaria de ouvir sobre minha ideia de negócio?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.answer.rich1";
			Text ="Você não vale minha ajuda ou meu tempo.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.goodInvest.answer.rich2";
			Text ="Acredito que encontrarei uma maneira melhor de gastar minha riqueza.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.line.poor1";
			Text ="Estamos todos melhor desde que deixamos de estar sob o domínio da nobreza. Mas por que ainda sou pobre?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.line.poor2";
			Text ="Demos nossas últimas moedas para pagar um resgate à nobreza para nos libertar... mas estamos realmente livres agora?";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.line.com1";
			Text ="Nós, cidadãos, podemos finalmente prosperar sem a nobreza. Devemos nos esforçar por muito mais!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.line.com2";
			Text ="Meus ancestrais trabalharam nos campos para seus senhores. Agora trabalho para o tesouro municipal...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.line.rich1";
			Text ="Como as Cidades Livres compraram sua liberdade da nobreza, podemos finalmente lutar pela verdadeira riqueza.";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.line.rich2";
			Text ="Desde que nos livramos do jugo da nobreza, a multidão tem desejado moedas. Vamos fazer algo contra isso!";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.answer.poor1";
			Text ="Nós pobres sempre seremos pobres, mesmo sem os nobres...";
		},
		LocDirectEntry
		{
			Key ="$d.npc.casualLife.newEra.answer.poor2";
